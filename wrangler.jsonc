{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "lastseason",
  "compatibility_date": "2026-07-15",
  "main": "./src/worker.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "COMMUNITY_DB",
      "database_name": "lastseason-community",
      "database_id": "76ce43c1-1d05-493f-a98c-a3044a515ebc"
    }
  ]
}
