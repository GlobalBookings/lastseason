{
  "name": "lastseason",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "check": "astro check",
    "audit:data": "node scripts/audit-seasons.mjs",
    "audit:current": "node scripts/audit-seasons.mjs --season=2025-26",
    "audit:release": "node scripts/audit-release.mjs",
    "deploy": "npm run build && wrangler deploy --keep-vars",
    "indexnow": "node scripts/submit-indexnow.mjs",
    "validate": "npm run check && npm run audit:current && npm run build && npm run audit:release",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.1.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "wrangler": "^4.110.0"
  }
}
