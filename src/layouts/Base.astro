---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: string;
  accentColor?: string;
  ogType?: string;
}

const { title, description, canonical, schema, accentColor, ogType = "website" } = Astro.props;
const siteUrl = "https://lastseason.co.uk";
const fullCanonical = canonical ? `${siteUrl}${canonical}` : siteUrl;
const fullTitle = title.includes("Last Season") ? title : `${title} | Last Season`;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={fullCanonical} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />

    <!-- Geo targeting for UK -->
    <meta name="geo.region" content="GB" />
    <meta name="geo.placename" content="United Kingdom" />
    <link rel="alternate" hreflang="en-GB" href={fullCanonical} />
    <link rel="alternate" hreflang="x-default" href={fullCanonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:site_name" content="Last Season" />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <!-- Bing specific -->
    <meta name="msvalidate.01" content="" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Font: Inter (preload for performance) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" media="print" onload="this.media='all'" />

    <!-- Schema markup -->
    {schema && <script type="application/ld+json" set:html={schema} />}

    <!-- Site-wide Organization schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Last Season",
      "url": siteUrl,
      "description": "Historical football season data  -  final tables, top scorers, season reviews.",
      "inLanguage": "en-GB",
    })} />

    <!-- Accent colour override -->
    {accentColor && <style set:html={`:root { --accent: ${accentColor}; --accent-light: ${accentColor}12; }`} />}

    <!-- Ezoic: add script tag here once account is active -->

    <!-- Google Analytics 4 -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-C2K4PMZEDJ"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-C2K4PMZEDJ');
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <header class="site-header" role="banner">
      <div class="container">
        <div class="header-inner">
          <a href="/" class="site-logo" aria-label="Last Season  -  home">
            <span class="logo-mark">LS</span>
            <span class="logo-text">last<span>season</span></span>
          </a>

          <nav class="site-nav" aria-label="Main navigation">
            <a href="/premier-league/">Premier League</a>
            <a href="/championship/">Championship</a>
            <a href="/la-liga/">La Liga</a>
            <a href="/bundesliga/">Bundesliga</a>
            <a href="/serie-a/">Serie A</a>
            <a href="/ligue-1/">Ligue 1</a>
            <a href="/scottish-premiership/">Scottish Prem</a>
            <a href="/mls/">MLS</a>
            <a href="/kits/" style="color:rgba(255,255,255,0.95);background:rgba(255,255,255,0.08);border-radius:6px;">Kits</a>
            <a href="/records/" style="color:rgba(255,255,255,0.95);background:rgba(255,255,255,0.08);border-radius:6px;">Records</a>
          </nav>

          <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" id="nav-toggle">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <line x1="3" y1="6" x2="21" y2="6" />
              <line x1="3" y1="12" x2="21" y2="12" />
              <line x1="3" y1="18" x2="21" y2="18" />
            </svg>
          </button>
        </div>
      </div>

      <div class="mobile-nav" id="mobile-nav" role="navigation" aria-label="Mobile navigation">
        <div class="nav-section-title">Leagues</div>
        <a href="/premier-league/">Premier League</a>
        <a href="/championship/">Championship</a>
        <a href="/la-liga/">La Liga</a>
        <a href="/bundesliga/">Bundesliga</a>
        <a href="/serie-a/">Serie A</a>
        <a href="/ligue-1/">Ligue 1</a>
        <a href="/scottish-premiership/">Scottish Premiership</a>
        <a href="/mls/">MLS</a>
        <div class="nav-section-title">Browse</div>
        <a href="/kits/">Kits 2024-25</a>
        <a href="/records/">Records & Stats</a>
        <a href="/faq/">Football FAQ</a>
        <a href="/clubs/">All Clubs</a>
        <a href="/players/">All Players</a>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer" role="contentinfo">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <a href="/" class="site-logo" style="color:#fff;font-size:1.1rem;">
              <span class="logo-mark">LS</span>
              <span class="logo-text">last<span>season</span></span>
            </a>
            <p>Historical football data archived. Final tables, top scorers, season reviews for leagues across Europe and beyond.</p>
          </div>
          <div>
            <div class="footer-heading">Leagues</div>
            <ul class="footer-link-list">
              <li><a href="/premier-league/">Premier League</a></li>
              <li><a href="/championship/">Championship</a></li>
              <li><a href="/la-liga/">La Liga</a></li>
              <li><a href="/bundesliga/">Bundesliga</a></li>
              <li><a href="/serie-a/">Serie A</a></li>
              <li><a href="/ligue-1/">Ligue 1</a></li>
            </ul>
          </div>
          <div>
            <div class="footer-heading">Site</div>
            <ul class="footer-link-list">
              <li><a href="/kits/">Kits 2024-25</a></li>
              <li><a href="/records/">Records & Stats</a></li>
              <li><a href="/faq/">Football FAQ</a></li>
              <li><a href="/clubs/">All Clubs</a></li>
              <li><a href="/players/">All Players</a></li>
              <li><a href="/privacy/">Privacy Policy</a></li>
              <li><a href="/cookies/">Cookie Policy</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <p class="footer-legal">&copy; {new Date().getFullYear()} lastseason.co.uk</p>
          <div class="gambling-disclaimer">
            18+ | <a href="https://www.begambleaware.org" rel="nofollow" target="_blank">BeGambleAware.org</a> | When the fun stops, stop. Affiliate links on this site may earn commission. All betting links carry rel="nofollow sponsored". T&Cs apply.
          </div>
        </div>
      </div>
    </footer>

    <script is:inline>
      const toggle = document.getElementById("nav-toggle");
      const nav = document.getElementById("mobile-nav");
      if (toggle && nav) {
        toggle.addEventListener("click", () => {
          const open = nav.classList.toggle("is-open");
          toggle.setAttribute("aria-expanded", String(open));
        });
      }
      document.querySelectorAll(".table-wrap").forEach(wrap => {
        const check = () => wrap.classList.toggle("is-scrollable", wrap.scrollWidth > wrap.clientWidth + 2);
        check();
        window.addEventListener("resize", check);
      });
    </script>
  </body>
</html>
