---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: string;
  accentColor?: string;
  ogType?: string;
  image?: string;
  imageAlt?: string;
  imageWidth?: number;
  imageHeight?: number;
  publishedTime?: string;
  modifiedTime?: string;
  robots?: string;
}

const {
  title,
  description,
  canonical,
  schema,
  accentColor,
  ogType = "website",
  image,
  imageAlt,
  imageWidth = 1200,
  imageHeight = 630,
  publishedTime,
  modifiedTime,
  robots = "index, follow, max-snippet:-1, max-image-preview:large",
} = Astro.props;
const siteUrl = "https://lastseason.co.uk";
const currentPath = Astro.url.pathname;
const fullCanonical = canonical?.startsWith("http") ? canonical : `${siteUrl}${canonical || currentPath}`;
const fullTitle = title.includes("Last Season") ? title : `${title} | Last Season`;
const inferredImage = currentPath.startsWith("/fantasy-football/squad-builder/")
  ? "/og/fantasy-squad-builder.png"
  : currentPath.startsWith("/fantasy-football/fixture-planner/")
    ? "/og/fantasy-fixture-planner.png"
    : currentPath.startsWith("/fantasy-football/captain-picker/")
      ? "/og/fantasy-captain-picker.png"
      : currentPath.includes("/fantasy-football/team-name") || currentPath.startsWith("/fantasy-football/mini-league-kit/")
        ? "/og/fantasy-team-names.png"
        : ["/player-compare/", "/transfer-planner/", "/chip-planner/", "/differentials/", "/my-plan/", "/control-room/", "/squad-doctor/", "/preseason-tracker/", "/mini-league-report/"].some((route) => currentPath.startsWith(`/fantasy-football${route}`))
          ? "/og/fantasy-planner.png"
          : currentPath.startsWith("/fantasy-football/")
            ? "/og/fantasy.png"
            : currentPath.startsWith("/scores/")
              ? "/og/scores.png"
              : currentPath.startsWith("/tools/") || currentPath.startsWith("/compare/")
                ? "/og/tools.png"
                : "/og/lastseason.png";
const socialImage = image || inferredImage;
const fullImage = socialImage.startsWith("http") ? socialImage : `${siteUrl}${socialImage}`;
const socialImageAlt = imageAlt || fullTitle;
const socialImageType = /\.jpe?g(?:$|\?)/i.test(socialImage) ? "image/jpeg" : "image/png";
const socialModifiedTime = modifiedTime || (currentPath.startsWith("/fantasy-football/") ? "2026-07-23T00:00:00+01:00" : undefined);
const isCurrent = (path: string) => currentPath === path || (path !== "/" && currentPath.startsWith(path));
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={fullCanonical} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#0b1620" />
    <meta name="google-site-verification" content="WJgP_4XApvaOWdCekx382oPqemu5z1QdFD8OASEnNJE" />

    <link rel="alternate" hreflang="en-GB" href={fullCanonical} />
    <link rel="alternate" hreflang="x-default" href={fullCanonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:site_name" content="Last Season" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:image" content={fullImage} />
    <meta property="og:image:secure_url" content={fullImage} />
    <meta property="og:image:type" content={socialImageType} />
    <meta property="og:image:width" content={String(imageWidth)} />
    <meta property="og:image:height" content={String(imageHeight)} />
    <meta property="og:image:alt" content={socialImageAlt} />
    {socialModifiedTime && <meta property="og:updated_time" content={socialModifiedTime} />}
    {publishedTime && ogType === "article" && <meta property="article:published_time" content={publishedTime} />}
    {socialModifiedTime && ogType === "article" && <meta property="article:modified_time" content={socialModifiedTime} />}
    <link rel="image_src" href={fullImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:url" content={fullCanonical} />
    <meta name="twitter:image" content={fullImage} />
    <meta name="twitter:image:alt" content={socialImageAlt} />

    <!-- Brand icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="apple-mobile-web-app-title" content="Last Season" />

    <!-- Schema markup -->
    {schema && <script is:inline type="application/ld+json" set:html={schema} />}

    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": `${siteUrl}/#organization`,
          "name": "Last Season",
          "url": siteUrl,
          "logo": {
            "@type": "ImageObject",
            "url": `${siteUrl}/icon-512.png`,
            "width": 512,
            "height": 512,
          },
          "email": "hello@lastseason.co.uk",
        },
        {
          "@type": "WebSite",
          "@id": `${siteUrl}/#website`,
          "name": "Last Season",
          "url": siteUrl,
          "publisher": { "@id": `${siteUrl}/#organization` },
          "description": "An interactive archive of completed football seasons, final tables, scorers and club history.",
          "inLanguage": "en-GB",
          "potentialAction": {
            "@type": "SearchAction",
            "target": `${siteUrl}/search/?q={search_term_string}`,
            "query-input": "required name=search_term_string",
          },
        },
        {
          "@type": "ImageObject",
          "@id": `${fullImage}#primaryimage`,
          "url": fullImage,
          "contentUrl": fullImage,
          "width": imageWidth,
          "height": imageHeight,
          "caption": socialImageAlt,
        },
        {
          "@type": "WebPage",
          "@id": `${fullCanonical}#webpage`,
          "url": fullCanonical,
          "name": fullTitle,
          "description": description,
          "isPartOf": { "@id": `${siteUrl}/#website` },
          "about": { "@id": `${siteUrl}/#organization` },
          "primaryImageOfPage": { "@id": `${fullImage}#primaryimage` },
          "inLanguage": "en-GB",
          ...(publishedTime ? { "datePublished": publishedTime } : {}),
          ...(socialModifiedTime ? { "dateModified": socialModifiedTime } : {}),
        },
      ],
    })} />

    <!-- Accent colour override -->
    {accentColor && <style set:html={`:root { --accent: ${accentColor}; --accent-light: ${accentColor}12; }`} />}

  </head>
  <body data-page-path={currentPath} data-page-title={fullTitle.replace(" | Last Season", "")}>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <header class="site-header" role="banner">
      <div class="container">
        <div class="header-inner">
          <a href="/" class="site-logo" aria-label="Last Season - home">
            <img class="logo-mark" src="/brand-mark.svg" alt="" width="34" height="34" />
            <span class="logo-text">last<span>season</span></span>
          </a>

          <nav class="site-nav" aria-label="Main navigation">
            <a href="/scores/" class="nav-live" aria-current={isCurrent("/scores/") ? "page" : undefined}><span></span>Scores</a>
            <a href="/daily/" class="nav-daily" aria-current={isCurrent("/daily/") ? "page" : undefined}>Daily game</a>
            <a href="/fantasy-football/" class="nav-fantasy" aria-current={isCurrent("/fantasy-football/") ? "page" : undefined}>Fantasy</a>
            <a href="/premier-league/" aria-current={isCurrent("/premier-league/") ? "page" : undefined}>Premier League</a>
            <a href="/championship/" aria-current={isCurrent("/championship/") ? "page" : undefined}>Championship</a>
            <details class="league-menu">
              <summary>More leagues <span aria-hidden="true">⌄</span></summary>
              <div class="league-menu__panel">
                <a href="/la-liga/">La Liga <small>Spain</small></a>
                <a href="/bundesliga/">Bundesliga <small>Germany</small></a>
                <a href="/serie-a/">Serie A <small>Italy</small></a>
                <a href="/ligue-1/">Ligue 1 <small>France</small></a>
                <a href="/scottish-premiership/">Scottish Premiership <small>Scotland</small></a>
              </div>
            </details>
            <a href="/tools/" class="nav-feature" aria-current={isCurrent("/tools/") ? "page" : undefined}>Tools</a>
            <a href="/compare/" class="nav-feature" aria-current={isCurrent("/compare/") ? "page" : undefined}>Compare</a>
            <a href="/records/" class="nav-feature" aria-current={isCurrent("/records/") ? "page" : undefined}>Records</a>
            <button type="button" class="nav-search-button" data-search-toggle aria-label="Search Last Season">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="m20 20-3.5-3.5"></path></svg>
              <span>Search</span><kbd>/</kbd>
            </button>
            <a href="/my/" class="nav-profile" aria-current={isCurrent("/my/") ? "page" : undefined}>My LS</a>
          </nav>

          <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" id="nav-toggle">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <line x1="3" y1="6" x2="21" y2="6" />
              <line x1="3" y1="12" x2="21" y2="12" />
              <line x1="3" y1="18" x2="21" y2="18" />
            </svg>
          </button>
        </div>
      </div>

      <div class="mobile-nav" id="mobile-nav" role="navigation" aria-label="Mobile navigation">
        <a href="/scores/" class="mobile-live-link"><span></span> Latest scores & fixtures</a>
        <a href="/daily/">Daily football game</a>
        <a href="/fantasy-football/">Fantasy football helpers</a>
        <a href="/my/">My Last Season</a>
        <div class="nav-section-title">Leagues</div>
        <a href="/premier-league/">Premier League</a>
        <a href="/championship/">Championship</a>
        <a href="/la-liga/">La Liga</a>
        <a href="/bundesliga/">Bundesliga</a>
        <a href="/serie-a/">Serie A</a>
        <a href="/ligue-1/">Ligue 1</a>
        <a href="/scottish-premiership/">Scottish Premiership</a>
        <a href="/mls/">MLS</a>
        <div class="nav-section-title">Browse</div>
        <a href="/kits/">Kit Colour Archive</a>
        <a href="/football-shirts/">Buy Football Shirts</a>
        <a href="/records/">Records & Stats</a>
        <a href="/faq/">Football FAQ</a>
        <a href="/clubs/">All Clubs</a>
        <a href="/players/">All Players</a>
        <a href="/tools/">Interactive Tools</a>
        <a href="/compare/">Season Comparisons</a>
        <button type="button" class="mobile-search-button" data-search-toggle>Search the archive <span aria-hidden="true">→</span></button>
      </div>
    </header>

    <aside class="search-drawer" id="search-drawer" hidden aria-label="Search Last Season">
      <button class="search-drawer__backdrop" type="button" data-search-close aria-label="Close search"></button>
      <div class="search-drawer__panel" role="search">
        <div class="search-drawer__top"><span>Search the football archive</span><button type="button" data-search-close aria-label="Close search">Esc</button></div>
        <form action="/search/" method="get">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="m20 20-3.5-3.5"></path></svg>
          <label for="global-search" class="sr-only">Search by club, player, league or season</label>
          <input id="global-search" name="q" type="search" autocomplete="off" placeholder="Try Arsenal, 2003–04 or Thierry Henry" />
          <button type="submit">Search</button>
        </form>
        <div class="search-drawer__suggestions"><span>Popular:</span><a href="/fantasy-football/squad-builder/">Fantasy squad builder</a><a href="/premier-league/2003-04/">Invincibles</a><a href="/records/all-time-top-scorers/">Top scorers</a><a href="/tools/season-compare/">Compare seasons</a></div>
      </div>
    </aside>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer" role="contentinfo">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <a href="/" class="site-logo" style="color:#fff;font-size:1.1rem;">
              <img class="logo-mark" src="/brand-mark.svg" alt="" width="34" height="34" />
              <span class="logo-text">last<span>season</span></span>
            </a>
            <p>Historical football data archived. Final tables, top scorers, season reviews for leagues across Europe and beyond.</p>
          </div>
          <div>
            <div class="footer-heading">Leagues</div>
            <ul class="footer-link-list">
              <li><a href="/premier-league/">Premier League</a></li>
              <li><a href="/championship/">Championship</a></li>
              <li><a href="/la-liga/">La Liga</a></li>
              <li><a href="/bundesliga/">Bundesliga</a></li>
              <li><a href="/serie-a/">Serie A</a></li>
              <li><a href="/ligue-1/">Ligue 1</a></li>
            </ul>
          </div>
          <div>
            <div class="footer-heading">Site</div>
            <ul class="footer-link-list">
              <li><a href="/tools/">Interactive Tools</a></li>
              <li><a href="/fantasy-football/">Fantasy Football Helpers</a></li>
              <li><a href="/daily/">Daily Football Game</a></li>
              <li><a href="/games/">More Football Games</a></li>
              <li><a href="/on-this-day/">On This Day</a></li>
              <li><a href="/my/">My Last Season</a></li>
              <li><a href="/scores/">Latest Scores & Fixtures</a></li>
              <li><a href="/compare/">Season Comparisons</a></li>
              <li><a href="/football-shirts/">Football Shirt Buying Guide</a></li>
              <li><a href="/search/">Search</a></li>
              <li><a href="/kits/">Kit Colour Archive</a></li>
              <li><a href="/records/">Records & Stats</a></li>
              <li><a href="/faq/">Football FAQ</a></li>
              <li><a href="/clubs/">All Clubs</a></li>
              <li><a href="/players/">All Players</a></li>
            </ul>
          </div>
          <div>
            <div class="footer-heading">Trust</div>
            <ul class="footer-link-list">
              <li><a href="/about/">About</a></li>
              <li><a href="/methodology/">Methodology & Sources</a></li>
              <li><a href="/corrections/">Corrections</a></li>
              <li><a href="/partners/">Data & Partnerships</a></li>
              <li><a href="/privacy/">Privacy Policy</a></li>
              <li><a href="/cookies/">Cookie Policy</a></li>
              <li><button class="footer-choice-button" type="button" data-reset-analytics>Privacy choices</button></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <p class="footer-legal">&copy; {new Date().getFullYear()} lastseason.co.uk</p>
          <p class="footer-legal">Independent football archive. Corrections are welcomed and logged.</p>
        </div>
      </div>
    </footer>

    <aside class="privacy-choice" id="privacy-choice" hidden aria-label="Privacy choices" aria-live="polite">
      <div>
        <strong>Your privacy choices</strong>
        <p>We use optional, privacy-conscious analytics to understand which archive pages are useful. No advertising trackers are loaded.</p>
        <a href="/cookies/">Cookie details</a>
      </div>
      <div class="privacy-choice-actions">
        <button type="button" data-analytics-choice="denied">Reject analytics</button>
        <button type="button" class="privacy-accept" data-analytics-choice="granted">Allow analytics</button>
      </div>
    </aside>

    <script is:inline>
      const toggle = document.getElementById("nav-toggle");
      const nav = document.getElementById("mobile-nav");
      if (toggle && nav) {
        toggle.addEventListener("click", () => {
          const open = nav.classList.toggle("is-open");
          toggle.setAttribute("aria-expanded", String(open));
          document.body.classList.toggle("nav-open", open);
        });
      }

      const searchDrawer = document.getElementById("search-drawer");
      const globalSearch = document.getElementById("global-search");
      const openSearch = () => {
        if (!searchDrawer) return;
        searchDrawer.hidden = false;
        document.body.classList.add("search-open");
        requestAnimationFrame(() => globalSearch?.focus());
      };
      const closeSearch = () => {
        if (!searchDrawer) return;
        searchDrawer.hidden = true;
        document.body.classList.remove("search-open");
      };
      document.querySelectorAll("[data-search-toggle]").forEach((button) => button.addEventListener("click", openSearch));
      document.querySelectorAll("[data-search-close]").forEach((button) => button.addEventListener("click", closeSearch));
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeSearch();
          nav?.classList.remove("is-open");
          toggle?.setAttribute("aria-expanded", "false");
          document.body.classList.remove("nav-open");
        }
        if (event.key === "/" && !event.metaKey && !event.ctrlKey && !event.altKey && !["INPUT", "TEXTAREA", "SELECT"].includes(document.activeElement?.tagName || "")) {
          event.preventDefault(); openSearch();
        }
      });

      const pagePath = document.body.dataset.pagePath;
      const pageTitle = document.body.dataset.pageTitle;
      if (pagePath && pagePath !== "/" && pageTitle) {
        try {
          const key = "lastseason-history";
          const history = JSON.parse(localStorage.getItem(key) || "[]").filter((item) => item.path !== pagePath);
          history.unshift({ path: pagePath, title: pageTitle, visitedAt: Date.now() });
          localStorage.setItem(key, JSON.stringify(history.slice(0, 6)));
        } catch {}
      }

      const favouriteKey = "lastseason-favourite-leagues";
      const readFavourites = () => {
        try { return JSON.parse(localStorage.getItem(favouriteKey) || "[]"); } catch { return []; }
      };
      const syncFavouriteButtons = () => {
        const favourites = readFavourites();
        document.querySelectorAll("[data-favourite-league]").forEach((button) => {
          const active = favourites.includes(button.dataset.favouriteLeague);
          button.setAttribute("aria-pressed", String(active));
          button.classList.toggle("is-favourite", active);
          const label = active ? "Remove from my leagues" : "Save to my leagues";
          button.setAttribute("aria-label", label);
          const text = button.querySelector("[data-favourite-label]");
          if (text) text.textContent = active ? "Saved" : "Save league";
        });
      };
      document.querySelectorAll("[data-favourite-league]").forEach((button) => button.addEventListener("click", () => {
        const favourites = readFavourites();
        const slug = button.dataset.favouriteLeague;
        const next = favourites.includes(slug) ? favourites.filter((item) => item !== slug) : [...favourites, slug];
        try { localStorage.setItem(favouriteKey, JSON.stringify(next)); } catch {}
        syncFavouriteButtons();
        document.dispatchEvent(new CustomEvent("lastseason:favourites"));
      }));
      syncFavouriteButtons();

      const favouriteClubKey = "lastseason-favourite-clubs";
      const readFavouriteClubs = () => {
        try { return JSON.parse(localStorage.getItem(favouriteClubKey) || "[]"); } catch { return []; }
      };
      const syncFavouriteClubButtons = () => {
        const favourites = readFavouriteClubs();
        document.querySelectorAll("[data-favourite-club]").forEach((button) => {
          const active = favourites.includes(button.dataset.favouriteClub);
          button.setAttribute("aria-pressed", String(active));
          button.classList.toggle("is-favourite", active);
          const text = button.querySelector("[data-favourite-club-label]");
          if (text) text.textContent = active ? "Following" : (button.dataset.clubName ? `Follow ${button.dataset.clubName}` : "Follow club");
        });
      };
      document.querySelectorAll("[data-favourite-club]").forEach((button) => button.addEventListener("click", () => {
        const favourites = readFavouriteClubs();
        const slug = button.dataset.favouriteClub;
        const next = favourites.includes(slug) ? favourites.filter((item) => item !== slug) : [...favourites, slug];
        try { localStorage.setItem(favouriteClubKey, JSON.stringify(next)); } catch {}
        syncFavouriteClubButtons();
      }));
      syncFavouriteClubButtons();
      document.querySelectorAll(".table-wrap").forEach(wrap => {
        const check = () => wrap.classList.toggle("is-scrollable", wrap.scrollWidth > wrap.clientWidth + 2);
        check();
        window.addEventListener("resize", check);
      });

      const analyticsKey = "lastseason-analytics-choice";
      const privacyChoice = document.getElementById("privacy-choice");
      const fantasyCompletionEvents = new Set([
        "fantasy_name_copy",
        "fantasy_name_save",
        "fantasy_name_share",
        "fantasy_league_name_save",
        "fantasy_squad_generate",
        "fantasy_plan_save",
        "fantasy_squad_download",
        "fantasy_reminder_download",
      ]);
      window.lsTrack = (eventName, parameters = {}) => {
        if (typeof window.gtag !== "function") return false;
        const eventParameters = {
          page_path: window.location.pathname,
          page_title: document.body.dataset.pageTitle || document.title,
          ...parameters,
        };
        window.gtag("event", eventName, eventParameters);
        if (fantasyCompletionEvents.has(eventName)) {
          window.gtag("event", "fantasy_tool_complete", {
            ...eventParameters,
            completion_type: eventName,
          });
        }
        return true;
      };
      const loadAnalytics = () => {
        if (document.querySelector('script[data-lastseason-analytics]')) return;
        window.dataLayer = window.dataLayer || [];
        window.gtag = function(){ window.dataLayer.push(arguments); };
        window.gtag("js", new Date());
        window.gtag("config", "G-C2K4PMZEDJ", {
          anonymize_ip: true,
          page_location: window.location.href,
          page_path: window.location.pathname + window.location.search,
          page_title: document.title,
        });
        const script = document.createElement("script");
        script.async = true;
        script.dataset.lastseasonAnalytics = "true";
        script.src = "https://www.googletagmanager.com/gtag/js?id=G-C2K4PMZEDJ";
        document.head.appendChild(script);
      };
      let analyticsChoice = null;
      try { analyticsChoice = localStorage.getItem(analyticsKey); } catch {}
      if (analyticsChoice === "granted") loadAnalytics();
      if (!analyticsChoice && privacyChoice) privacyChoice.hidden = false;
      document.querySelectorAll("[data-analytics-choice]").forEach((button) => {
        button.addEventListener("click", () => {
          const choice = button.getAttribute("data-analytics-choice");
          try { localStorage.setItem(analyticsKey, choice); } catch {}
          if (choice === "granted") loadAnalytics();
          if (privacyChoice) privacyChoice.hidden = true;
        });
      });
      document.querySelectorAll("[data-reset-analytics]").forEach((button) => {
        button.addEventListener("click", () => {
          try { localStorage.removeItem(analyticsKey); } catch {}
          if (privacyChoice) privacyChoice.hidden = false;
        });
      });

      document.addEventListener("click", (event) => {
        const link = event.target instanceof Element ? event.target.closest("a[data-retailer]") : null;
        if (!link || typeof window.gtag !== "function") return;
        window.gtag("event", "retailer_click", {
          retailer: link.getAttribute("data-retailer"),
          commerce_context: link.getAttribute("data-commerce-context"),
          affiliate_link: link.getAttribute("data-affiliate") === "true",
        });
      });

      const fantasyActions = {
        "generate-squad": "fantasy_squad_generate",
        "save-squad": "fantasy_plan_save",
        "share-squad": "fantasy_squad_share",
        "download-squad": "fantasy_squad_download",
        "save-chips": "fantasy_plan_save",
        "save-transfer": "fantasy_plan_save",
        "regenerate-kit": "fantasy_mini_league_generate",
        "copy-kit": "fantasy_mini_league_copy",
      };
      document.addEventListener("click", (event) => {
        const element = event.target instanceof Element ? event.target.closest("a,button") : null;
        if (!element) return;
        const action = element.id ? fantasyActions[element.id] : null;
        if (action) window.lsTrack?.(action, { control_id: element.id });
        if (element instanceof HTMLAnchorElement && element.pathname.endsWith(".ics")) {
          window.lsTrack?.("fantasy_reminder_download", { reminder: element.pathname });
        }
        if (element instanceof HTMLAnchorElement && window.location.pathname.startsWith("/fantasy-football/") && element.pathname.startsWith("/fantasy-football/")) {
          window.lsTrack?.("fantasy_internal_click", { destination: element.pathname });
        }
      });

      if (window.location.pathname.startsWith("/fantasy-football/")) {
        const seenDepths = new Set();
        const measureDepth = () => {
          const available = document.documentElement.scrollHeight - window.innerHeight;
          if (available <= 0) return;
          const depth = Math.round((window.scrollY / available) * 100);
          [50, 90].forEach((threshold) => {
            if (depth >= threshold && !seenDepths.has(threshold)) {
              seenDepths.add(threshold);
              window.lsTrack?.("fantasy_content_depth", { percent_scrolled: threshold });
            }
          });
        };
        window.addEventListener("scroll", measureDepth, { passive: true });
      }
    </script>
  </body>
</html>
