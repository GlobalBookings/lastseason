---
import Base from "../../layouts/Base.astro";
import { getClubChallenges } from "../../utils/games";
const clubChallenges = getClubChallenges().slice(0, 18);
---

<Base title="Free Football History Games" description="Play free daily football history games using real final tables and scorer data. Guess the season, identify the player or solve a club challenge." canonical="/games/">
  <div class="container games-page">
    <header class="page-hero games-hero"><span class="section-kicker">Play the archive</span><h1>Football history, made playable.</h1><p class="subtitle">Short daily challenges built from reviewed tables and scoring records. No download and no account required.</p></header>
    <section class="featured-games">
      <a href="/daily/" class="game-card game-card--daily"><span>New every day</span><strong>Last Season Daily</strong><p>Identify the mystery season from six progressively revealed clues.</p><small>Play today →</small></a>
      <a href="/games/player-path/" class="game-card"><span>Daily player</span><strong>Player Path</strong><p>Follow the scoring trail and name the footballer.</p><small>Start guessing →</small></a>
      <a href="/games/missing-club/" class="game-card"><span>Daily table</span><strong>Missing Club</strong><p>Use position, points and record clues to identify the club.</p><small>Find the club →</small></a>
    </section>
    <section class="club-challenges">
      <div class="editorial-heading"><div><span class="section-kicker">Pick your colours</span><h2>Club challenges</h2></div><a href="/clubs/">Browse clubs →</a></div>
      <div class="club-challenge-grid">
        {clubChallenges.map((club) => <a href={`/games/clubs/${club.slug}/`}><span>{club.name.slice(0,2).toUpperCase()}</span><strong>{club.name}</strong><small>{club.puzzles.length} archive seasons →</small></a>)}
      </div>
    </section>
  </div>
</Base>

<style>
  .games-page { padding-bottom:4rem; }
  .games-hero { max-width:820px; }
  .games-hero h1 { font-size:clamp(2.6rem,6vw,5.5rem); max-width:12ch; line-height:.95; letter-spacing:-.07em; }
  .featured-games { display:grid; grid-template-columns:1.35fr 1fr 1fr; gap:.8rem; }
  .game-card { min-height:270px; display:flex; flex-direction:column; padding:1.35rem; background:#162633; border-radius:20px; color:#fff; }
  .game-card--daily { background:radial-gradient(circle at 80% 15%,rgba(113,230,158,.28),transparent 35%),#0b1620; }
  .game-card > span { color:#75e6a3; font-size:.64rem; font-weight:850; text-transform:uppercase; letter-spacing:.1em; }
  .game-card strong { margin-top:auto; font-size:1.55rem; }
  .game-card p { color:#9eafbb; font-size:.84rem; margin:.35rem 0 1rem; }
  .game-card small { color:#fff; font-weight:750; }
  .club-challenges { margin-top:3rem; }
  .club-challenge-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(190px,1fr)); gap:.65rem; }
  .club-challenge-grid a { display:grid; grid-template-columns:42px 1fr; gap:.1rem .7rem; align-items:center; min-height:78px; padding:.75rem; background:#fff; border:1px solid var(--border); border-radius:13px; color:var(--text); }
  .club-challenge-grid a > span { grid-row:1/3; display:grid; place-items:center; width:42px; height:42px; border-radius:12px; background:#0b1620; color:#75e6a3; font-size:.65rem; font-weight:850; }
  .club-challenge-grid small { color:var(--text-muted); }
  @media(max-width:800px) { .featured-games { grid-template-columns:1fr; } .game-card { min-height:210px; } }
</style>
