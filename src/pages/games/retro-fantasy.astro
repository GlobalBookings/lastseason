---
import Base from "../../layouts/Base.astro";
const legends=[
 {id:"schmeichel",name:"Peter Schmeichel",club:"Manchester United",pos:"GK",cost:8,score:94,era:"1990s"},
 {id:"cech",name:"Petr Čech",club:"Chelsea",pos:"GK",cost:8,score:93,era:"2000s"},
 {id:"seaman",name:"David Seaman",club:"Arsenal",pos:"GK",cost:7,score:88,era:"1990s"},
 {id:"adams",name:"Tony Adams",club:"Arsenal",pos:"DEF",cost:8,score:91,era:"1990s"},
 {id:"terry",name:"John Terry",club:"Chelsea",pos:"DEF",cost:9,score:95,era:"2000s"},
 {id:"ferdinand",name:"Rio Ferdinand",club:"Manchester United",pos:"DEF",cost:8,score:91,era:"2000s"},
 {id:"kompany",name:"Vincent Kompany",club:"Manchester City",pos:"DEF",cost:8,score:90,era:"2010s"},
 {id:"le-tissier",name:"Matt Le Tissier",club:"Southampton",pos:"MID",cost:8,score:90,era:"1990s"},
 {id:"gerrard",name:"Steven Gerrard",club:"Liverpool",pos:"MID",cost:10,score:97,era:"2000s"},
 {id:"lampard",name:"Frank Lampard",club:"Chelsea",pos:"MID",cost:10,score:98,era:"2000s"},
 {id:"scholes",name:"Paul Scholes",club:"Manchester United",pos:"MID",cost:9,score:93,era:"2000s"},
 {id:"yaya",name:"Yaya Touré",club:"Manchester City",pos:"MID",cost:9,score:94,era:"2010s"},
 {id:"henry",name:"Thierry Henry",club:"Arsenal",pos:"FWD",cost:12,score:100,era:"2000s"},
 {id:"shearer",name:"Alan Shearer",club:"Newcastle United",pos:"FWD",cost:11,score:99,era:"1990s"},
 {id:"rooney",name:"Wayne Rooney",club:"Manchester United",pos:"FWD",cost:10,score:96,era:"2000s"},
 {id:"drogba",name:"Didier Drogba",club:"Chelsea",pos:"FWD",cost:10,score:95,era:"2000s"},
 {id:"aguero",name:"Sergio Agüero",club:"Manchester City",pos:"FWD",cost:11,score:98,era:"2010s"},
];
const payload=JSON.stringify(legends).replace(/</g,"\\u003c");
const schema=JSON.stringify({"@context":"https://schema.org","@type":"Game","name":"Retro Fantasy Five","url":"https://lastseason.co.uk/games/retro-fantasy/","numberOfPlayers":{"@type":"QuantitativeValue","minValue":1,"maxValue":1}});
---
<Base title="Retro Fantasy Football Team Builder" description="Build and share a five-player Premier League legends team under a 50-credit budget using Last Season's editorial legacy index." canonical="/games/retro-fantasy/" schema={schema}>
  <div class="retro-page"><section class="retro-hero"><div class="container"><span>Archive game · no account</span><h1>Retro Fantasy Five</h1><p>Pick one goalkeeper, one defender, two midfielders and one forward for 50 credits. Maximum two legends from one club.</p><div class="retro-score"><strong id="retro-budget">50</strong><small>credits left</small><strong id="retro-index">0</strong><small>legacy index</small></div></div></section><section class="container retro-board"><div class="retro-team"><span class="section-kicker">Your five</span><h2 id="retro-title">Choose your legends</h2><div id="retro-selected" class="retro-slots"></div><div class="retro-actions"><button id="retro-share">Share team</button><button id="retro-download">Download card</button><button id="retro-clear">Clear</button></div><p id="retro-status">Legacy index is a Last Season editorial score, not historical fantasy points.</p></div><div><div class="retro-filters"><button aria-pressed="true" data-filter="All">All</button>{["GK","DEF","MID","FWD"].map(p=><button aria-pressed="false" data-filter={p}>{p}</button>)}</div><div class="retro-pool">{legends.map(p=><button class="retro-player" data-id={p.id} data-pos={p.pos}><span>{p.pos} · {p.era}</span><strong>{p.name}</strong><small>{p.club}</small><em>{p.cost}cr · index {p.score}</em></button>)}</div></div></section></div>
  <script is:inline type="application/json" id="retro-data" set:html={payload}></script><script is:inline>
    const players=JSON.parse(document.getElementById("retro-data")?.textContent||"[]"),byId=id=>players.find(p=>p.id===id),limits={GK:1,DEF:1,MID:2,FWD:1};let selected=[];try{selected=JSON.parse(localStorage.getItem("lastseason-retro-five")||"[]").filter(byId)}catch{}const esc=s=>String(s).replace(/[&<>"']/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
    function render(){const picked=selected.map(byId),spent=picked.reduce((n,p)=>n+p.cost,0),index=picked.reduce((n,p)=>n+p.score,0);document.getElementById("retro-budget").textContent=50-spent;document.getElementById("retro-index").textContent=index;document.getElementById("retro-title").textContent=picked.length===5?"Your Retro Fantasy Five":"Choose your legends";document.getElementById("retro-selected").innerHTML=["GK","DEF","MID","MID","FWD"].map((pos,i)=>{const prior=["GK","DEF","MID","MID","FWD"].slice(0,i).filter(x=>x===pos).length,p=picked.filter(x=>x.pos===pos)[prior];return p?`<button data-remove="${p.id}"><span>${p.pos}</span><strong>${esc(p.name)}</strong><small>${p.cost}cr · ${p.score}</small></button>`:`<div><span>${pos}</span><strong>Empty slot</strong></div>`}).join("");document.querySelectorAll("[data-remove]").forEach(b=>b.addEventListener("click",()=>{selected=selected.filter(id=>id!==b.dataset.remove);save()}));document.querySelectorAll("[data-id]").forEach(b=>b.setAttribute("aria-pressed",String(selected.includes(b.dataset.id))))}
    function save(){localStorage.setItem("lastseason-retro-five",JSON.stringify(selected));render()}document.querySelectorAll("[data-id]").forEach(b=>b.addEventListener("click",()=>{const p=byId(b.dataset.id);if(selected.includes(p.id)){selected=selected.filter(id=>id!==p.id);save();return}const picked=selected.map(byId),spent=picked.reduce((n,x)=>n+x.cost,0),clubs=picked.filter(x=>x.club===p.club).length,positions=picked.filter(x=>x.pos===p.pos).length;if(spent+p.cost>50)return document.getElementById("retro-status").textContent="That pick exceeds the 50-credit budget.";if(clubs>=2)return document.getElementById("retro-status").textContent="Maximum two players from one club.";if(positions>=limits[p.pos])return document.getElementById("retro-status").textContent=`Your ${p.pos} slots are already full.`;selected.push(p.id);document.getElementById("retro-status").textContent=selected.length===5?"Team complete—share it with the group chat.":"Player added.";save()}));document.querySelectorAll("[data-filter]").forEach(b=>b.addEventListener("click",()=>{document.querySelectorAll("[data-filter]").forEach(x=>x.setAttribute("aria-pressed",String(x===b)));document.querySelectorAll("[data-id]").forEach(p=>p.hidden=b.dataset.filter!=="All"&&p.dataset.pos!==b.dataset.filter)}));
    const text=()=>`My Retro Fantasy Five:\n${selected.map(byId).map(p=>`${p.pos}: ${p.name}`).join("\n")}\nLegacy index: ${selected.map(byId).reduce((n,p)=>n+p.score,0)}`;document.getElementById("retro-share")?.addEventListener("click",async()=>{if(selected.length!==5)return document.getElementById("retro-status").textContent="Complete all five slots before sharing.";try{if(navigator.share)await navigator.share({title:"My Retro Fantasy Five",text:text(),url:location.href});else await navigator.clipboard.writeText(`${text()}\n${location.href}`)}catch{}});
    document.getElementById("retro-download")?.addEventListener("click",()=>{if(selected.length!==5)return document.getElementById("retro-status").textContent="Complete all five slots before downloading.";const picked=selected.map(byId),c=document.createElement("canvas"),x=c.getContext("2d");c.width=1200;c.height=630;x.fillStyle="#0b1620";x.fillRect(0,0,1200,630);x.fillStyle="#75e6a3";x.font="800 25px system-ui";x.fillText("LAST SEASON · RETRO FANTASY FIVE",65,70);x.fillStyle="#fff";x.font="900 58px system-ui";x.fillText("My all-time five",65,145);picked.forEach((p,i)=>{x.fillStyle="#fff";x.font="800 31px system-ui";x.fillText(`${p.pos} · ${p.name}`,75,225+i*61);x.textAlign="right";x.fillStyle="#75e6a3";x.fillText(String(p.score),1110,225+i*61);x.textAlign="left"});x.fillStyle="#9eafbb";x.font="600 22px system-ui";x.fillText(`Legacy index ${picked.reduce((n,p)=>n+p.score,0)} · lastseason.co.uk/games/retro-fantasy`,65,590);const a=document.createElement("a");a.download="retro-fantasy-five.png";a.href=c.toDataURL("image/png");a.click()});document.getElementById("retro-clear")?.addEventListener("click",()=>{selected=[];save()});render();
  </script>
</Base>
<style>
.retro-page{padding-bottom:5rem}.retro-hero{padding:4rem 0;background:radial-gradient(circle at 80% 20%,rgba(117,230,163,.24),transparent 30%),#0b1620;color:#fff}.retro-hero span{color:#75e6a3;text-transform:uppercase;font-size:.7rem;font-weight:850;letter-spacing:.13em}.retro-hero h1{color:#fff;margin:.3rem 0;font-size:clamp(3rem,8vw,7rem);letter-spacing:-.08em;line-height:.9}.retro-hero p{max-width:680px;color:#aab9c2}.retro-score{display:grid;grid-template-columns:auto auto auto auto;align-items:end;gap:.3rem .8rem;margin-top:1.5rem;width:max-content}.retro-score strong{font-size:2rem;color:#75e6a3}.retro-score small{padding-bottom:.35rem;color:#aab9c2}.retro-board{display:grid;grid-template-columns:minmax(300px,.7fr) minmax(0,1.3fr);gap:1rem;margin-top:1rem}.retro-team{position:sticky;top:1rem;align-self:start;padding:1.2rem;border-radius:18px;background:#f1f6f2}.retro-slots{display:grid;gap:.45rem}.retro-slots>*{display:grid;grid-template-columns:40px 1fr auto;align-items:center;gap:.5rem;min-height:58px;padding:.6rem;border:0;border-radius:10px;background:#fff;text-align:left}.retro-slots span{font-weight:900;color:#347252}.retro-slots small{color:#63727b}.retro-actions,.retro-filters{display:flex;flex-wrap:wrap;gap:.4rem;margin-top:.8rem}.retro-actions button,.retro-filters button{border:1px solid #cdd8d1;border-radius:999px;background:#fff;padding:.5rem .7rem;font-weight:800;cursor:pointer}.retro-filters button[aria-pressed=true]{background:#0b1620;color:#75e6a3}.retro-pool{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.55rem;margin-top:.8rem}.retro-player{display:grid;min-height:130px;padding:.8rem;border:1px solid #dfe7e2;border-radius:13px;background:#fff;text-align:left;cursor:pointer}.retro-player[aria-pressed=true]{border-color:#245d3c;background:#e9f7ee}.retro-player span{color:#347252;font-size:.65rem;font-weight:900}.retro-player strong{font-size:1rem}.retro-player small{color:#65747d}.retro-player em{margin-top:auto;font-style:normal;font-size:.7rem;font-weight:800}@media(max-width:800px){.retro-board{grid-template-columns:1fr}.retro-team{position:static}}@media(max-width:520px){.retro-pool{grid-template-columns:1fr}.retro-score{grid-template-columns:auto auto}}
</style>
