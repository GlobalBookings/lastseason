---
import Base from "../../layouts/Base.astro";import FantasyHeader from "../../components/FantasyHeader.astro";import FantasyDisclaimer from "../../components/FantasyDisclaimer.astro";import { fantasyPlayers, averageFixtureDifficulty } from "../../data/fantasy";
const data=JSON.stringify(fantasyPlayers.map(p=>({...p,fixtureDifficulty:averageFixtureDifficulty(p.clubSlug)}))).replace(/</g,"\\u003c");
---
<Base title="Fantasy Football Transfer Planner 2026/27" description="Test transfers against your saved fantasy squad using planning value, reviewed evidence, opening fixtures and minutes confidence." canonical="/fantasy-football/transfer-planner/">
  <FantasyHeader active="plan"/><div class="fantasy-page"><div class="fantasy-tool-hero"><div class="fantasy-container"><nav class="fantasy-breadcrumbs"><a href="/fantasy-football/">Fantasy</a><span>/</span><span>Transfer planner</span></nav><span class="fantasy-eyebrow">Pressure-test one move</span><h1>Is the transfer actually an upgrade?</h1><p>Load your saved draft, choose a player out and compare same-position replacements. The planner measures evidence, opening run, minutes confidence and planning-value change.</p></div></div><section class="fantasy-section fantasy-section--tint"><div class="fantasy-container"><div class="fantasy-panel"><div class="fantasy-controls fantasy-controls--two"><label class="fantasy-field">Player out<select id="transfer-out"></select></label><label class="fantasy-field">Player in<select id="transfer-in"></select></label></div><div class="comparison-grid" id="transfer-comparison"></div><div class="fantasy-actions" style="margin-top:1rem"><button class="fantasy-button" id="save-transfer">Save planned move</button><a class="fantasy-button fantasy-button--dark" href="/fantasy-football/squad-builder/">Edit squad</a></div><p class="fantasy-status" id="transfer-status">A transfer is only useful if it improves the whole squad, not just one headline metric.</p></div><FantasyDisclaimer short/></div></section></div>
  <script is:inline type="application/json" id="transfer-data" set:html={data}></script><script is:inline>
    const P=JSON.parse(document.getElementById("transfer-data")?.textContent||"[]"),out=document.getElementById("transfer-out"),incoming=document.getElementById("transfer-in"),byId=id=>P.find(p=>p.id===id);let squad=[];try{squad=JSON.parse(localStorage.getItem("lastseason-fantasy-squad")||"null")?.ids||[]}catch{}const renderOut=()=>{out.innerHTML=squad.length?squad.map(id=>{const p=byId(id);return p?`<option value="${p.id}">${p.name} · ${p.position}</option>`:""}).join(""):`<option value="">Save a squad first</option>`};const renderIn=()=>{const current=byId(out.value);incoming.innerHTML=current?P.filter(p=>p.position===current.position&&!squad.includes(p.id)).sort((a,b)=>b.evidence-a.evidence).map(p=>`<option value="${p.id}">${p.name} · ${p.planningPrice.toFixed(1)} cr</option>`).join(""):"";renderCompare()};const card=(p,label)=>`<article class="comparison-card"><span class="fantasy-pill">${label}</span><h2>${p.name}</h2><p>${p.club}</p><div class="comparison-metric"><span>Planning value</span><strong>${p.planningPrice.toFixed(1)} cr</strong></div><div class="comparison-metric"><span>Evidence</span><strong>${p.evidence}/100</strong></div><div class="comparison-metric"><span>Opening difficulty</span><strong>${p.fixtureDifficulty.toFixed(1)}/5</strong></div><div class="comparison-metric"><span>Minutes</span><strong>${p.minutes}</strong></div></article>`;function renderCompare(){const a=byId(out.value),b=byId(incoming.value);if(!a||!b){document.getElementById("transfer-comparison").innerHTML="<p>Save a draft in the squad assistant before planning a move.</p>";return}document.getElementById("transfer-comparison").innerHTML=`${card(a,"OUT")}<div class="comparison-vs">→<br><small>${b.planningPrice-a.planningPrice>=0?"+":""}${(b.planningPrice-a.planningPrice).toFixed(1)} cr</small></div>${card(b,"IN")}`;document.getElementById("transfer-status").textContent=b.evidence>a.evidence&&b.fixtureDifficulty<=a.fixtureDifficulty?"The incoming player improves both reviewed evidence and the opening fixture score. Still verify minutes and official affordability.":"This move involves a trade-off. Check whether the evidence or fixture change solves a real squad problem."}out.addEventListener("change",renderIn);incoming.addEventListener("change",renderCompare);document.getElementById("save-transfer")?.addEventListener("click",()=>{const a=byId(out.value),b=byId(incoming.value);if(!a||!b)return;let plans=[];try{plans=JSON.parse(localStorage.getItem("lastseason-fantasy-transfers")||"[]")}catch{}plans=[{out:a.name,in:b.name,delta:b.planningPrice-a.planningPrice,createdAt:Date.now()},...plans].slice(0,5);localStorage.setItem("lastseason-fantasy-transfers",JSON.stringify(plans));document.getElementById("transfer-status").textContent=`Saved: ${a.name} → ${b.name}.`});renderOut();renderIn();
  </script>
</Base>
