---
import Base from "../../layouts/Base.astro";import FantasyHeader from "../../components/FantasyHeader.astro";import FantasyDisclaimer from "../../components/FantasyDisclaimer.astro";import { fantasyClubs, clubBySlug, fixtureDifficulty, fantasyPlayers, fantasySourceUrl, fantasyUpdated } from "../../data/fantasy";
const fixtures=fantasyClubs.flatMap(club=>club.fixtures.filter(f=>f.gw===1&&f.venue==="H").map(f=>({home:club,away:clubBySlug.get(f.opponent)!}))).sort((a,b)=>a.home.name.localeCompare(b.home.name));
const watch=[...fantasyPlayers].sort((a,b)=>{const af=clubBySlug.get(a.clubSlug)!.fixtures[0],bf=clubBySlug.get(b.clubSlug)!.fixtures[0];return (b.evidence+(6-fixtureDifficulty(bf.opponent,bf.venue))*5)-(a.evidence+(6-fixtureDifficulty(af.opponent,af.venue))*5)}).slice(0,8);
const schema=JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Fantasy football Gameweek 1 planning guide 2026/27","dateModified":"2026-07-21","author":{"@type":"Organization","name":"Last Season"},"mainEntityOfPage":"https://lastseason.co.uk/fantasy-football/gameweek-1/"});
---
<Base title="Fantasy Football Gameweek 1 Guide 2026/27" description="Prepare for fantasy football Gameweek 1 in 2026/27 with the opening fixtures, an evidence watchlist and a checklist separating confirmed information from pre-season uncertainty." canonical="/fantasy-football/gameweek-1/" schema={schema}>
  <FantasyHeader/><div class="fantasy-page"><div class="fantasy-tool-hero"><div class="fantasy-container"><nav class="fantasy-breadcrumbs"><a href="/fantasy-football/">Fantasy</a><span>/</span><span>Gameweek 1</span></nav><span class="fantasy-eyebrow">Updated {fantasyUpdated}</span><h1>Gameweek 1, without the noise.</h1><p>The confirmed opening fixtures, a reviewed evidence shortlist and the questions that still need answering before you lock anything in.</p></div></div>
  <section class="fantasy-section fantasy-section--tint"><div class="fantasy-container"><div class="fantasy-section__head"><div><span class="fantasy-eyebrow">Opening card</span><h2>The 10 fixtures</h2></div><a href={fantasySourceUrl} target="_blank" rel="noopener noreferrer">Published schedule ↗</a></div><div class="rotation-grid">{fixtures.map(({home,away})=><article class="rotation-card"><strong>{home.name} v {away.name}</strong><span>{home.short} home · {away.short} away</span></article>)}</div></div></section>
  <section class="fantasy-section"><div class="fantasy-container"><div class="fantasy-section__head"><div><span class="fantasy-eyebrow">Evidence shortlist</span><h2>Start the conversation here</h2></div><p>This ranking is a discussion aid, not a prediction.</p></div><div class="ranking-list">{watch.map((p,i)=><article class="ranking-card"><b>{i+1}</b><div><strong>{p.name}</strong><span>{p.club} · {p.position}<br/>{p.note}</span></div><div class="ranking-score"><strong>{p.evidence}</strong><small>evidence</small></div></article>)}</div></div></section>
  <section class="fantasy-section fantasy-section--tint"><div class="fantasy-container"><div class="fantasy-card-grid"><article class="fantasy-card"><span>Known</span><strong>Fixtures and last-season evidence</strong><p>The opening schedule is published and the 2025/26 evidence cited in our methodology is fixed.</p></article><article class="fantasy-card"><span>Unknown</span><strong>Official prices, roles and deadline</strong><p>Do not mistake our planning credits or kick-off countdown for official game information.</p></article><article class="fantasy-card"><span>Do next</span><strong>Watch the final friendlies</strong><p>Prioritise starting roles, set pieces, fitness and late returns over pre-season scorelines.</p></article></div><FantasyDisclaimer/></div></section></div>
</Base>
