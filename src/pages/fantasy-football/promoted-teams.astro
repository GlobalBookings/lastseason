---
import Base from "../../layouts/Base.astro";
import FantasyHeader from "../../components/FantasyHeader.astro";
import FantasyDisclaimer from "../../components/FantasyDisclaimer.astro";
import { averageFixtureDifficulty, clubBySlug, fantasyPlayers, fantasyUpdated } from "../../data/fantasy";
const promotedSlugs=["coventry-city","hull-city","ipswich-town"];
const promoted=promotedSlugs.map((slug)=>({club:clubBySlug.get(slug)!,players:fantasyPlayers.filter((player)=>player.clubSlug===slug),difficulty:averageFixtureDifficulty(slug)}));
---
<Base title="Promoted Teams Fantasy Football Guide 2026/27" description="A 2026/27 fantasy guide to Coventry City, Hull City and Ipswich Town: opening fixtures, reviewed player watchlists and promoted-team risks." canonical="/fantasy-football/promoted-teams/" ogType="article">
  <FantasyHeader />
  <div class="fantasy-page"><div class="fantasy-tool-hero"><div class="fantasy-container"><nav class="fantasy-breadcrumbs"><a href="/fantasy-football/">Fantasy</a><span>/</span><span>Promoted teams</span></nav><span class="fantasy-eyebrow">Reviewed {fantasyUpdated}</span><h1>The promoted-team watch.</h1><p>Coventry City, Hull City and Ipswich Town enter a different level of opposition. Look for price, minutes and role—not last season's raw totals alone.</p></div></div>
  {promoted.map(({club,players,difficulty},index)=><section class:list={["fantasy-section",index%2===0&&"fantasy-section--tint"]}><div class="fantasy-container"><div class="fantasy-section__head"><div><span class="fantasy-eyebrow">Opening-six difficulty {difficulty.toFixed(1)} / 5</span><h2>{club.name}</h2></div><a href={`/fantasy-football/club-guides/${club.slug}/`}>Full club guide →</a></div><div class="fixture-run">{club.fixtures.map((fixture)=><article><span>GW{fixture.gw}</span><strong>{clubBySlug.get(fixture.opponent)?.short} ({fixture.venue})</strong></article>)}</div>{players.length?<div class="ranking-list" style="margin-top:1rem">{players.map((player,rank)=><article class="ranking-card"><b>{rank+1}</b><div><strong>{player.name}</strong><span>{player.position} · {player.note}</span></div><div class="ranking-score"><strong>{player.evidence}</strong><small>evidence</small></div></article>)}</div>:<p class="fantasy-status" style="margin-top:1rem">No player has yet cleared the selective planning pool. That can change quickly when official prices and pre-season roles arrive.</p>}</div></section>)}
  <section class="fantasy-section"><div class="fantasy-container"><div class="fantasy-card-grid"><article class="fantasy-card"><span>Upside</span><strong>Secure starters can be underpriced</strong><p>Promoted clubs often offer cheap players with reliable minutes and clear responsibility.</p></article><article class="fantasy-card"><span>Risk</span><strong>Old totals need context</strong><p>Chance quality, possession and defensive strength can change sharply against top-flight opponents.</p></article><article class="fantasy-card"><span>Method</span><strong>Start with role, then fixtures</strong><p>Penalties, set pieces and attacking position can outweigh the badge when the price is right.</p></article></div><FantasyDisclaimer /></div></section></div>
</Base>
