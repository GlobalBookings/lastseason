---
import Base from "../../layouts/Base.astro";import FantasyHeader from "../../components/FantasyHeader.astro";import FantasyDisclaimer from "../../components/FantasyDisclaimer.astro";
const schema=JSON.stringify({"@context":"https://schema.org","@type":"WebApplication","name":"Fantasy Mini-League Report Generator","url":"https://lastseason.co.uk/fantasy-football/mini-league-report/","applicationCategory":"SportsApplication","isAccessibleForFree":true});
---
<Base title="Fantasy Mini-League Report Generator" description="Turn a pasted fantasy mini-league table into a ranked, funny, shareable weekly report with awards for the group chat." canonical="/fantasy-football/mini-league-report/" schema={schema}>
  <FantasyHeader/><div class="fantasy-page"><div class="fantasy-tool-hero"><div class="fantasy-container"><nav class="fantasy-breadcrumbs"><a href="/fantasy-football/">Fantasy</a><span>/</span><span>Mini-league report</span></nav><span class="fantasy-eyebrow">No login · no official account access</span><h1>Make the group-chat report.</h1><p>Paste names and weekly scores, one manager per line. We rank the table, hand out harmless awards and make a share card—without connecting to the official game.</p></div></div><section class="fantasy-section fantasy-section--tint"><div class="fantasy-container newsletter-layout"><form class="fantasy-panel" id="league-form"><span class="fantasy-eyebrow">Paste scores</span><h2>Manager, score</h2><label class="fantasy-field">Gameweek<input id="report-week" type="number" min="1" max="38" value="1"/></label><label class="fantasy-field">League name<input id="report-name" value="The Office League" maxlength="40"/></label><label class="fantasy-field">Standings<textarea id="report-input" rows="10" placeholder="Jack, 72&#10;Sarah, 68&#10;Mo, 54">Jack, 72
Sarah, 68
Mo, 54
Alex, 47</textarea></label><button class="fantasy-button" type="submit">Generate report</button><p class="fantasy-status" id="report-status">Use a comma or tab between each name and score.</p></form><div class="fantasy-panel" id="league-output"><span class="fantasy-eyebrow">Preview</span><h2>Your report will appear here</h2><p>Add at least two managers, then generate.</p></div></div><div class="fantasy-actions" id="report-actions" style="margin-top:1rem" hidden><button class="fantasy-button" id="share-report">Share report</button><button class="fantasy-button fantasy-button--dark" id="download-report">Download card</button></div><FantasyDisclaimer/></div></section></div>
  <script is:inline>
    let latest=null;const esc=s=>String(s).replace(/[&<>"']/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));function parse(){return document.getElementById("report-input").value.split(/\n/).map(line=>{const parts=line.split(/[,\t;]/),score=Number(parts.pop()?.trim());return{name:parts.join(" ").trim().slice(0,30),score}}).filter(x=>x.name&&Number.isFinite(x.score)&&x.score>=0).sort((a,b)=>b.score-a.score)}
    function generate(e){e?.preventDefault();const rows=parse();if(rows.length<2){document.getElementById("report-status").textContent="Add at least two valid manager-score rows.";document.getElementById("report-status").dataset.tone="warning";return}const name=document.getElementById("report-name").value.trim()||"Mini League",week=Number(document.getElementById("report-week").value)||1,best=rows[0],last=rows.at(-1),average=Math.round(rows.reduce((n,r)=>n+r.score,0)/rows.length),closest=[...rows].sort((a,b)=>Math.abs(a.score-average)-Math.abs(b.score-average))[0];latest={rows,name,week,best,last,average,closest};document.getElementById("league-output").innerHTML=`<span class="fantasy-eyebrow">GW${week} · ${esc(name)}</span><h2>${esc(best.name)} sets the pace</h2><div class="ranking-list">${rows.map((r,i)=>`<article class="ranking-card"><b>${i+1}</b><div><strong>${esc(r.name)}</strong><span>${i===0?"Manager of the week":i===rows.length-1?"Needs a team talk":"Still in the hunt"}</span></div><div class="ranking-score"><strong>${r.score}</strong><small>points</small></div></article>`).join("")}</div><div class="fantasy-card-grid" style="margin-top:1rem"><article class="fantasy-card"><span>Top scorer</span><strong>${esc(best.name)}</strong><p>${best.score} points. Screenshots are allowed.</p></article><article class="fantasy-card"><span>League average</span><strong>${average}</strong><p>${esc(closest.name)} landed closest to par.</p></article><article class="fantasy-card"><span>Wooden spoon</span><strong>${esc(last.name)}</strong><p>${last.score} points. The comeback starts next week.</p></article></div>`;document.getElementById("report-actions").hidden=false;document.getElementById("report-status").textContent=`Report generated for ${rows.length} managers.`;localStorage.setItem("lastseason-mini-league-report",JSON.stringify({name,week,input:document.getElementById("report-input").value}));window.lsTrack?.("fantasy_mini_league_report",{managers:rows.length,week})}
    document.getElementById("league-form")?.addEventListener("submit",generate);document.getElementById("share-report")?.addEventListener("click",async()=>{if(!latest)return;const text=`${latest.name} · GW${latest.week}\n🏆 ${latest.best.name}: ${latest.best.score}\n📊 Average: ${latest.average}\n🥄 ${latest.last.name}: ${latest.last.score}`;try{if(navigator.share)await navigator.share({title:`${latest.name} GW${latest.week} report`,text,url:location.href});else await navigator.clipboard.writeText(`${text}\n${location.href}`);document.getElementById("report-status").textContent="Report shared or copied."}catch(e){if(e.name!=="AbortError")document.getElementById("report-status").textContent="Could not share this time."}});
    document.getElementById("download-report")?.addEventListener("click",()=>{if(!latest)return;const c=document.createElement("canvas"),x=c.getContext("2d");c.width=1200;c.height=630;const g=x.createLinearGradient(0,0,1200,630);g.addColorStop(0,"#09141d");g.addColorStop(1,"#24513f");x.fillStyle=g;x.fillRect(0,0,1200,630);x.fillStyle="#b7ff5a";x.font="800 25px system-ui";x.fillText(`LAST SEASON · GW${latest.week}`,65,70);x.fillStyle="#fff";x.font="900 60px system-ui";x.fillText(latest.name.slice(0,28),65,145);latest.rows.slice(0,6).forEach((r,i)=>{x.fillStyle=i===0?"#b7ff5a":"#fff";x.font="800 31px system-ui";x.fillText(`${i+1}. ${r.name}`.slice(0,32),75,225+i*57);x.textAlign="right";x.fillText(String(r.score),1115,225+i*57);x.textAlign="left"});x.fillStyle="#9fb1bb";x.font="600 21px system-ui";x.fillText("Made at lastseason.co.uk/fantasy-football/mini-league-report",65,590);const a=document.createElement("a");a.download=`${latest.name.toLowerCase().replace(/[^a-z0-9]+/g,"-")}-gw${latest.week}.png`;a.href=c.toDataURL("image/png");a.click()});try{const s=JSON.parse(localStorage.getItem("lastseason-mini-league-report")||"null");if(s){document.getElementById("report-name").value=s.name;document.getElementById("report-week").value=s.week;document.getElementById("report-input").value=s.input}}catch{}
  </script>
</Base>
