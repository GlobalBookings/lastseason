---
import Base from "../../layouts/Base.astro";import FantasyHeader from "../../components/FantasyHeader.astro";import FantasyDisclaimer from "../../components/FantasyDisclaimer.astro";import { fantasyPlayers, averageFixtureDifficulty } from "../../data/fantasy";
const data=JSON.stringify(fantasyPlayers.map(p=>({...p,fixtureDifficulty:averageFixtureDifficulty(p.clubSlug)}))).replace(/</g,"\\u003c");
---
<Base title="Fantasy Football Player Comparison Tool 2026/27" description="Compare two 2026/27 fantasy football watchlist players by planning value, reviewed evidence, opening fixtures, position and minutes confidence." canonical="/fantasy-football/player-compare/">
  <FantasyHeader/><div class="fantasy-page"><div class="fantasy-tool-hero"><div class="fantasy-container"><nav class="fantasy-breadcrumbs"><a href="/fantasy-football/">Fantasy</a><span>/</span><span>Player comparison</span></nav><span class="fantasy-eyebrow">Side by side</span><h1>Compare the trade-offs.</h1><p>Price, evidence, fixtures and minutes risk in one view. The winner depends on what your squad needs.</p></div></div><section class="fantasy-section fantasy-section--tint"><div class="fantasy-container"><div class="fantasy-panel"><div class="fantasy-controls fantasy-controls--two"><label class="fantasy-field">Player one<select id="compare-one"></select></label><label class="fantasy-field">Player two<select id="compare-two"></select></label></div><div class="comparison-grid" id="comparison-output"></div></div><FantasyDisclaimer short/></div></section></div>
  <script is:inline type="application/json" id="compare-data" set:html={data}></script><script is:inline>const P=JSON.parse(document.getElementById("compare-data")?.textContent||"[]"),one=document.getElementById("compare-one"),two=document.getElementById("compare-two");const opts=P.map(p=>`<option value="${p.id}">${p.name} · ${p.position}</option>`).join("");one.innerHTML=opts;two.innerHTML=opts;two.selectedIndex=1;const card=p=>`<article class="comparison-card"><span class="fantasy-pill">${p.position}</span><h2>${p.name}</h2><p>${p.club}</p><div class="comparison-metric"><span>Planning value</span><strong>${p.planningPrice.toFixed(1)} credits</strong></div><div class="comparison-metric"><span>Evidence score</span><strong>${p.evidence}/100</strong></div><div class="comparison-metric"><span>Opening difficulty</span><strong>${p.fixtureDifficulty.toFixed(1)}/5</strong></div><div class="comparison-metric"><span>Minutes confidence</span><strong>${p.minutes}</strong></div><p>${p.note}</p></article>`;const render=()=>{const a=P.find(p=>p.id===one.value),b=P.find(p=>p.id===two.value);document.getElementById("comparison-output").innerHTML=`${card(a)}<div class="comparison-vs">VS</div>${card(b)}`};one.addEventListener("change",render);two.addEventListener("change",render);render();</script>
</Base>
