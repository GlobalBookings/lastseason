---
import Base from "../../../layouts/Base.astro";
import FantasyHeader from "../../../components/FantasyHeader.astro";
import FantasyDisclaimer from "../../../components/FantasyDisclaimer.astro";
import { generalTeamNames, clubNameCollections, fantasyNameStyles, fantasyPlayerNameCollections } from "../../../data/fantasy";
const schema = JSON.stringify({
  "@context":"https://schema.org",
  "@type":"CollectionPage",
  "name":"Fantasy football team names 2026/27",
  "url":"https://lastseason.co.uk/fantasy-football/team-names/",
  "mainEntity":{"@type":"ItemList","numberOfItems":clubNameCollections.length,"itemListElement":clubNameCollections.map((club,index)=>({
    "@type":"ListItem","position":index+1,"name":`${club.name} fantasy football team names`,"url":`https://lastseason.co.uk/fantasy-football/team-names/${club.slug}/`
  }))}
});
---
<Base title="Funny Fantasy Football Team Names 2026/27" description="Hundreds of funny fantasy football team names for 2026/27: all 20 Premier League clubs, current-player puns, retro classics, clever and clean ideas." canonical="/fantasy-football/team-names/" schema={schema}>
  <FantasyHeader active="names" /><div class="fantasy-page"><div class="fantasy-tool-hero"><div class="fantasy-container"><nav class="fantasy-breadcrumbs"><a href="/fantasy-football/">Fantasy</a><span>/</span><span>Team names</span></nav><span class="fantasy-eyebrow">Curated, not scraped</span><h1>Funny fantasy football team names.</h1><p>Current players, archive favourites and clean names that still work in a work league. Every suggestion is checked by a human.</p><a class="fantasy-button" href="/fantasy-football/team-name-generator/">Personalise a name</a></div></div>
  <section class="fantasy-section"><div class="fantasy-container"><div class="fantasy-section__head"><div><span class="fantasy-eyebrow">The shortlist</span><h2>32 names ready to use</h2></div><a href="/fantasy-football/team-name-generator/">Personalise one →</a></div><div class="name-list">{generalTeamNames.map(([name,style])=><div class="name-row"><div><strong>{name}</strong><span class="fantasy-pill" style="margin-left:.5rem">{style}</span></div><div class="name-row__actions"><button type="button" data-save-name={name}>Save</button><button type="button" data-copy-name={name}>Copy</button></div></div>)}</div></div></section>
  <section class="fantasy-section fantasy-section--tint"><div class="fantasy-container"><div class="fantasy-section__head"><div><span class="fantasy-eyebrow">Pick your club</span><h2>All 20 Premier League clubs</h2></div><p>Current players, club culture and archive favourites—reviewed for the 2026/27 pre-season.</p></div><div class="fantasy-card-grid fantasy-card-grid--four">{clubNameCollections.map(collection=><a class="fantasy-card" href={`/fantasy-football/team-names/${collection.slug}/`}><span>{collection.names.length} ideas</span><strong>{collection.name}</strong><p>{collection.intro}</p><small>See the names →</small></a>)}</div></div></section>
  <section class="fantasy-section"><div class="fantasy-container"><div class="fantasy-section__head"><div><span class="fantasy-eyebrow">Browse by mood</span><h2>Find the right kind of name</h2></div></div><div class="fantasy-card-grid">{fantasyNameStyles.map(style=><a class="fantasy-card" href={`/fantasy-football/team-names/styles/${style.slug}/`}><span>{style.names.length} reviewed ideas</span><strong>{style.name} names</strong><p>{style.description}</p><small>Browse {style.name.toLowerCase()} names →</small></a>)}</div></div></section>
  <section class="fantasy-section fantasy-section--tint"><div class="fantasy-container"><div class="fantasy-section__head"><div><span class="fantasy-eyebrow">Player inspired</span><h2>Names built around the headline picks</h2></div></div><div class="fantasy-card-grid fantasy-card-grid--four">{fantasyPlayerNameCollections.map(item=><a class="fantasy-card" href={`/fantasy-football/team-names/players/${item.slug}/`}><span>{item.club}</span><strong>{item.player}</strong><p>{item.names.slice(0,3).join(" · ")}</p><small>See all {item.names.length} →</small></a>)}</div><FantasyDisclaimer short /></div></section></div>
  <script is:inline>
    const savedKey="lastseason-fantasy-saved-names";
    const saveName=(name)=>{let names=[];try{names=JSON.parse(localStorage.getItem(savedKey)||"[]")}catch{}names=[name,...names.filter(item=>item!==name)].slice(0,20);localStorage.setItem(savedKey,JSON.stringify(names));window.lsTrack?.("fantasy_name_save",{name,source:"team_names_hub"});};
    document.querySelectorAll("[data-copy-name]").forEach(button=>button.addEventListener("click",async()=>{await navigator.clipboard?.writeText(button.dataset.copyName||"");const old=button.textContent;button.textContent="Copied";window.lsTrack?.("fantasy_name_copy",{name:button.dataset.copyName,source:"team_names_hub"});setTimeout(()=>button.textContent=old,1200);}));
    document.querySelectorAll("[data-save-name]").forEach(button=>button.addEventListener("click",()=>{saveName(button.dataset.saveName||"");const old=button.textContent;button.textContent="Saved";setTimeout(()=>button.textContent=old,1200);}));
  </script>
</Base>
