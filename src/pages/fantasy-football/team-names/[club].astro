---
import Base from "../../../layouts/Base.astro";
import FantasyHeader from "../../../components/FantasyHeader.astro";
import FantasyDisclaimer from "../../../components/FantasyDisclaimer.astro";
import { clubNameCollections } from "../../../data/fantasy";
export function getStaticPaths(){return clubNameCollections.map(collection=>({params:{club:collection.slug},props:{collection}}));}
const { collection } = Astro.props;
const schema=JSON.stringify({"@context":"https://schema.org","@graph":[
  {"@type":"CollectionPage","name":`${collection.name} fantasy football team names 2026/27`,"url":`https://lastseason.co.uk/fantasy-football/team-names/${collection.slug}/`,"description":collection.intro},
  {"@type":"ItemList","name":`${collection.name} fantasy football team names`,"numberOfItems":collection.names.length,"itemListElement":collection.names.map((name:string,index:number)=>({"@type":"ListItem","position":index+1,"name":name}))}
]});
---
<Base title={`${collection.name} Fantasy Football Team Names 2026/27`} description={`${collection.names.length} funny, clean and current ${collection.name} fantasy football team names for 2026/27, grouped by squad, club culture and retro favourites.`} canonical={`/fantasy-football/team-names/${collection.slug}/`} schema={schema}>
  <FantasyHeader active="names" /><div class="fantasy-page"><div class="fantasy-tool-hero"><div class="fantasy-container"><nav class="fantasy-breadcrumbs"><a href="/fantasy-football/">Fantasy</a><span>/</span><a href="/fantasy-football/team-names/">Team names</a><span>/</span><span>{collection.name}</span></nav><span class="fantasy-eyebrow">Club name lab</span><h1>{collection.name} fantasy team names.</h1><p>{collection.intro} Updated for the 2026/27 pre-season.</p><a class="fantasy-button" href={`/fantasy-football/team-name-generator/?club=${collection.slug}`}>Generate another</a></div></div>
  <section class="fantasy-section"><div class="fantasy-container"><div class="fantasy-callout"><strong>Found the one?</strong><span>Save a shortlist, copy it into your game or share it with the group chat.</span><span id="saved-count">0 saved</span></div>{collection.groups.map((group:any,groupIndex:number)=><section class="name-group"><div class="fantasy-section__head"><div><span class="fantasy-eyebrow">Collection {groupIndex+1}</span><h2>{group.label}</h2></div><p>{groupIndex===0?"Names connected to the current squad and recent team context.":groupIndex===1?"Terrace, stadium and local references other supporters will recognise.":"Archive players and evergreen clean names worth bringing back."}</p></div><div class="name-list">{group.names.map((name:string,index:number)=><div class="name-row" data-name-row={name}><div><span class="fantasy-pill">{String(groupIndex*group.names.length+index+1).padStart(2,"0")}</span> <strong>{name}</strong></div><div class="name-row__actions"><button type="button" data-vote-name={name} aria-label={`Vote for ${name}`}>♡ <span data-vote-count>0</span></button><button type="button" data-save-name={name}>Save</button><button type="button" data-share-name={name}>Share</button><button type="button" data-copy-name={name}>Copy</button></div></div>)}</div></section>)}<div class="fantasy-next-step"><div><span class="fantasy-eyebrow">Name sorted</span><h2>Now make the first draft count.</h2><p>Use the independent squad assistant, then check {collection.name}'s opening fixtures and planning watchlist.</p></div><div class="fantasy-actions"><a class="fantasy-button" href="/fantasy-football/squad-builder/">Build my squad</a><a class="fantasy-button fantasy-button--dark" href={`/fantasy-football/club-guides/${collection.slug}/`}>Open {collection.name} guide</a></div></div><FantasyDisclaimer short /><p class="fantasy-status">Names change as squads and transfers change. If a player leaves, the archive section keeps the pun alive—but the generator prioritises current references.</p></div></section></div>
  <script is:inline>
    const clubSlug=document.body.dataset.pagePath?.split("/").filter(Boolean).at(-1)||"club",savedKey="lastseason-fantasy-saved-names";
    const readSaved=()=>{try{return JSON.parse(localStorage.getItem(savedKey)||"[]")}catch{return[]}};
    const syncSaved=()=>{const saved=readSaved();const counter=document.getElementById("saved-count");if(counter)counter.textContent=`${saved.length} saved`;document.querySelectorAll("[data-save-name]").forEach(button=>button.textContent=saved.includes(button.dataset.saveName)?"Saved":"Save")};
    const saveName=(name)=>{const saved=readSaved(),next=saved.includes(name)?saved.filter(item=>item!==name):[name,...saved].slice(0,20);localStorage.setItem(savedKey,JSON.stringify(next));syncSaved();window.lsTrack?.("fantasy_name_save",{name,club:clubSlug,saved:String(next.includes(name))})};
    document.querySelectorAll("[data-copy-name]").forEach(button=>button.addEventListener("click",async()=>{await navigator.clipboard?.writeText(button.dataset.copyName||"");const old=button.textContent;button.textContent="Copied";window.lsTrack?.("fantasy_name_copy",{name:button.dataset.copyName,club:clubSlug});setTimeout(()=>button.textContent=old,1200)}));
    document.querySelectorAll("[data-save-name]").forEach(button=>button.addEventListener("click",()=>saveName(button.dataset.saveName||"")));
    document.querySelectorAll("[data-share-name]").forEach(button=>button.addEventListener("click",async()=>{const name=button.dataset.shareName||"",url=location.href,text=`My ${clubSlug.replaceAll("-"," ")} fantasy team name: ${name}`;try{if(navigator.share)await navigator.share({title:name,text,url});else await navigator.clipboard?.writeText(`${text}\n${url}`);window.lsTrack?.("fantasy_name_share",{name,club:clubSlug})}catch(error){if(error?.name!=="AbortError")button.textContent="Try again"}}));
    let voterId=localStorage.getItem("lastseason-fantasy-voter-id");if(!voterId){voterId=crypto.randomUUID();localStorage.setItem("lastseason-fantasy-voter-id",voterId)}
    document.querySelectorAll("[data-vote-name]").forEach(button=>button.addEventListener("click",async()=>{if(button.dataset.voted==="true")return;button.dataset.voted="true";button.firstChild.textContent="♥ ";const name=button.dataset.voteName||"";try{const response=await fetch("/api/fantasy-name-vote",{method:"POST",headers:{"content-type":"application/json"},body:JSON.stringify({club:clubSlug,name,voterId})});const result=await response.json();if(result.votes!==undefined)button.querySelector("[data-vote-count]").textContent=String(result.votes);window.lsTrack?.("fantasy_name_vote",{name,club:clubSlug})}catch{button.title="Vote saved on this device"}}));
    fetch(`/api/fantasy-name-vote?club=${encodeURIComponent(clubSlug)}`).then(response=>response.json()).then(result=>{Object.entries(result.votes||{}).forEach(([name,count])=>{const row=[...document.querySelectorAll("[data-name-row]")].find(item=>item.dataset.nameRow===name);if(row)row.querySelector("[data-vote-count]").textContent=String(count)})}).catch(()=>{});
    syncSaved();
  </script>
</Base>
