---
import Base from "../../layouts/Base.astro";
import FantasyHeader from "../../components/FantasyHeader.astro";
import FantasyDisclaimer from "../../components/FantasyDisclaimer.astro";
import { fantasyNameStyles, leagueNameIdeas } from "../../data/fantasy";
const miniLeagueNames = fantasyNameStyles.find((style)=>style.slug==="mini-league")?.names || [];
const payload=JSON.stringify([...new Set([...leagueNameIdeas,...miniLeagueNames])]).replace(/</g,"\\u003c");
const schema=JSON.stringify({"@context":"https://schema.org","@type":"WebApplication","name":"Fantasy football league-name generator","url":"https://lastseason.co.uk/fantasy-football/league-name-generator/","applicationCategory":"EntertainmentApplication","operatingSystem":"Any","offers":{"@type":"Offer","price":"0","priceCurrency":"GBP"}});
---
<Base title="Fantasy Football League Name Generator 2026/27" description="Generate funny, clean and group-chat-ready fantasy football league names for 2026/27. Free, instant and separate from individual team names." canonical="/fantasy-football/league-name-generator/" schema={schema}>
  <FantasyHeader active="names" />
  <div class="fantasy-page"><div class="fantasy-tool-hero"><div class="fantasy-container"><nav class="fantasy-breadcrumbs"><a href="/fantasy-football/">Fantasy</a><span>/</span><span>League-name generator</span></nav><span class="fantasy-eyebrow">Name the whole competition</span><h1>A mini-league name people remember.</h1><p>This is for the league itself—not one manager's team. Choose the tone, generate a shortlist and share it with the group.</p></div></div>
  <section class="fantasy-section"><div class="fantasy-container name-stage"><div class="name-output"><div><small>Your league name</small><strong id="league-name-output">The Expected Goals Society</strong><p id="league-name-status">Clean · group-chat ready</p><div class="fantasy-actions" style="justify-content:center"><button class="fantasy-button" id="generate-league-name">Another name</button><button class="fantasy-button fantasy-button--secondary" id="save-league-name">Save</button><button class="fantasy-button fantasy-button--ghost" id="share-league-name">Share</button></div></div></div><aside class="fantasy-panel"><span class="fantasy-eyebrow">Tone</span><div class="name-filters">{["Any","Work league","Friends","Serious-ish","Chaotic"].map((tone,index)=><button class="name-filter" type="button" data-league-tone={tone} aria-pressed={index===0?"true":"false"}>{tone}</button>)}</div><p class="fantasy-status">The tone guides the label and future shortlist. Every current result remains safe for a general football audience.</p><a href="/fantasy-football/mini-league-kit/">Need a prize and punishment too? →</a></aside></div></section>
  <section class="fantasy-section fantasy-section--tint"><div class="fantasy-container"><div class="fantasy-section__head"><div><span class="fantasy-eyebrow">Saved locally</span><h2>Your league shortlist</h2></div></div><div class="name-list" id="league-name-shortlist"><p class="fantasy-status">Save a result to start the shortlist.</p></div><FantasyDisclaimer short /></div></section></div>
  <script is:inline type="application/json" id="league-name-data" set:html={payload}></script>
  <script is:inline>
    const names=JSON.parse(document.getElementById("league-name-data")?.textContent||"[]"),output=document.getElementById("league-name-output"),status=document.getElementById("league-name-status"),shortlist=document.getElementById("league-name-shortlist"),key="lastseason-fantasy-league-names";let tone="Any";
    const read=()=>{try{return JSON.parse(localStorage.getItem(key)||"[]")}catch{return[]}};const render=()=>{const saved=read();shortlist.innerHTML=saved.length?saved.map(name=>`<div class="name-row"><strong>${name.replace(/</g,"&lt;")}</strong><button type="button" data-copy-league="${name.replace(/"/g,"&quot;")}">Copy</button></div>`).join(""):'<p class="fantasy-status">Save a result to start the shortlist.</p>';shortlist.querySelectorAll("[data-copy-league]").forEach(button=>button.addEventListener("click",()=>navigator.clipboard?.writeText(button.dataset.copyLeague||"")))};
    const generate=()=>{output.textContent=names[Math.floor(Math.random()*names.length)]||"The Expected Goals Society";status.textContent=`${tone} · group-chat ready`;window.lsTrack?.("fantasy_league_name_generate",{tone})};
    document.getElementById("generate-league-name")?.addEventListener("click",generate);document.getElementById("save-league-name")?.addEventListener("click",()=>{const saved=[output.textContent,...read().filter(name=>name!==output.textContent)].slice(0,12);localStorage.setItem(key,JSON.stringify(saved));status.textContent="Saved to this browser";render();window.lsTrack?.("fantasy_league_name_save",{tone})});document.getElementById("share-league-name")?.addEventListener("click",async()=>{const name=output.textContent||"My fantasy league";try{if(navigator.share)await navigator.share({title:name,text:`Our fantasy football league: ${name}`,url:location.href});else await navigator.clipboard?.writeText(`${name}\n${location.href}`);window.lsTrack?.("fantasy_league_name_share",{tone})}catch{}});
    document.querySelectorAll("[data-league-tone]").forEach(button=>button.addEventListener("click",()=>{tone=button.dataset.leagueTone;document.querySelectorAll("[data-league-tone]").forEach(item=>item.setAttribute("aria-pressed",String(item===button)));generate()}));render();
  </script>
</Base>
