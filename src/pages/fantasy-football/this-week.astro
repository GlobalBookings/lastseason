---
import Base from "../../layouts/Base.astro";
import FantasyHeader from "../../components/FantasyHeader.astro";
import FantasyDisclaimer from "../../components/FantasyDisclaimer.astro";
import { fantasyUpdated } from "../../data/fantasy";
---
<Base title="Fantasy Football This Week: 2026/27 Pre-Season Briefing" description="Your independent fantasy football return hub: what changed, what to check next, saved-name and plan status, plus the latest 2026/27 guides." canonical="/fantasy-football/this-week/">
  <FantasyHeader />
  <div class="fantasy-page"><div class="fantasy-hero fantasy-hero--compact"><div class="fantasy-container fantasy-hero__grid"><div class="fantasy-hero__copy"><span class="fantasy-eyebrow">Return desk · reviewed {fantasyUpdated}</span><h1>What matters this week.</h1><p>A calm route back into your plan: recent changes, saved work and the next decision worth making.</p></div><aside class="kickoff-card"><small>Your local plan</small><strong id="return-status">Checking…</strong><p id="return-detail">Saved only in this browser.</p></aside></div></div>
  <section class="fantasy-section fantasy-section--tint"><div class="fantasy-container"><div class="fantasy-section__head"><div><span class="fantasy-eyebrow">Since your last visit</span><h2 id="visit-heading">Welcome back</h2></div><p id="visit-copy">The latest review date is 23 July 2026.</p></div><div class="fantasy-card-grid"><a class="fantasy-card fantasy-card--feature" href="/fantasy-football/control-room/"><span>Confirmed deadline</span><strong>Open control room</strong><p>See the deadline clock, eight-chip rules, position changes and your saved plan status.</p><small>Open deadline HQ →</small></a><a class="fantasy-card" href="/fantasy-football/preseason-tracker/"><span>Role watch</span><strong>Pre-season tracker</strong><p>Track every current minutes warning and all official position changes.</p><small>Open tracker →</small></a><a class="fantasy-card" href="/fantasy-football/briefing/"><span>Latest issue</span><strong>Read the briefing</strong><p>The confirmed facts, what to do now and what still needs patience.</p><small>Read briefing →</small></a></div></div></section>
  <section class="fantasy-section"><div class="fantasy-container"><div class="fantasy-section__head"><div><span class="fantasy-eyebrow">Your next action</span><h2>Continue where you left off</h2></div></div><div class="plan-grid"><article class="plan-card"><span class="fantasy-eyebrow">Squad</span><h2 id="return-squad">No saved draft</h2><p>Balance evidence, fixtures, minutes and planning value.</p><a href="/fantasy-football/squad-doctor/">Run squad doctor →</a></article><article class="plan-card"><span class="fantasy-eyebrow">Names</span><h2 id="return-names">No saved names</h2><p>Keep a shortlist and share the best one with the group chat.</p><a href="/fantasy-football/team-names/">Browse team names →</a></article><article class="plan-card"><span class="fantasy-eyebrow">Players</span><h2 id="return-watchlist">No watchlist</h2><p>Recheck minutes, roles and transfer status before committing.</p><a href="/fantasy-football/preseason-tracker/">Open tracker →</a></article><article class="plan-card"><span class="fantasy-eyebrow">Checklist</span><h2 id="return-checklist">Nothing checked</h2><p>Run through prices, injuries, captain and final saved squad.</p><a href="/fantasy-football/my-plan/">Open my plan →</a></article></div><FantasyDisclaimer /></div></section></div>
  <script is:inline>
    const read=(key,fallback)=>{try{return JSON.parse(localStorage.getItem(key)||JSON.stringify(fallback))}catch{return fallback}};
    const squad=read("lastseason-fantasy-squad",null),names=read("lastseason-fantasy-saved-names",[]),watch=read("lastseason-fantasy-watchlist",[]),checks=read("lastseason-fantasy-checklist",[]);
    const parts=[squad?.ids?.length?`${squad.ids.length} players`:null,names.length?`${names.length} names`:null,watch.length?`${watch.length} watched`:null].filter(Boolean);
    document.getElementById("return-status").textContent=parts.length?"Plan found":"Fresh start";
    document.getElementById("return-detail").textContent=parts.length?parts.join(" · "):"Nothing saved yet in this browser.";
    document.getElementById("return-squad").textContent=squad?.ids?.length?`${squad.ids.length} players saved`:"No saved draft";
    document.getElementById("return-names").textContent=names.length?`${names.length} names saved`:"No saved names";
    document.getElementById("return-watchlist").textContent=watch.length?`${watch.length} players watched`:"No watchlist";
    document.getElementById("return-checklist").textContent=checks.filter(Boolean).length?`${checks.filter(Boolean).length} checks complete`:"Nothing checked";
    const visitKey="lastseason-fantasy-last-visit",previous=localStorage.getItem(visitKey),now=new Date();if(previous){const days=Math.max(0,Math.floor((Date.now()-new Date(previous).getTime())/86400000));document.getElementById("visit-heading").textContent=days?`${days} day${days===1?"":"s"} since your last visit`:"You visited earlier today";document.getElementById("visit-copy").textContent="Review the dated update log before changing a saved plan."}localStorage.setItem(visitKey,now.toISOString());window.lsTrack?.("fantasy_return_hub_view",{has_plan:String(Boolean(parts.length))});
  </script>
</Base>
