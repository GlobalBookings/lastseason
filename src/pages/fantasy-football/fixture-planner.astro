---
import Base from "../../layouts/Base.astro";
import FantasyHeader from "../../components/FantasyHeader.astro";
import FantasyDisclaimer from "../../components/FantasyDisclaimer.astro";
import { fantasyClubs, fixtureDifficulty, clubBySlug, fantasySourceUrl } from "../../data/fantasy";
const data=JSON.stringify(fantasyClubs.map(club=>({...club,fixtures:club.fixtures.map(f=>({...f,opponentName:clubBySlug.get(f.opponent)?.short,difficulty:fixtureDifficulty(f.opponent,f.venue)}))}))).replace(/</g,"\\u003c");
---
<Base title="Fantasy Football Fixture Planner 2026/27" description="Compare every Premier League club's first six 2026/27 fixtures with independent difficulty ratings and discover useful rotation pairs." canonical="/fantasy-football/fixture-planner/">
  <FantasyHeader active="fixtures"/><div class="fantasy-page"><div class="fantasy-tool-hero"><div class="fantasy-container"><nav class="fantasy-breadcrumbs"><a href="/fantasy-football/">Fantasy</a><span>/</span><span>Fixture planner</span></nav><span class="fantasy-eyebrow">Gameweeks 1–6</span><h1>See the run, not just the next match.</h1><p>Filter the opening schedule, rank each run and pair clubs whose easier fixtures alternate. Difficulty is our own transparent model based on last season's finishing strength and venue.</p></div></div>
  <section class="fantasy-section fantasy-section--tint"><div class="fantasy-container"><div class="fantasy-panel"><div class="fantasy-controls fantasy-controls--two"><label class="fantasy-field">Start gameweek<select id="fixture-from">{[1,2,3,4,5,6].map(n=><option value={n}>GW{n}</option>)}</select></label><label class="fantasy-field">End gameweek<select id="fixture-to">{[1,2,3,4,5,6].map(n=><option value={n} selected={n===6}>GW{n}</option>)}</select></label></div><div class="fixture-scroll"><table class="fixture-table"><thead id="fixture-head"></thead><tbody id="fixture-body"></tbody></table></div></div></div></section>
  <section class="fantasy-section"><div class="fantasy-container"><div class="fantasy-section__head"><div><span class="fantasy-eyebrow">Rotation lab</span><h2>Useful pairings</h2></div><p>Lower combined difficulty is better. This is most useful for rotating budget defenders or goalkeepers.</p></div><div class="rotation-grid" id="rotation-grid"></div><FantasyDisclaimer/><p class="fantasy-meta">Fixture list checked against the <a href={fantasySourceUrl} target="_blank" rel="noopener noreferrer">published 2026/27 schedule ↗</a>. Match dates and kick-off times can move.</p></div></section></div>
  <script is:inline type="application/json" id="fixture-data" set:html={data}></script><script is:inline>
    const CLUBS=JSON.parse(document.getElementById("fixture-data")?.textContent||"[]"),from=document.getElementById("fixture-from"),to=document.getElementById("fixture-to");
    const range=()=>{let a=Number(from.value),b=Number(to.value);if(a>b)[a,b]=[b,a];return[a,b];};const avg=(club,a,b)=>club.fixtures.filter(f=>f.gw>=a&&f.gw<=b).reduce((s,f)=>s+f.difficulty,0)/(b-a+1);
    const render=()=>{const[a,b]=range(),weeks=Array.from({length:b-a+1},(_,i)=>i+a);document.getElementById("fixture-head").innerHTML=`<tr><th>Club</th>${weeks.map(gw=>`<th>GW${gw}</th>`).join("")}<th>Avg</th></tr>`;document.getElementById("fixture-body").innerHTML=[...CLUBS].sort((x,y)=>avg(x,a,b)-avg(y,a,b)).map(club=>`<tr><td>${club.name}</td>${weeks.map(gw=>{const f=club.fixtures.find(item=>item.gw===gw);return`<td><span class="fixture-chip" data-difficulty="${f.difficulty}">${f.opponentName} (${f.venue})</span></td>`}).join("")}<td><strong>${avg(club,a,b).toFixed(1)}</strong></td></tr>`).join("");const pairs=[];for(let i=0;i<CLUBS.length;i++)for(let j=i+1;j<CLUBS.length;j++){const one=CLUBS[i],two=CLUBS[j],score=weeks.reduce((sum,gw)=>sum+Math.min(one.fixtures.find(f=>f.gw===gw).difficulty,two.fixtures.find(f=>f.gw===gw).difficulty),0)/weeks.length;pairs.push({one,two,score});}document.getElementById("rotation-grid").innerHTML=pairs.sort((x,y)=>x.score-y.score).slice(0,6).map(pair=>`<article class="rotation-card"><strong>${pair.one.name} + ${pair.two.name}</strong><span>Best available average: ${pair.score.toFixed(1)} / 5</span></article>`).join("");};from.addEventListener("change",render);to.addEventListener("change",render);render();
  </script>
</Base>
