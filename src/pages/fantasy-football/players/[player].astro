---
import Base from "../../../layouts/Base.astro";import FantasyHeader from "../../../components/FantasyHeader.astro";import FantasyDisclaimer from "../../../components/FantasyDisclaimer.astro";import { fantasyPlayers, clubBySlug, fixtureDifficulty, averageFixtureDifficulty, fantasyUpdated } from "../../../data/fantasy";
export function getStaticPaths(){return fantasyPlayers.map(player=>({params:{player:player.id},props:{player}}))}
const { player }=Astro.props;
const club=clubBySlug.get(player.clubSlug);
const avg=averageFixtureDifficulty(player.clubSlug);
const verdict=player.minutes==="Monitor"?"WATCH":player.evidence>=88&&avg<=3.2?"SHORTLIST":player.evidence>=76?"CONSIDER":"WAIT";
const alternatives=fantasyPlayers.filter(p=>p.position===player.position&&p.id!==player.id&&Math.abs(p.planningPrice-player.planningPrice)<=1.5).sort((a,b)=>b.evidence-a.evidence).slice(0,3);
const faqs=[
  {q:`Is ${player.name} a good fantasy pick for 2026/27?`,a:`Our current editorial verdict is ${verdict.toLowerCase()}. ${player.note} This must be checked again when official prices and pre-season roles are available.`},
  {q:`What is ${player.name}'s price?`,a:`Last Season uses ${player.planningPrice.toFixed(1)} planning credits to compare squad structures. This is not claimed to be the official 2026/27 game price.`},
  {q:`Should I wait before selecting ${player.name}?`,a:player.minutes==="Monitor"?"Yes. The current minutes label is Monitor, so wait for stronger evidence about fitness or starting role.":"The minutes evidence is currently Strong, but injuries and pre-season changes still need checking before the deadline."}
];
const schema=JSON.stringify({"@context":"https://schema.org","@graph":[{"@type":"Article","headline":`${player.name} fantasy football guide 2026/27`,"dateModified":"2026-07-23","mainEntityOfPage":`https://lastseason.co.uk/fantasy-football/players/${player.id}/`,"author":{"@type":"Organization","name":"Last Season"}},{"@type":"FAQPage","mainEntity":faqs.map(f=>({"@type":"Question","name":f.q,"acceptedAnswer":{"@type":"Answer","text":f.a}}))}]});
---
<Base title={`${player.name} Fantasy Football Guide 2026/27`} description={`${player.name} fantasy guide: ${player.club} fixtures, ${player.position} classification, planning value, minutes risk, evidence and alternatives for 2026/27.`} canonical={`/fantasy-football/players/${player.id}/`} schema={schema}>
  <FantasyHeader/><div class="fantasy-page"><section class="fantasy-hero fantasy-hero--compact"><div class="fantasy-container fantasy-hero__grid"><div class="fantasy-hero__copy"><nav class="fantasy-breadcrumbs" style="color:#aebdc5"><a href="/fantasy-football/">Fantasy</a><span>/</span><a href="/fantasy-football/players/">Players</a><span>/</span><span>{player.name}</span></nav><span class="fantasy-eyebrow">{player.club} · {player.position}</span><h1>{player.name}</h1><p>{player.note}</p><div class="fantasy-actions"><a class="fantasy-button" href="/fantasy-football/player-compare/">Compare players</a><a class="fantasy-button fantasy-button--secondary" href="/fantasy-football/squad-builder/">Open builder</a></div></div><aside class="kickoff-card"><small>Current verdict</small><strong>{verdict}</strong><p>{player.evidence}/100 reviewed evidence · {player.minutes} minutes label · {avg.toFixed(2)} opening fixture rating.</p></aside></div></section>
    <section class="fantasy-section fantasy-section--tint"><div class="fantasy-container"><div class="fantasy-card-grid"><article class="fantasy-card"><span>Classification</span><strong>{player.position}</strong><p>Use this current planning position when comparing structure and alternatives.</p></article><article class="fantasy-card"><span>Planning value</span><strong>{player.planningPrice.toFixed(1)} credits</strong><p>An editorial squad-building value, not the official game price.</p></article><article class="fantasy-card"><span>Minutes</span><strong>{player.minutes}</strong><p>{player.minutes==="Strong"?"Current evidence points towards reliable selection.":"Wait for clearer pre-season role or fitness evidence."}</p></article></div></div></section>
    <section class="fantasy-section"><div class="fantasy-container"><div class="fantasy-section__head"><div><span class="fantasy-eyebrow">Gameweeks 1–6</span><h2>{player.club} opening fixtures</h2></div><p>Lower difficulty is more favourable. These are Last Season editorial ratings.</p></div><div class="fixture-run">{club?.fixtures.map(f=><article><span>GW{f.gw}</span><strong>{clubBySlug.get(f.opponent)?.short||f.opponent} ({f.venue})</strong><small class="fixture-chip" data-difficulty={fixtureDifficulty(f.opponent,f.venue)}>Difficulty {fixtureDifficulty(f.opponent,f.venue)}</small></article>)}</div>
    <div class="fantasy-section__head" style="margin-top:2.5rem"><div><span class="fantasy-eyebrow">Same-position shortlist</span><h2>Alternatives to compare</h2></div></div><div class="fantasy-card-grid">{alternatives.map(p=><a class="fantasy-card" href={`/fantasy-football/players/${p.id}/`}><span>{p.position} · {p.planningPrice.toFixed(1)} credits</span><strong>{p.name}</strong><p>{p.club} · evidence {p.evidence}<br/>{p.note}</p><small>Open guide →</small></a>)}</div>
    <div class="fantasy-section__head" style="margin-top:2.5rem"><div><span class="fantasy-eyebrow">Quick answers</span><h2>{player.name} fantasy FAQ</h2></div></div><div class="ranking-list">{faqs.map((f,i)=><article class="ranking-card"><b>{i+1}</b><div><strong>{f.q}</strong><span>{f.a}</span></div></article>)}</div><FantasyDisclaimer/><p class="fantasy-meta">Profile reviewed {fantasyUpdated}. Last-season points, where shown, are historical evidence rather than a projection.</p></div></section>
  </div>
</Base>
