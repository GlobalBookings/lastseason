---
import Base from "../../../layouts/Base.astro";import FantasyHeader from "../../../components/FantasyHeader.astro";import { fantasyPlayers, fantasyUpdated } from "../../../data/fantasy";
const positions=["All","GK","DEF","MID","FWD"];
---
<Base title="Fantasy Football Player Guides 2026/27" description="Independent 2026/27 fantasy player guides with opening fixtures, planning value, minutes flags, evidence scores and comparable alternatives." canonical="/fantasy-football/players/">
  <FantasyHeader/><div class="fantasy-page"><div class="fantasy-tool-hero"><div class="fantasy-container"><nav class="fantasy-breadcrumbs"><a href="/fantasy-football/">Fantasy</a><span>/</span><span>Players</span></nav><span class="fantasy-eyebrow">{fantasyPlayers.length} reviewed profiles · {fantasyUpdated}</span><h1>Research a pick before you commit.</h1><p>Player-level landing pages built around early fixtures, role security and evidence. Planning credits remain separate from official prices.</p></div></div><section class="fantasy-section fantasy-section--tint"><div class="fantasy-container"><div class="fantasy-controls fantasy-controls--two"><label class="fantasy-field">Search<input id="player-search" type="search" placeholder="Player or club"/></label><label class="fantasy-field">Position<select id="player-position">{positions.map(p=><option value={p}>{p==="All"?"All positions":p}</option>)}</select></label></div><div class="fantasy-card-grid" id="player-grid">{fantasyPlayers.map(p=><a class="fantasy-card" href={`/fantasy-football/players/${p.id}/`} data-player={`${p.name} ${p.club}`.toLowerCase()} data-position={p.position}><span>{p.position} · {p.minutes} minutes</span><strong>{p.name}</strong><p>{p.club} · {p.planningPrice.toFixed(1)} planning credits<br/>{p.note}</p><small>Open player guide →</small></a>)}</div><p class="fantasy-status" id="player-count">{fantasyPlayers.length} player guides shown.</p></div></section></div>
  <script is:inline>const cards=[...document.querySelectorAll("[data-player]")],search=document.getElementById("player-search"),position=document.getElementById("player-position"),count=document.getElementById("player-count");function filter(){let n=0;cards.forEach(card=>{const visible=card.dataset.player.includes(search.value.toLowerCase())&&(position.value==="All"||card.dataset.position===position.value);card.hidden=!visible;if(visible)n++});count.textContent=`${n} player guide${n===1?"":"s"} shown.`}search?.addEventListener("input",filter);position?.addEventListener("change",filter);</script>
</Base>
