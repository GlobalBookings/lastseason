---
import Base from "../../layouts/Base.astro";import FantasyHeader from "../../components/FantasyHeader.astro";import FantasyDisclaimer from "../../components/FantasyDisclaimer.astro";import { fantasyRulesUrl } from "../../data/fantasy";
const chips=[
  ["Wildcard A","A flexible early reset. Do not lock it to a week before fixtures and prices settle."],["Free Hit A","Keep provisional until blank or unusually difficult weeks are confirmed."],["Bench Boost A","Works best when all 15 players have credible minutes and fixtures."],["Triple Captain A","Reserve for an elite captain opportunity; future doubles are not yet known."],
  ["Wildcard B","A later structural reset rather than a repair for one bad score."],["Free Hit B","Hold for confirmed schedule disruption or a concentrated upside week."],["Bench Boost B","Plan transfers into it gradually instead of forcing fifteen expensive starters."],["Triple Captain B","Wait for firm fixture and minutes information."],
];
---
<Base title="Fantasy Football Chip Planner 2026/27" description="Plan both confirmed sets of Wildcard, Free Hit, Bench Boost and Triple Captain chips across the 2026/27 fantasy season." canonical="/fantasy-football/chip-planner/">
  <FantasyHeader/><div class="fantasy-page"><div class="fantasy-tool-hero"><div class="fantasy-container"><nav class="fantasy-breadcrumbs"><a href="/fantasy-football/">Fantasy</a><span>/</span><span>Chip planner</span></nav><span class="fantasy-eyebrow">Eight chips confirmed</span><h1>Sketch the season. Keep the pencil handy.</h1><p>The official 2026/27 rules give every manager two Wildcards, two Free Hits, two Bench Boosts and two Triple Captains. The first set expires at the Gameweek 19 deadline. <a href={fantasyRulesUrl} rel="nofollow">Read the official announcement.</a></p></div></div><section class="fantasy-section fantasy-section--tint"><div class="fantasy-container"><div class="chip-grid">{chips.map(([name,description])=>{const firstSet=name.endsWith(" A");const weeks=firstSet?Array.from({length:19},(_,j)=>j+1):Array.from({length:19},(_,j)=>j+20);return <article class="chip-card"><span class="fantasy-eyebrow">{firstSet?"First-half chip":"Second-half chip"}</span><h3>{name}</h3><p>{description}</p><label class="fantasy-field">Target week<select data-chip={name}><option value="">Unplanned</option>{weeks.map(gw=><option value={gw}>Gameweek {gw}</option>)}</select></label></article>})}</div><div class="fantasy-actions" style="margin-top:1rem"><button class="fantasy-button" id="save-chips">Save chip plan</button><button class="fantasy-button fantasy-button--dark" id="clear-chips">Clear plan</button></div><p class="fantasy-status" id="chip-status" aria-live="polite">Nothing is uploaded. Your plan stays in this browser.</p><FantasyDisclaimer/></div></section></div>
  <script is:inline>const key="lastseason-fantasy-chips",controls=[...document.querySelectorAll("[data-chip]")];try{const saved=JSON.parse(localStorage.getItem(key)||"{}");controls.forEach(c=>c.value=saved[c.dataset.chip]||"")}catch{}document.getElementById("save-chips")?.addEventListener("click",()=>{const plan=Object.fromEntries(controls.map(c=>[c.dataset.chip,c.value]));localStorage.setItem(key,JSON.stringify(plan));document.getElementById("chip-status").textContent="Chip sketch saved. Revisit it when rules and schedule changes are confirmed."});document.getElementById("clear-chips")?.addEventListener("click",()=>{controls.forEach(c=>c.value="");localStorage.removeItem(key);document.getElementById("chip-status").textContent="Chip sketch cleared."});</script>
</Base>
