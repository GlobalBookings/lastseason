---
import Base from "../../layouts/Base.astro";import FantasyHeader from "../../components/FantasyHeader.astro";import FantasyDisclaimer from "../../components/FantasyDisclaimer.astro";import { fantasyPlayers, clubBySlug, fixtureDifficulty } from "../../data/fantasy";
const data=JSON.stringify(fantasyPlayers.map(p=>({...p,fixtures:clubBySlug.get(p.clubSlug)?.fixtures.map(f=>({...f,difficulty:fixtureDifficulty(f.opponent,f.venue),opponentName:clubBySlug.get(f.opponent)?.name}))}))).replace(/</g,"\\u003c");
---
<Base title="Fantasy Football Captain Picker 2026/27" description="Rank 2026/27 fantasy football captain candidates by reviewed evidence, fixture, minutes security and your preferred risk level." canonical="/fantasy-football/captain-picker/">
  <FantasyHeader active="captain"/><div class="fantasy-page"><div class="fantasy-tool-hero"><div class="fantasy-container"><nav class="fantasy-breadcrumbs"><a href="/fantasy-football/">Fantasy</a><span>/</span><span>Captain picker</span></nav><span class="fantasy-eyebrow">Decision helper</span><h1>Choose a captain for the right reasons.</h1><p>Rank candidates by evidence, opponent, venue and minutes confidence. No certainty theatre and no invented projected points.</p></div></div><section class="fantasy-section fantasy-section--tint"><div class="fantasy-container"><div class="fantasy-panel"><div class="fantasy-controls fantasy-controls--two"><label class="fantasy-field">Gameweek<select id="captain-gw">{[1,2,3,4,5,6].map(n=><option value={n}>Gameweek {n}</option>)}</select></label><label class="fantasy-field">Risk appetite<select id="captain-risk"><option value="safe">Reliable</option><option value="balanced" selected>Balanced</option><option value="aggressive">Aggressive</option></select></label></div><div class="ranking-list" id="captain-ranking"></div></div><FantasyDisclaimer short/></div></section></div>
  <script is:inline type="application/json" id="captain-data" set:html={data}></script><script is:inline>const PLAYERS=JSON.parse(document.getElementById("captain-data")?.textContent||"[]"),gw=document.getElementById("captain-gw"),risk=document.getElementById("captain-risk"),out=document.getElementById("captain-ranking");const rank=()=>{const mode=risk.value,n=Number(gw.value);const ranked=PLAYERS.filter(p=>p.position==="MID"||p.position==="FWD").map(p=>{const f=p.fixtures.find(x=>x.gw===n);let score=p.evidence+(6-f.difficulty)*6+(f.venue==="H"?3:0);if(mode==="safe")score+=p.minutes==="Strong"?10:-15;if(mode==="aggressive")score+=p.tags.includes("upside")||p.tags.includes("differential")?10:0;return{...p,f,score};}).sort((a,b)=>b.score-a.score).slice(0,8);out.innerHTML=ranked.map((p,i)=>`<article class="ranking-card"><b>${i+1}</b><div><strong>${p.name}</strong><span>${p.club} · ${p.f.opponentName} (${p.f.venue}) · ${p.minutes} minutes confidence<br>${p.note}</span></div><div class="ranking-score"><strong>${Math.round(p.score)}</strong><small>decision score</small></div></article>`).join("");};gw.addEventListener("change",rank);risk.addEventListener("change",rank);rank();</script>
</Base>
