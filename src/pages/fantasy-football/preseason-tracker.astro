---
import Base from "../../layouts/Base.astro";import FantasyHeader from "../../components/FantasyHeader.astro";import FantasyDisclaimer from "../../components/FantasyDisclaimer.astro";import { fantasyPlayers, fantasyPositionChanges, fantasyUpdated } from "../../data/fantasy";
const monitor=fantasyPlayers.filter(p=>p.minutes==="Monitor");
const payload=JSON.stringify(monitor).replace(/</g,"\\u003c");
---
<Base title="Fantasy Football Pre-Season Tracker 2026/27" description="Track minutes, roles, transfers and position changes for the 2026/27 fantasy season, with a private watchlist that stays in your browser." canonical="/fantasy-football/preseason-tracker/">
  <FantasyHeader/><div class="fantasy-page"><div class="fantasy-tool-hero"><div class="fantasy-container"><nav class="fantasy-breadcrumbs"><a href="/fantasy-football/">Fantasy</a><span>/</span><span>Pre-season tracker</span></nav><span class="fantasy-eyebrow">Reviewed {fantasyUpdated}</span><h1>Track uncertainty, not noise.</h1><p>A focused list of players whose role, minutes or classification deserve checking before the confirmed Gameweek 1 deadline.</p></div></div><section class="fantasy-section fantasy-section--tint"><div class="fantasy-container"><div class="fantasy-section__head"><div><span class="fantasy-eyebrow">{monitor.length} role checks</span><h2>Minutes monitor</h2></div><label class="fantasy-field">Filter players<input id="tracker-search" type="search" placeholder="Player or club"/></label></div><div class="ranking-list" id="tracker-list">{monitor.map((p,i)=><article class="ranking-card" data-search={`${p.name} ${p.club}`.toLowerCase()}><b>{i+1}</b><div><strong>{p.name}</strong><span>{p.club} · {p.position}<br/>{p.note}</span></div><button class="fantasy-button fantasy-button--dark" data-watch={p.id}>Watch</button></article>)}</div>
    <div class="fantasy-section__head" style="margin-top:2.5rem"><div><span class="fantasy-eyebrow">Official classifications</span><h2>Position changes</h2></div></div><div class="fantasy-card-grid">{fantasyPositionChanges.map(p=><article class="fantasy-card"><span>{p.previous} → {p.current}</span><strong>{p.player}</strong><p>{p.club}. Reassess last season’s output under the new scoring opportunities.</p><small>Confirmed change</small></article>)}</div><FantasyDisclaimer/></div></section></div>
  <script is:inline type="application/json" id="tracker-data" set:html={payload}></script><script is:inline>
    const players=JSON.parse(document.getElementById("tracker-data")?.textContent||"[]");let saved=[];try{saved=JSON.parse(localStorage.getItem("lastseason-fantasy-watchlist")||"[]")}catch{}const render=()=>document.querySelectorAll("[data-watch]").forEach(b=>{const on=saved.some(p=>p.id===b.dataset.watch);b.textContent=on?"Watching":"Watch";b.classList.toggle("fantasy-button--dark",!on)});document.querySelectorAll("[data-watch]").forEach(b=>b.addEventListener("click",()=>{const p=players.find(p=>p.id===b.dataset.watch);saved=saved.some(x=>x.id===p.id)?saved.filter(x=>x.id!==p.id):[...saved,{id:p.id,name:p.name}];localStorage.setItem("lastseason-fantasy-watchlist",JSON.stringify(saved));render()}));render();document.getElementById("tracker-search")?.addEventListener("input",e=>document.querySelectorAll("[data-search]").forEach(row=>row.hidden=!row.dataset.search.includes(e.target.value.toLowerCase())));
  </script>
</Base>
