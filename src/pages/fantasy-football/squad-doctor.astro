---
import Base from "../../layouts/Base.astro";
import FantasyHeader from "../../components/FantasyHeader.astro";
import FantasyDisclaimer from "../../components/FantasyDisclaimer.astro";
import { fantasyPlayers, fantasyClubs, averageFixtureDifficulty } from "../../data/fantasy";
const playerData=JSON.stringify(fantasyPlayers.map(p=>({...p,afd:Number(averageFixtureDifficulty(p.clubSlug).toFixed(2))}))).replace(/</g,"\\u003c");
const clubData=JSON.stringify(Object.fromEntries(fantasyClubs.map(c=>[c.slug,c.short]))).replace(/</g,"\\u003c");
const schema=JSON.stringify({"@context":"https://schema.org","@type":"WebApplication","name":"Fantasy Football Squad Doctor","url":"https://lastseason.co.uk/fantasy-football/squad-doctor/","applicationCategory":"SportsApplication","isAccessibleForFree":true,"description":"Diagnose a saved fantasy football draft for structure, minutes, club concentration, fixtures and planning value."});
---
<Base title="Free Fantasy Football Squad Doctor 2026/27" description="Check your saved 2026/27 fantasy squad for minutes risk, team structure, club concentration, fixtures and planning value, then share the report." canonical="/fantasy-football/squad-doctor/" schema={schema}>
  <FantasyHeader active="doctor"/><div class="fantasy-page"><div class="fantasy-tool-hero"><div class="fantasy-container"><nav class="fantasy-breadcrumbs"><a href="/fantasy-football/">Fantasy</a><span>/</span><span>Squad doctor</span></nav><span class="fantasy-eyebrow">Transparent checks · private by default</span><h1>Give your draft a proper physical.</h1><p>Load the squad saved in this browser and see the structural risks. This uses editorial planning credits and reviewed evidence—not secret predicted points.</p><div class="fantasy-actions"><button id="run-doctor" class="fantasy-button">Diagnose saved squad</button><a href="/fantasy-football/squad-builder/" class="fantasy-button fantasy-button--dark">Build or edit squad</a></div></div></div>
  <section class="fantasy-section fantasy-section--tint"><div class="fantasy-container"><div id="doctor-empty" class="fantasy-panel"><span class="fantasy-eyebrow">Waiting room</span><h2>No diagnosis yet</h2><p>Save a complete draft in the Squad Assistant, then come back here. Nothing leaves this browser.</p></div><div id="doctor-report" hidden>
    <div class="doctor-score"><div><span class="fantasy-eyebrow">Squad health</span><strong id="health-score">—</strong><small>/ 100</small></div><div><h2 id="health-label">Calculating…</h2><p id="health-summary"></p></div></div>
    <div class="fantasy-card-grid" id="doctor-metrics"></div>
    <div class="fantasy-panel" style="margin-top:1rem"><div class="fantasy-section__head"><div><span class="fantasy-eyebrow">Prescription</span><h2>Three useful next moves</h2></div></div><div class="ranking-list" id="doctor-actions"></div><div class="fantasy-actions" style="margin-top:1rem"><button class="fantasy-button" id="share-doctor">Share report</button><button class="fantasy-button fantasy-button--dark" id="download-doctor">Download card</button></div><p class="fantasy-status" id="doctor-status" aria-live="polite">The report is an editorial planning aid, not a promise of points.</p></div>
  </div><FantasyDisclaimer/></div></section></div>
  <script is:inline type="application/json" id="doctor-player-data" set:html={playerData}></script><script is:inline type="application/json" id="doctor-club-data" set:html={clubData}></script>
  <script is:inline>
    const players=JSON.parse(document.getElementById("doctor-player-data")?.textContent||"[]"),byId=id=>players.find(p=>p.id===id);let report=null;
    const esc=s=>String(s).replace(/[&<>"']/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
    function diagnose(){let saved;try{saved=JSON.parse(localStorage.getItem("lastseason-fantasy-squad")||"null")}catch{}const squad=(saved?.ids||[]).map(byId).filter(Boolean);if(!squad.length){document.getElementById("doctor-empty").innerHTML='<span class="fantasy-eyebrow">No saved draft</span><h2>Build a squad first</h2><p>The doctor reads the squad you save in the Squad Assistant.</p><a class="fantasy-button" href="/fantasy-football/squad-builder/">Open squad assistant</a>';return}
      const counts=Object.fromEntries(["GK","DEF","MID","FWD"].map(pos=>[pos,squad.filter(p=>p.position===pos).length])),valid=counts.GK===2&&counts.DEF===5&&counts.MID===5&&counts.FWD===3&&squad.length===15;const monitors=squad.filter(p=>p.minutes==="Monitor"),clubs={};squad.forEach(p=>clubs[p.club]=(clubs[p.club]||0)+1);const stacks=Object.entries(clubs).filter(([,n])=>n>=3);const spend=squad.reduce((n,p)=>n+p.planningPrice,0),avgEvidence=squad.reduce((n,p)=>n+p.evidence,0)/squad.length,avgFixtures=squad.reduce((n,p)=>n+p.afd,0)/squad.length;let score=100;score-=valid?0:25;score-=Math.min(24,monitors.length*4);score-=stacks.length*4;score-=avgFixtures>3.35?10:avgFixtures>3.05?5:0;score-=spend>100?12:0;score=Math.max(15,Math.round(score));
      const low=[...squad].sort((a,b)=>(a.evidence-a.afd*4)-(b.evidence-b.afd*4))[0],alts=players.filter(p=>p.position===low?.position&&!squad.some(s=>s.id===p.id)&&p.planningPrice<=low.planningPrice+.5&&p.minutes==="Strong").sort((a,b)=>(b.evidence-b.afd*4)-(a.evidence-a.afd*4)).slice(0,2);
      const actions=[];if(!valid)actions.push(["Fix structure",`Current shape is ${counts.GK}-${counts.DEF}-${counts.MID}-${counts.FWD}; the planning template expects 2-5-5-3.`]);if(monitors.length)actions.push(["Reduce uncertainty",`${monitors.length} picks carry a minutes warning: ${monitors.slice(0,4).map(p=>p.name).join(", ")}${monitors.length>4?"…":""}`]);if(stacks.length)actions.push(["Check club exposure",`${stacks.map(([c,n])=>`${c} (${n})`).join(", ")} sit at the three-player ceiling.`]);if(low&&alts.length)actions.push(["Pressure-test one slot",`${low.name} is the weakest evidence/fixture blend here. Compare ${alts.map(p=>p.name).join(" or ")} at a similar planning cost.`]);if(actions.length<3)actions.push(["Keep flexibility","Do not spend every planning credit before official prices and pre-season roles settle."]);if(actions.length<3)actions.push(["Set the final check","Revisit injuries, starts, captain and vice-captain one hour before the deadline."]);
      report={score,squad,monitors,spend,avgEvidence,avgFixtures,actions:actions.slice(0,3),valid};document.getElementById("doctor-empty").hidden=true;document.getElementById("doctor-report").hidden=false;document.getElementById("health-score").textContent=score;document.getElementById("health-label").textContent=score>=85?"Healthy draft":score>=70?"Promising, with caveats":"Needs another pass";document.getElementById("health-summary").textContent=`${squad.length} players · ${spend.toFixed(1)} planning credits · ${monitors.length} minutes flags.`;
      const metrics=[["Shape",valid?"Valid 2-5-5-3":"Needs work",`${counts.GK} GK · ${counts.DEF} DEF · ${counts.MID} MID · ${counts.FWD} FWD`],["Minutes",`${monitors.length} flagged`,monitors.length?"Verify likely starts before locking in.":"Every pick currently has a strong minutes label."],["Opening fixtures",avgFixtures.toFixed(2),avgFixtures<=3?"Favourable editorial average.":"A tougher-than-neutral opening blend."],["Evidence",Math.round(avgEvidence),`Average reviewed evidence score across ${squad.length} players.`]];document.getElementById("doctor-metrics").innerHTML=metrics.map(([tag,title,note])=>`<article class="fantasy-card"><span>${esc(tag)}</span><strong>${esc(title)}</strong><p>${esc(note)}</p></article>`).join("");document.getElementById("doctor-actions").innerHTML=report.actions.map(([title,note],i)=>`<article class="ranking-card"><b>${i+1}</b><div><strong>${esc(title)}</strong><span>${esc(note)}</span></div></article>`).join("");window.lsTrack?.("fantasy_squad_diagnosed",{score,players:squad.length,minutes_flags:monitors.length});
    }
    const shareText=()=>`My Last Season squad health: ${report.score}/100\n${report.squad.length} players · ${report.monitors.length} minutes flags · ${report.avgFixtures.toFixed(2)} fixture rating`;
    document.getElementById("run-doctor")?.addEventListener("click",diagnose);document.getElementById("share-doctor")?.addEventListener("click",async()=>{if(!report)return;try{if(navigator.share)await navigator.share({title:"My fantasy squad diagnosis",text:shareText(),url:location.href});else await navigator.clipboard.writeText(`${shareText()}\n${location.href}`);document.getElementById("doctor-status").textContent="Report shared or copied."}catch(e){if(e.name!=="AbortError")document.getElementById("doctor-status").textContent="Could not share this time."}});
    document.getElementById("download-doctor")?.addEventListener("click",()=>{if(!report)return;const c=document.createElement("canvas"),x=c.getContext("2d");c.width=1200;c.height=630;const g=x.createLinearGradient(0,0,1200,630);g.addColorStop(0,"#09141d");g.addColorStop(1,"#1d493b");x.fillStyle=g;x.fillRect(0,0,c.width,c.height);x.fillStyle="#b7ff5a";x.font="800 26px system-ui";x.fillText("LAST SEASON · SQUAD DOCTOR",70,75);x.fillStyle="#fff";x.font="900 150px system-ui";x.fillText(String(report.score),70,250);x.font="800 42px system-ui";x.fillText("/ 100 squad health",310,236);x.fillStyle="#b9c9d2";x.font="600 29px system-ui";x.fillText(`${report.squad.length} players · ${report.monitors.length} minutes flags · ${report.spend.toFixed(1)} planning credits`,75,325);report.actions.forEach((a,i)=>{x.fillStyle="#b7ff5a";x.font="800 24px system-ui";x.fillText(`${i+1}. ${a[0]}`,75,410+i*65);x.fillStyle="#dce7e1";x.font="500 20px system-ui";x.fillText(a[1].slice(0,78),315,410+i*65)});x.fillStyle="#8fa4af";x.font="600 20px system-ui";x.fillText("lastseason.co.uk/fantasy-football/squad-doctor",75,590);const a=document.createElement("a");a.download="last-season-squad-doctor.png";a.href=c.toDataURL("image/png");a.click()});
    try{if(JSON.parse(localStorage.getItem("lastseason-fantasy-squad")||"null")?.ids?.length)diagnose()}catch{}
  </script>
</Base>
