---
import Base from "../../layouts/Base.astro";import FantasyHeader from "../../components/FantasyHeader.astro";import FantasyDisclaimer from "../../components/FantasyDisclaimer.astro";import { fantasyUpdated } from "../../data/fantasy";
const updates=[
  {date:"23 July 2026",title:"Official deadline, chips and positions confirmed",text:"Added the Gameweek 1 deadline of 18:30 BST on 21 August, the two half-season sets of four chips, and all eleven official position changes."},
  {date:"23 July 2026",title:"Fantasy growth sprint released",text:"Expanded team names to all twenty clubs, added player and style collections, club guides, Gameweek 1–6 hubs, role and budget guides, saved-name journeys, a return desk and a consented briefing-interest list."},
  {date:"21 July 2026",title:"Pre-season planning pool reviewed",text:"Updated known transfers, removed departed players from the active pool, added 2025/26 evidence leaders and refreshed minutes warnings."},
  {date:"21 July 2026",title:"Opening-six advice reviewed",text:"Checked the published 2026/27 fixtures and recalculated Last Season difficulty ratings and rotation pairs."},
  {date:"19 June 2026",title:"2026/27 fixtures published",text:"Added all twenty clubs and their first six opponents. Dates and kick-off times remain capable of moving."},
];
---
<Base title="Fantasy Football Data Updates & Change Log 2026/27" description="See when Last Season's independent 2026/27 fantasy planning pool, fixtures, ratings and assumptions were reviewed and what remains unconfirmed." canonical="/fantasy-football/updates/">
  <FantasyHeader/><div class="fantasy-page"><div class="fantasy-tool-hero"><div class="fantasy-container"><nav class="fantasy-breadcrumbs"><a href="/fantasy-football/">Fantasy</a><span>/</span><span>Updates</span></nav><span class="fantasy-eyebrow">Last reviewed {fantasyUpdated}</span><h1>What changed—and what did not.</h1><p>A visible review log for the advice layer. We distinguish editorial updates from official game information and never silently rewrite provisional assumptions.</p></div></div><section class="fantasy-section"><div class="fantasy-container"><div class="ranking-list">{updates.map((update,i)=><article class="ranking-card"><b>{i+1}</b><div><strong>{update.title}</strong><span>{update.date}<br/>{update.text}</span></div></article>)}</div><div class="fantasy-card-grid" style="margin-top:1.5rem"><article class="fantasy-card"><span>Pending</span><strong>Official 2026/27 prices</strong><p>Planning credits will remain clearly separate until a permissible reviewed source is available.</p></article><article class="fantasy-card"><span>Confirmed</span><strong>Rules and Gameweek 1 deadline</strong><p>Eight chips and the 21 August, 18:30 BST deadline now come directly from official Premier League announcements.</p></article><article class="fantasy-card"><span>Ongoing</span><strong>Transfers and minutes</strong><p>The window remains open, so every Monitor label should be checked before a real deadline.</p></article></div><FantasyDisclaimer/></div></section></div>
</Base>
