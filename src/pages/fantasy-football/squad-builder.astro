---
import Base from "../../layouts/Base.astro";
import FantasyHeader from "../../components/FantasyHeader.astro";
import FantasyDisclaimer from "../../components/FantasyDisclaimer.astro";
import { fantasyPlayers, fantasyClubs, averageFixtureDifficulty, fantasyUpdated } from "../../data/fantasy";
const players=fantasyPlayers.map(player=>({...player,fixtureDifficulty:Number(averageFixtureDifficulty(player.clubSlug).toFixed(2))}));
const payload=JSON.stringify({players,clubs:fantasyClubs.map(({name,slug})=>({name,slug})),updated:fantasyUpdated}).replace(/</g,"\\u003c");
const schema=JSON.stringify({"@context":"https://schema.org","@type":"WebApplication","name":"Fantasy football squad assistant","url":"https://lastseason.co.uk/fantasy-football/squad-builder/","applicationCategory":"SportsApplication","operatingSystem":"Any","offers":{"@type":"Offer","price":"0","priceCurrency":"GBP"}});
---
<Base title="Fantasy Football Squad Builder & Smart Assistant 2026/27" description="Build and save a balanced 15-player fantasy football draft using reviewed evidence, opening fixtures, minutes confidence and transparent planning values." canonical="/fantasy-football/squad-builder/" schema={schema}>
  <FantasyHeader active="builder"/><div class="fantasy-page"><div class="fantasy-tool-hero"><div class="fantasy-container"><nav class="fantasy-breadcrumbs"><a href="/fantasy-football/">Fantasy</a><span>/</span><span>Squad assistant</span></nav><span class="fantasy-eyebrow">Transparent squad advice</span><h1>Build a first draft you can explain.</h1><p>The assistant balances last-season evidence, opening fixtures, minutes confidence and planning value. It never logs into another game and every recommendation shows its reasoning.</p></div></div>
  <section class="fantasy-section fantasy-section--tint"><div class="fantasy-container"><div class="fantasy-panel"><div class="fantasy-controls"><label class="fantasy-field">Approach<select id="builder-strategy"><option value="balanced">Balanced</option><option value="safe">Reliable minutes</option><option value="aggressive">High upside</option><option value="value">Value first</option></select></label><label class="fantasy-field">Planning budget<input id="builder-budget" type="number" min="90" max="115" value="100" step="0.5" /></label><label class="fantasy-field">Club to favour<select id="builder-club"><option value="">No preference</option>{fantasyClubs.map(club=><option value={club.slug}>{club.name}</option>)}</select></label></div><div class="fantasy-actions"><button class="fantasy-button" id="generate-squad">Build my draft</button><button class="fantasy-button fantasy-button--dark" id="save-squad">Save draft</button><button class="fantasy-button fantasy-button--ghost" id="share-squad">Copy squad</button><button class="fantasy-button fantasy-button--ghost" id="download-squad">Download squad card</button></div><p class="fantasy-status" id="builder-status" aria-live="polite">Planning values are Last Season estimates, not official prices. Generate a squad, then pressure-test every flagged player.</p></div></div></section>
  <section class="fantasy-section"><div class="fantasy-container builder-layout"><div class="pitch"><div class="pitch-summary"><div><span>Draft cost</span><strong id="squad-cost">0.0</strong></div><div style="text-align:right"><span>Players</span><strong id="squad-count">0/15</strong></div></div><div id="pitch-players"></div><div class="bench"><small>Bench</small><div class="pitch-row" id="bench-players"></div></div></div><aside class="fantasy-panel"><div class="fantasy-controls fantasy-controls--two"><label class="fantasy-field">Position<select id="candidate-position"><option value="">All</option><option>GK</option><option>DEF</option><option>MID</option><option>FWD</option></select></label><label class="fantasy-field">Find player<input id="candidate-search" type="search" placeholder="Search name or club" /></label></div><div class="candidate-list" id="candidate-list"></div><div class="squad-reason" id="squad-reason">Generate a draft to see why the assistant chose it.</div></aside></div><FantasyDisclaimer /></div></section>
  </div><script is:inline type="application/json" id="builder-data" set:html={payload}></script>
  <script is:inline>
    const DATA=JSON.parse(document.getElementById("builder-data")?.textContent||"{}"); const PLAYERS=DATA.players||[], QUOTA={GK:2,DEF:5,MID:5,FWD:3}; let selected=[];
    const byId=id=>PLAYERS.find(player=>player.id===id), cost=()=>selected.reduce((sum,id)=>sum+(byId(id)?.planningPrice||0),0), clubCount=(slug,without="")=>selected.filter(id=>id!==without&&byId(id)?.clubSlug===slug).length;
    const strategyScore=(player,strategy,preferred)=>{let score=player.evidence+(6-player.fixtureDifficulty)*4-player.planningPrice; if(strategy==="safe")score+=(player.minutes==="Strong"?12:-12); if(strategy==="aggressive")score+=(player.tags.includes("upside")||player.tags.includes("differential")?12:0)-player.evidence*.08; if(strategy==="value")score+=(player.evidence/player.planningPrice)*4-player.planningPrice*1.7; if(preferred&&player.clubSlug===preferred)score+=7; return score;};
    const buildBase=()=>{selected=[]; for(const position of Object.keys(QUOTA)){const options=PLAYERS.filter(p=>p.position===position).sort((a,b)=>a.planningPrice-b.planningPrice||b.evidence-a.evidence); while(selected.filter(id=>byId(id)?.position===position).length<QUOTA[position]){const next=options.find(p=>!selected.includes(p.id)&&clubCount(p.clubSlug)<3); if(!next)break;selected.push(next.id);}}};
    const generate=()=>{const strategy=document.getElementById("builder-strategy").value, preferred=document.getElementById("builder-club").value, budget=Number(document.getElementById("builder-budget").value)||100; buildBase(); let changed=true; while(changed){changed=false; let best=null; for(const oldId of selected){const old=byId(oldId); for(const candidate of PLAYERS.filter(p=>p.position===old.position&&!selected.includes(p.id))){if(clubCount(candidate.clubSlug,oldId)>=3)continue; const extra=candidate.planningPrice-old.planningPrice;if(cost()+extra>budget+.001)continue;const gain=strategyScore(candidate,strategy,preferred)-strategyScore(old,strategy,preferred);if(gain>0&&(!best||gain/Math.max(extra,.25)>best.ratio))best={oldId,candidate,gain,ratio:gain/Math.max(extra,.25)};} } if(best){selected[selected.indexOf(best.oldId)]=best.candidate.id;changed=true;}} render(); const flagged=selected.map(byId).filter(p=>p.minutes==="Monitor").length; document.getElementById("squad-reason").textContent=`This ${strategy} draft uses ${cost().toFixed(1)} planning credits. ${flagged} selection${flagged===1?" needs":"s need"} a pre-season minutes or status check. The preferred-club setting is only a small tie-breaker, never permission to stack more than three players.`;};
    const benchIds=()=>{const bench=[];const goalkeepers=selected.map(byId).filter(p=>p.position==="GK").sort((a,b)=>a.evidence-b.evidence);if(goalkeepers[0])bench.push(goalkeepers[0].id);const counts={DEF:5,MID:5,FWD:3};const outfield=selected.map(byId).filter(p=>p.position!=="GK").sort((a,b)=>strategyScore(a,"balanced","")-strategyScore(b,"balanced",""));for(const player of outfield){if(bench.length>=4)break;if(counts[player.position]-bench.filter(id=>byId(id)?.position===player.position).length>({DEF:3,MID:2,FWD:1})[player.position])bench.push(player.id);}return bench;};
    const shirt=player=>`<button class="player-shirt" type="button" data-remove="${player.id}" title="Remove ${player.name}"><strong>${player.name}</strong><span>${player.club} · ${player.position}</span><small>${player.planningPrice.toFixed(1)} cr</small></button>`;
    const render=()=>{const bench=benchIds(), starters=selected.filter(id=>!bench.includes(id)).map(byId);document.getElementById("pitch-players").innerHTML=["FWD","MID","DEF","GK"].map(pos=>`<div class="pitch-row">${starters.filter(p=>p.position===pos).map(shirt).join("")}</div>`).join("");document.getElementById("bench-players").innerHTML=bench.map(id=>shirt(byId(id))).join("");document.getElementById("squad-cost").textContent=cost().toFixed(1);document.getElementById("squad-count").textContent=`${selected.length}/15`;document.querySelectorAll("[data-remove]").forEach(button=>button.addEventListener("click",()=>{selected=selected.filter(id=>id!==button.dataset.remove);render();}));renderCandidates(); const valid=Object.entries(QUOTA).every(([pos,n])=>selected.filter(id=>byId(id)?.position===pos).length===n)&&cost()<=Number(document.getElementById("builder-budget").value)&&PLAYERS.every(p=>clubCount(p.clubSlug)<=3);document.getElementById("builder-status").textContent=valid?"Valid 15-player planning draft: 2 goalkeepers, 5 defenders, 5 midfielders, 3 forwards and no more than three from one club.":"Draft incomplete. Use the candidate list or generate a new valid squad.";document.getElementById("builder-status").dataset.tone=valid?"":"warning";};
    const renderCandidates=()=>{const query=(document.getElementById("candidate-search").value||"").toLowerCase(),pos=document.getElementById("candidate-position").value;document.getElementById("candidate-list").innerHTML=PLAYERS.filter(p=>(!pos||p.position===pos)&&(!query||`${p.name} ${p.club}`.toLowerCase().includes(query))).sort((a,b)=>b.evidence-a.evidence).map(p=>`<div class="candidate"><div><strong>${p.name}</strong><span>${p.club} · ${p.position} · ${p.planningPrice.toFixed(1)} cr · evidence ${p.evidence}</span></div><button type="button" data-add="${p.id}" ${selected.includes(p.id)||clubCount(p.clubSlug)>=3||selected.filter(id=>byId(id)?.position===p.position).length>=QUOTA[p.position]?"disabled":""}>Add</button></div>`).join("");document.querySelectorAll("[data-add]").forEach(button=>button.addEventListener("click",()=>{selected.push(button.dataset.add);render();}));};
    document.getElementById("generate-squad")?.addEventListener("click",generate);document.getElementById("save-squad")?.addEventListener("click",()=>{localStorage.setItem("lastseason-fantasy-squad",JSON.stringify({ids:selected,updatedAt:Date.now()}));document.getElementById("builder-status").textContent="Draft saved privately in this browser.";});document.getElementById("share-squad")?.addEventListener("click",()=>navigator.clipboard?.writeText(`My Last Season Fantasy draft\nCost: ${cost().toFixed(1)} planning credits\n${["GK","DEF","MID","FWD"].map(pos=>`${pos}: ${selected.map(byId).filter(p=>p.position===pos).map(p=>p.name).join(", ")}`).join("\n")}\n\nIndependent planning helper — lastseason.co.uk/fantasy-football/`));
    document.getElementById("download-squad")?.addEventListener("click",()=>{const canvas=document.createElement("canvas");canvas.width=1200;canvas.height=630;const ctx=canvas.getContext("2d");const gradient=ctx.createLinearGradient(0,0,1200,630);gradient.addColorStop(0,"#09141d");gradient.addColorStop(1,"#194837");ctx.fillStyle=gradient;ctx.fillRect(0,0,1200,630);ctx.fillStyle="#b7ff5a";ctx.font="800 24px Arial";ctx.fillText("LAST SEASON FANTASY",70,70);ctx.fillStyle="#ffffff";ctx.font="800 54px Arial";ctx.fillText("My 2026/27 first draft",70,140);ctx.fillStyle="#a9c1b5";ctx.font="24px Arial";ctx.fillText(`${cost().toFixed(1)} planning credits · independent helper`,70,178);let y=245;for(const pos of ["GK","DEF","MID","FWD"]){ctx.fillStyle="#b7ff5a";ctx.font="800 22px Arial";ctx.fillText(pos,70,y);ctx.fillStyle="#ffffff";ctx.font="700 25px Arial";const names=selected.map(byId).filter(p=>p.position===pos).map(p=>p.name).join("  ·  ");ctx.fillText(names,155,y);y+=78;}ctx.fillStyle="#8fa89d";ctx.font="20px Arial";ctx.fillText("Planning values are not official prices · lastseason.co.uk/fantasy-football",70,580);const link=document.createElement("a");link.download="last-season-fantasy-draft.png";link.href=canvas.toDataURL("image/png");link.click();});
    document.getElementById("candidate-search")?.addEventListener("input",renderCandidates);document.getElementById("candidate-position")?.addEventListener("change",renderCandidates);document.getElementById("builder-budget")?.addEventListener("change",render);try{const saved=JSON.parse(localStorage.getItem("lastseason-fantasy-squad")||"null");if(saved?.ids)selected=saved.ids.filter(id=>byId(id));}catch{} if(selected.length)render();else generate();
  </script>
</Base>
