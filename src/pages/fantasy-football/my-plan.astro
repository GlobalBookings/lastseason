---
import Base from "../../layouts/Base.astro";import FantasyHeader from "../../components/FantasyHeader.astro";import FantasyDisclaimer from "../../components/FantasyDisclaimer.astro";import { fantasyPlayers, fantasyKickoff } from "../../data/fantasy";
const players=JSON.stringify(fantasyPlayers.map(({id,name,club,position,planningPrice})=>({id,name,club,position,planningPrice}))).replace(/</g,"\\u003c");
---
<Base title="My Fantasy Football Plan 2026/27" description="Your private fantasy football planning dashboard for saved squad drafts, player watchlists, chip ideas and the Gameweek 1 checklist." canonical="/fantasy-football/my-plan/" robots="noindex, follow">
  <FantasyHeader active="plan"/><div class="fantasy-page"><div class="fantasy-tool-hero"><div class="fantasy-container"><nav class="fantasy-breadcrumbs"><a href="/fantasy-football/">Fantasy</a><span>/</span><span>My plan</span></nav><span class="fantasy-eyebrow">Private to this browser</span><h1>Your pre-season control room.</h1><p>Saved squad, watchlist, chips and deadline checks in one place. No login and nothing is sent to Last Season.</p></div></div><section class="fantasy-section fantasy-section--tint"><div class="fantasy-container"><div class="plan-grid">
    <article class="plan-card"><span class="fantasy-eyebrow">First draft</span><h2>Saved squad</h2><div id="plan-squad" class="plan-empty">No squad saved yet.</div><a href="/fantasy-football/squad-builder/">Open squad assistant →</a></article>
    <article class="plan-card"><span class="fantasy-eyebrow">Keep an eye on</span><h2>Watchlist</h2><div id="plan-watchlist" class="watchlist"><p class="plan-empty">No players watched yet.</p></div><a href="/fantasy-football/differentials/">Browse value picks →</a></article>
    <article class="plan-card"><span class="fantasy-eyebrow">Group chat shortlist</span><h2>Saved team names</h2><div id="plan-names" class="watchlist"><p class="plan-empty">No names saved yet.</p></div><a href="/fantasy-football/team-names/">Browse team names →</a></article>
    <article class="plan-card"><span class="fantasy-eyebrow">Season sketch</span><h2>Chip ideas</h2><div id="plan-chips" class="plan-empty">No chip weeks saved yet.</div><a href="/fantasy-football/chip-planner/">Open chip planner →</a></article>
    <article class="plan-card"><span class="fantasy-eyebrow">Possible moves</span><h2>Transfer notes</h2><div id="plan-transfers" class="plan-empty">No transfers planned yet.</div><a href="/fantasy-football/transfer-planner/">Open transfer planner →</a></article>
    <article class="plan-card"><span class="fantasy-eyebrow">Before the opener</span><h2>Deadline checklist</h2><div class="watchlist" id="plan-checklist">{["Confirm official player prices","Check injuries and late World Cup returns","Verify expected starting roles","Review captain and vice-captain","Save the final game-side squad"].map((item,i)=><label class="watchlist-item"><span><input type="checkbox" data-check={i}/> {item}</span></label>)}</div></article>
  </div><div class="fantasy-panel" style="margin-top:.8rem"><div class="fantasy-section__head"><div><span class="fantasy-eyebrow">Kick-off clock</span><h2 data-plan-countdown data-kickoff={fantasyKickoff}>Calculating…</h2></div><div class="fantasy-actions"><a class="fantasy-button" href="/fantasy-kickoff-reminder.ics?v=1" download>Add calendar reminder</a><a class="fantasy-button fantasy-button--secondary" href="/fantasy-football/newsletter/">Join briefing list</a><button class="fantasy-button fantasy-button--dark" id="clear-plan">Clear my fantasy data</button></div></div><p class="fantasy-status">This countdown is to the first league match, not an unconfirmed fantasy deadline. The early briefing list is now open; delivery will begin only when a compliant email provider and unsubscribe flow are connected.</p></div><FantasyDisclaimer/></div></section></div>
  <script is:inline type="application/json" id="plan-player-data" set:html={players}></script><script is:inline>
    const P=JSON.parse(document.getElementById("plan-player-data")?.textContent||"[]"),byId=id=>P.find(p=>p.id===id);try{const squad=JSON.parse(localStorage.getItem("lastseason-fantasy-squad")||"null");if(squad?.ids?.length){const picked=squad.ids.map(byId).filter(Boolean),price=picked.reduce((s,p)=>s+p.planningPrice,0);document.getElementById("plan-squad").innerHTML=`<p><strong>${picked.length} players · ${price.toFixed(1)} planning credits</strong></p><p>${picked.map(p=>p.name).join(", ")}</p>`;}}catch{}
    const renderWatch=()=>{try{const list=JSON.parse(localStorage.getItem("lastseason-fantasy-watchlist")||"[]");if(list.length)document.getElementById("plan-watchlist").innerHTML=list.map(p=>`<div class="watchlist-item"><span>${p.name}</span><button type="button" data-remove-watch="${p.id}" aria-label="Remove ${p.name}">×</button></div>`).join("");document.querySelectorAll("[data-remove-watch]").forEach(b=>b.addEventListener("click",()=>{localStorage.setItem("lastseason-fantasy-watchlist",JSON.stringify(list.filter(p=>p.id!==b.dataset.removeWatch)));renderWatch()}));}catch{}};renderWatch();
    const renderNames=()=>{try{const names=JSON.parse(localStorage.getItem("lastseason-fantasy-saved-names")||"[]");if(names.length)document.getElementById("plan-names").innerHTML=names.map(name=>`<div class="watchlist-item"><span>${name.replace(/</g,"&lt;")}</span><button type="button" data-remove-name="${name.replace(/"/g,"&quot;")}" aria-label="Remove ${name.replace(/"/g,"&quot;")}">×</button></div>`).join("");document.querySelectorAll("[data-remove-name]").forEach(button=>button.addEventListener("click",()=>{localStorage.setItem("lastseason-fantasy-saved-names",JSON.stringify(names.filter(name=>name!==button.dataset.removeName)));renderNames()}));}catch{}};renderNames();
    try{const chips=JSON.parse(localStorage.getItem("lastseason-fantasy-chips")||"{}");const planned=Object.entries(chips).filter(([,gw])=>gw);if(planned.length)document.getElementById("plan-chips").innerHTML=planned.map(([name,gw])=>`<div class="watchlist-item"><span>${name}</span><strong>GW${gw}</strong></div>`).join("");}catch{}
    try{const transfers=JSON.parse(localStorage.getItem("lastseason-fantasy-transfers")||"[]");if(transfers.length)document.getElementById("plan-transfers").innerHTML=transfers.map(move=>`<div class="watchlist-item"><span>${move.out} → ${move.in}</span><strong>${move.delta>=0?"+":""}${Number(move.delta).toFixed(1)} cr</strong></div>`).join("");}catch{}
    const checkKey="lastseason-fantasy-checklist";let checks=[];try{checks=JSON.parse(localStorage.getItem(checkKey)||"[]")}catch{}document.querySelectorAll("[data-check]").forEach((box,i)=>{box.checked=Boolean(checks[i]);box.addEventListener("change",()=>{checks[i]=box.checked;localStorage.setItem(checkKey,JSON.stringify(checks))})});
    const countdown=document.querySelector("[data-plan-countdown]");const tick=()=>{const ms=new Date(countdown.dataset.kickoff).getTime()-Date.now();if(ms<=0){countdown.textContent="Season under way";return}const days=Math.floor(ms/86400000),hours=Math.floor(ms%86400000/3600000);countdown.textContent=`${days} days, ${hours} hours to kick-off`};tick();setInterval(tick,60000);
    document.getElementById("clear-plan")?.addEventListener("click",()=>{if(!confirm("Clear your saved fantasy squad, watchlist, team names, transfers, chips and checklist from this browser?"))return;["lastseason-fantasy-squad","lastseason-fantasy-watchlist","lastseason-fantasy-saved-names","lastseason-fantasy-transfers","lastseason-fantasy-chips","lastseason-fantasy-checklist"].forEach(key=>localStorage.removeItem(key));location.reload()});
  </script>
</Base>
