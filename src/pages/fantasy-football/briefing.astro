---
import Base from "../../layouts/Base.astro";import FantasyHeader from "../../components/FantasyHeader.astro";import FantasyDisclaimer from "../../components/FantasyDisclaimer.astro";import { fantasyDeadlineLabel, fantasyPositionChanges, fantasyRulesUrl, fantasyUpdated } from "../../data/fantasy";
const schema=JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"2026/27 fantasy football pre-season briefing","dateModified":"2026-07-23","author":{"@type":"Organization","name":"Last Season"},"mainEntityOfPage":"https://lastseason.co.uk/fantasy-football/briefing/"});
---
<Base title="Fantasy Football Pre-Season Briefing 2026/27" description="The latest independent fantasy briefing: confirmed Gameweek 1 deadline, eight-chip rules, position changes and the practical decisions to make next." canonical="/fantasy-football/briefing/" schema={schema} ogType="article">
  <FantasyHeader active="week"/><div class="fantasy-page"><section class="fantasy-hero fantasy-hero--compact"><div class="fantasy-container fantasy-hero__grid"><div class="fantasy-hero__copy"><span class="fantasy-eyebrow">Latest briefing · {fantasyUpdated}</span><h1>The deadline is real. Prices come next.</h1><p>Gameweek 1 now has a confirmed cut-off, all eight chips are confirmed and eleven players changed position. Here is what to act on—and what still deserves patience.</p></div><aside class="kickoff-card"><small>Confirmed deadline</small><strong>18:30 BST</strong><p>{fantasyDeadlineLabel}</p></aside></div></section>
    <section class="fantasy-section fantasy-section--tint"><div class="fantasy-container"><div class="ranking-list"><article class="ranking-card"><b>1</b><div><strong>Set the deadline reminder</strong><span>The official cut-off is 90 minutes before kick-off. Use the Control Room reminder and do the final role check one hour before lock.</span></div><a href="/fantasy-football/control-room/">Open →</a></article><article class="ranking-card"><b>2</b><div><strong>Plan the first four chips only through GW19</strong><span>The first Wildcard, Free Hit, Bench Boost and Triple Captain expire at the Gameweek 19 deadline.</span></div><a href="/fantasy-football/chip-planner/">Plan →</a></article><article class="ranking-card"><b>3</b><div><strong>Reprice positional expectations</strong><span>{fantasyPositionChanges.length} official changes alter clean-sheet and scoring routes. Historic output needs context.</span></div><a href="/fantasy-football/preseason-tracker/">Track →</a></article></div>
    <div class="fantasy-section__head" style="margin-top:2.5rem"><div><span class="fantasy-eyebrow">Do now / wait / ignore</span><h2>The decision board</h2></div></div><div class="fantasy-card-grid"><article class="fantasy-card fantasy-card--feature"><span>Do now</span><strong>Build for structure</strong><p>Create a balanced 15-player draft and run the Squad Doctor. Treat planning credits as a comparison tool.</p><small><a href="/fantasy-football/squad-doctor/">Diagnose draft →</a></small></article><article class="fantasy-card"><span>Wait</span><strong>Official player prices</strong><p>Do not mistake editorial planning values for launch prices. The squad pool will be refreshed when permissible official data arrives.</p><small><a href="/fantasy-football/updates/">Follow updates →</a></small></article><article class="fantasy-card"><span>Ignore</span><strong>False price-change certainty</strong><p>The official predictor begins after Gameweek 1 and updates every 15 minutes. Third-party certainty before then is not evidence.</p><small><a href={fantasyRulesUrl} rel="nofollow">Read official rules →</a></small></article></div>
    <div class="fantasy-next-step"><div><span class="fantasy-eyebrow">For the group chat</span><h2>Turn the weekly table into a report.</h2><p>Paste manager names and scores to make a ranked report with shareable awards.</p></div><a class="fantasy-button" href="/fantasy-football/mini-league-report/">Make a report</a></div><FantasyDisclaimer/></div></section></div>
</Base>
