---
import Base from "../../layouts/Base.astro";
import FantasyHeader from "../../components/FantasyHeader.astro";
import FantasyDisclaimer from "../../components/FantasyDisclaimer.astro";
import { fantasyPlayers, fantasyUpdated } from "../../data/fantasy";
const watched = fantasyPlayers.filter((player) => player.tags.some((tag) => ["penalties","set pieces","talisman"].includes(tag))).sort((a,b)=>b.evidence-a.evidence);
const schema=JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"Fantasy football penalty and set-piece takers watchlist 2026/27","dateModified":"2026-07-23","author":{"@type":"Organization","name":"Last Season"}});
---
<Base title="Fantasy Football Penalty & Set-Piece Takers 2026/27" description="A cautious 2026/27 fantasy football set-piece watchlist: penalty, corner and free-kick roles to verify through pre-season and early team sheets." canonical="/fantasy-football/set-piece-takers/" schema={schema} ogType="article">
  <FantasyHeader />
  <div class="fantasy-page"><div class="fantasy-tool-hero"><div class="fantasy-container"><nav class="fantasy-breadcrumbs"><a href="/fantasy-football/">Fantasy</a><span>/</span><span>Set-piece takers</span></nav><span class="fantasy-eyebrow">Role watch · {fantasyUpdated}</span><h1>Set pieces: verify, then value.</h1><p>This is a pre-season role watch—not a claim that every taker is confirmed. Penalties, corners and direct free-kicks matter only when the player is expected to start.</p></div></div>
  <section class="fantasy-section fantasy-section--tint"><div class="fantasy-container"><div class="fantasy-section__head"><div><span class="fantasy-eyebrow">Players to investigate</span><h2>Strongest role signals in the pool</h2></div><p>Labels describe why the player is being monitored, not an official set-piece order.</p></div><div class="ranking-list">{watched.map((player,index)=><article class="ranking-card"><b>{index+1}</b><div><strong>{player.name}</strong><span>{player.club} · {player.position} · {player.tags.filter((tag)=>["penalties","set pieces","talisman"].includes(tag)).join(" · ")}<br/>{player.note}</span></div><div class="ranking-score"><strong>{player.evidence}</strong><small>evidence</small></div></article>)}</div></div></section>
  <section class="fantasy-section"><div class="fantasy-container"><div class="fantasy-card-grid"><article class="fantasy-card"><span>Evidence</span><strong>Who took the last one?</strong><p>Use competitive matches first, then final friendlies. One pre-season kick is not proof of a permanent hierarchy.</p></article><article class="fantasy-card"><span>Availability</span><strong>Who will be on the pitch?</strong><p>A second-choice taker with secure minutes can be more useful than a nominal specialist who may not start.</p></article><article class="fantasy-card"><span>Change</span><strong>Who joined or left?</strong><p>Transfers and coaching changes can reset corners, free-kicks and penalties immediately.</p></article></div><div class="fantasy-next-step"><div><span class="fantasy-eyebrow">Keep it honest</span><h2>Watch the update log.</h2><p>Last Season records material role and assumption changes rather than silently rewriting them.</p></div><a class="fantasy-button fantasy-button--dark" href="/fantasy-football/updates/">See what changed</a></div><FantasyDisclaimer /></div></section></div>
</Base>
