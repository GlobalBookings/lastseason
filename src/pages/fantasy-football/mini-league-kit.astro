---
import Base from "../../layouts/Base.astro";
import FantasyHeader from "../../components/FantasyHeader.astro";
import FantasyDisclaimer from "../../components/FantasyDisclaimer.astro";
import { leagueNameIdeas, punishmentIdeas, prizeIdeas } from "../../data/fantasy";
const data=JSON.stringify({leagueNameIdeas,punishmentIdeas,prizeIdeas}).replace(/</g,"\\u003c");
---
<Base title="Fantasy Football Mini-League Name, Prize & Punishment Generator" description="Generate a funny fantasy football mini-league name, harmless last-place punishment and end-of-season prize for your group." canonical="/fantasy-football/mini-league-kit/">
  <FantasyHeader active="names" /><div class="fantasy-page"><div class="fantasy-tool-hero"><div class="fantasy-container"><nav class="fantasy-breadcrumbs"><a href="/fantasy-football/">Fantasy</a><span>/</span><span>Mini-league kit</span></nav><span class="fantasy-eyebrow">For the group chat</span><h1>Set the stakes without starting a war.</h1><p>A league name, a winner's prize and a harmless last-place punishment. No paid entry or account required.</p></div></div>
  <section class="fantasy-section"><div class="fantasy-container"><div class="fantasy-card-grid"><article class="fantasy-card fantasy-card--feature"><span>League name</span><strong id="league-result">The Expected Goals Society</strong><p>Copy it straight into your league setup.</p></article><article class="fantasy-card"><span>Winner receives</span><strong id="prize-result">A deliberately tiny trophy</strong><p>Keep it fun and affordable.</p></article><article class="fantasy-card"><span>Last place does</span><strong id="punishment-result">Write an apology to the winner</strong><p>Nothing dangerous, humiliating or expensive.</p></article></div><div class="fantasy-actions" style="margin-top:1rem"><button class="fantasy-button" id="regenerate-kit">Make another kit</button><button class="fantasy-button fantasy-button--dark" id="copy-kit">Copy all three</button></div><FantasyDisclaimer short /></div></section></div>
  <script is:inline type="application/json" id="league-kit-data" set:html={data}></script><script is:inline>const kit=JSON.parse(document.getElementById("league-kit-data")?.textContent||"{}");const pick=a=>a[Math.floor(Math.random()*a.length)];const render=()=>{document.getElementById("league-result").textContent=pick(kit.leagueNameIdeas);document.getElementById("prize-result").textContent=pick(kit.prizeIdeas);document.getElementById("punishment-result").textContent=pick(kit.punishmentIdeas);};document.getElementById("regenerate-kit")?.addEventListener("click",render);document.getElementById("copy-kit")?.addEventListener("click",()=>navigator.clipboard?.writeText(`${document.getElementById("league-result").textContent}\nPrize: ${document.getElementById("prize-result").textContent}\nLast place: ${document.getElementById("punishment-result").textContent}`));</script>
</Base>
