---
import Base from "../../layouts/Base.astro";
import FantasyHeader from "../../components/FantasyHeader.astro";
import FantasyDisclaimer from "../../components/FantasyDisclaimer.astro";
import { fantasyBonusChangesUrl, fantasyDeadline, fantasyDeadlineLabel, fantasyLiveRankingsUrl, fantasyPositionChanges, fantasyPositionChangesUrl, fantasyRulesUrl, fantasyUpdated } from "../../data/fantasy";
const changes = JSON.stringify(fantasyPositionChanges).replace(/</g,"\\u003c");
const schema=JSON.stringify({"@context":"https://schema.org","@type":"WebApplication","name":"Fantasy Football Control Room 2026/27","url":"https://lastseason.co.uk/fantasy-football/control-room/","applicationCategory":"SportsApplication","isAccessibleForFree":true});
---
<Base title="Fantasy Football Control Room 2026/27" description="Your 2026/27 fantasy deadline dashboard: confirmed deadline, chip rules, position changes, saved squad status and a practical next-action checklist." canonical="/fantasy-football/control-room/" schema={schema}>
  <FantasyHeader active="control"/>
  <div class="fantasy-page">
    <section class="fantasy-hero fantasy-hero--compact"><div class="fantasy-container fantasy-hero__grid"><div class="fantasy-hero__copy"><span class="fantasy-eyebrow">Deadline headquarters · reviewed {fantasyUpdated}</span><h1>Know what matters next.</h1><p>Confirmed rules, your private planning state and the handful of checks worth making before Gameweek 1.</p><div class="fantasy-actions"><a class="fantasy-button" href="/fantasy-football/squad-builder/">Build a draft</a><a class="fantasy-button fantasy-button--secondary" href="/fantasy-football/squad-doctor/">Run squad doctor</a></div></div><aside class="kickoff-card" data-deadline={fantasyDeadline}><small>Confirmed Gameweek 1 deadline</small><strong data-countdown>Calculating…</strong><p>{fantasyDeadlineLabel}</p></aside></div></section>
    <section class="fantasy-section fantasy-section--tint"><div class="fantasy-container"><div class="fantasy-section__head"><div><span class="fantasy-eyebrow">Your browser</span><h2>Planning pulse</h2></div><p>No login: these cards read only the plans saved on this device.</p></div><div class="fantasy-card-grid">
      <article class="fantasy-card"><span>Squad</span><strong id="pulse-squad">Checking…</strong><p id="pulse-squad-note">Looking for your saved draft.</p><small><a href="/fantasy-football/squad-builder/">Open builder →</a></small></article>
      <article class="fantasy-card"><span>Watchlist</span><strong id="pulse-watch">Checking…</strong><p>Players you marked for another look.</p><small><a href="/fantasy-football/preseason-tracker/">Open tracker →</a></small></article>
      <article class="fantasy-card"><span>Deadline checks</span><strong id="pulse-checks">Checking…</strong><p>Completion of your private pre-deadline checklist.</p><small><a href="/fantasy-football/my-plan/">Open my plan →</a></small></article>
    </div></div></section>
    <section class="fantasy-section"><div class="fantasy-container"><div class="fantasy-section__head"><div><span class="fantasy-eyebrow">Confirmed by the Premier League</span><h2>The rules that changed</h2></div></div><div class="fantasy-card-grid">
      <article class="fantasy-card fantasy-card--feature"><span>Deadline</span><strong>21 August, 18:30 BST</strong><p>Gameweek 1 locks 90 minutes before Arsenal v Coventry.</p><small><a href="/fantasy-kickoff-reminder.ics?v=2" download>Add one-hour reminder →</a></small></article>
      <a class="fantasy-card" href={fantasyRulesUrl} rel="nofollow"><span>Chips</span><strong>Two sets of four</strong><p>Wildcard, Free Hit, Bench Boost and Triple Captain refresh after the first half; set A expires at GW19.</p><small>Official announcement →</small></a>
      <a class="fantasy-card" href={fantasyPositionChangesUrl} rel="nofollow"><span>Positions</span><strong>11 players moved</strong><p>Several former defenders are now midfielders, changing clean-sheet and scoring expectations.</p><small>Official announcement →</small></a>
      <a class="fantasy-card" href={fantasyBonusChangesUrl} rel="nofollow"><span>Bonus points</span><strong>BPS retuned</strong><p>Being tackled no longer loses BPS; saves and attacking play get revised treatment, while some defensive actions earn less.</p><small>Official breakdown →</small></a>
      <a class="fantasy-card" href={fantasyLiveRankingsUrl} rel="nofollow"><span>Matchday</span><strong>Ranks update live</strong><p>League positions and projected bonus will move during matches, with final scores confirmed after the Gameweek locks.</p><small>Official breakdown →</small></a>
    </div></div></section>
    <section class="fantasy-section fantasy-section--tint"><div class="fantasy-container"><div class="fantasy-section__head"><div><span class="fantasy-eyebrow">Role changes</span><h2>Position-change board</h2></div><p>Do not compare a player with last season’s scoring without accounting for the new classification.</p></div><div class="fixture-scroll"><table class="fixture-table"><thead><tr><th>Player</th><th>Club</th><th>2025/26</th><th>2026/27</th></tr></thead><tbody>{fantasyPositionChanges.map(p=><tr><td>{p.player}</td><td>{p.club}</td><td>{p.previous}</td><td><strong>{p.current}</strong></td></tr>)}</tbody></table></div><div class="fantasy-next-step"><div><span class="fantasy-eyebrow">This week</span><h2>Build, diagnose, then wait for prices.</h2><p>Use planning credits for structure—not as claimed official prices. Return when official player prices launch and the pool is refreshed.</p></div><a class="fantasy-button" href="/fantasy-football/newsletter/">Get the briefing</a></div><FantasyDisclaimer/></div></section>
  </div>
  <script is:inline type="application/json" id="position-data" set:html={changes}></script>
  <script is:inline>
    const deadline=document.querySelector("[data-deadline]"),countdown=document.querySelector("[data-countdown]");const tick=()=>{const ms=new Date(deadline?.dataset.deadline).getTime()-Date.now();if(!countdown)return;if(ms<=0){countdown.textContent="Deadline passed";return}const d=Math.floor(ms/86400000),h=Math.floor(ms%86400000/3600000),m=Math.floor(ms%3600000/60000);countdown.textContent=`${d}d ${h}h ${m}m`};tick();setInterval(tick,60000);
    try{const squad=JSON.parse(localStorage.getItem("lastseason-fantasy-squad")||"null"),watch=JSON.parse(localStorage.getItem("lastseason-fantasy-watchlist")||"[]"),checks=JSON.parse(localStorage.getItem("lastseason-fantasy-checklist")||"[]");const ids=squad?.ids||[];document.getElementById("pulse-squad").textContent=ids.length?`${ids.length}/15 saved`:"No draft yet";document.getElementById("pulse-squad-note").textContent=ids.length===15?"Ready for a diagnosis.":"Build all 15 positions before diagnosing.";document.getElementById("pulse-watch").textContent=`${watch.length} watched`;document.getElementById("pulse-checks").textContent=`${checks.filter(Boolean).length}/5 complete`;}catch{}
  </script>
</Base>
