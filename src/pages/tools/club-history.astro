---
import Base from "../../layouts/Base.astro";
import { getAllLoadedSeasons } from "../../utils/data";
const map = new Map<string, { name: string; entries: { season: string; league: string; position: number; points: number; url: string }[] }>();
for (const season of getAllLoadedSeasons()) for (const row of season.standings) { const club = map.get(row.clubSlug) ?? { name: row.club, entries: [] }; club.entries.push({ season: season.seasonDisplay, league: season.league, position: row.pos, points: row.pts, url: `/${season.leagueSlug}/${season.season}/` }); map.set(row.clubSlug, club); }
const clubs = [...map].map(([id, club]) => ({ id, ...club, entries: club.entries.sort((a, b) => a.season.localeCompare(b.season)) })).sort((a, b) => a.name.localeCompare(b.name));
const json = JSON.stringify(clubs).replace(/</g, "\\u003c");
---

<Base title="Football Club History Explorer" description="Explore club finishing positions and points across the reviewed Last Season archive." canonical="/tools/club-history/">
  <div class="container prose">
    <nav class="breadcrumbs"><a href="/">Home</a><span class="sep">/</span><a href="/tools/">Tools</a><span class="sep">/</span><span class="current">Club history</span></nav>
    <section class="page-hero"><h1>Club history explorer</h1><p class="subtitle">Follow a club's league finishes across the published archive.</p></section>
    <section class="tool-panel"><label>Club<select id="club-select"></select></label><div id="club-output" class="tool-output" aria-live="polite"></div></section>
  </div>
  <script is:inline type="application/json" id="club-data" set:html={json}></script>
  <script is:inline>
    const clubs = JSON.parse(document.getElementById("club-data")?.textContent || "[]"), select = document.getElementById("club-select"), output = document.getElementById("club-output");
    for (const club of clubs) { const option = document.createElement("option"); option.value = club.id; option.textContent = club.name; select.append(option); }
    const params = new URLSearchParams(location.search); select.value = params.get("club") || clubs[0]?.id || "";
    const render = () => { const club = clubs.find((c) => c.id === select.value); if (!club) return; const width = 720, height = 230, pad = 30, max = Math.max(20, ...club.entries.map((e) => e.position)); const points = club.entries.map((e,i) => `${pad + (club.entries.length === 1 ? (width-2*pad)/2 : i*(width-2*pad)/(club.entries.length-1))},${pad+(e.position-1)*(height-2*pad)/(max-1)}`).join(" "); output.innerHTML = `<h2>${club.name}</h2><div class="chart-wrap"><svg class="history-chart" viewBox="0 0 ${width} ${height}" role="img" aria-label="${club.name} finishing positions"><line x1="${pad}" y1="${pad}" x2="${width-pad}" y2="${pad}"/><line x1="${pad}" y1="${height-pad}" x2="${width-pad}" y2="${height-pad}"/><polyline points="${points}"/></svg></div><div class="table-wrap"><table class="stats-table"><thead><tr><th>Season</th><th>League</th><th class="num">Position</th><th class="num">Points</th></tr></thead><tbody>${club.entries.map((e) => `<tr><td><a href="${e.url}">${e.season}</a></td><td>${e.league}</td><td class="num"><strong>${e.position}</strong></td><td class="num">${e.points}</td></tr>`).join("")}</tbody></table></div>`; const url = new URL(location.href); url.searchParams.set("club", club.id); history.replaceState({}, "", url); };
    select.addEventListener("change", render); render();
  </script>
</Base>
