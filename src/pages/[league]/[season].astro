---
import Base from "../../layouts/Base.astro";
import StandingsTable from "../../components/StandingsTable.astro";
import ScorersTable from "../../components/ScorersTable.astro";
import AssistersTable from "../../components/AssistersTable.astro";
import CleanSheetsTable from "../../components/CleanSheetsTable.astro";
import Awards from "../../components/Awards.astro";
import RelegationPromotion from "../../components/RelegationPromotion.astro";
import DataNotice from "../../components/DataNotice.astro";
import { getSeasonData, getAdjacentSeasons, getLeague, getAllSeasonPaths, unverifiedSeasonKeys } from "../../utils/data";
import { buildSeasonSchema } from "../../utils/schema";

export function getStaticPaths() {
  return getAllSeasonPaths().map(({ leagueSlug, season }) => ({
    params: { league: leagueSlug, season },
    props: { leagueSlug, season },
  }));
}

const { leagueSlug, season } = Astro.props;
const data = getSeasonData(leagueSlug, season);
const league = getLeague(leagueSlug);
const { prev, next } = getAdjacentSeasons(leagueSlug, season);

if (!data || !league) {
  return Astro.redirect("/404");
}

const narrativeParagraphs = data.narrative.split("\n\n").filter(Boolean);
const isUnverified = unverifiedSeasonKeys.has(`${leagueSlug}/${season}`);
const schema = isUnverified ? undefined : buildSeasonSchema(data);

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lastseason.co.uk/" },
    { "@type": "ListItem", "position": 2, "name": data.league, "item": `https://lastseason.co.uk/${leagueSlug}/` },
    { "@type": "ListItem", "position": 3, "name": data.seasonDisplay },
  ],
});

---

<Base
  title={data.metaTitle}
  description={data.metaDescription}
  canonical={`/${leagueSlug}/${season}/`}
  schema={schema}
  accentColor={league.accentColor}
  robots={isUnverified ? "noindex, follow" : undefined}
>
  <script is:inline type="application/ld+json" set:html={breadcrumbSchema} />

  <div class="container">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <a href={`/${leagueSlug}/`}>{data.league}</a>
      <span class="sep">/</span>
      <span class="current">{data.seasonDisplay}</span>
    </nav>

    <section class="page-hero">
      <h1>{data.league} {data.seasonDisplay}</h1>
      <p class="subtitle">Final table, top scorers, season awards and full review.</p>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-value">{data.champion}</span>
          <span class="hero-stat-label">Champion</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">{data.topScorer}</span>
          <span class="hero-stat-label">Top Scorer ({data.topScorerGoals} goals)</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">{data.totalGoals.toLocaleString()}</span>
          <span class="hero-stat-label">Total Goals</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">{data.standings.length}</span>
          <span class="hero-stat-label">Clubs</span>
        </div>
      </div>
    </section>

    <DataNotice leagueSlug={leagueSlug} status={isUnverified ? "review" : "verified"} />

    <div class="tool-actions section" aria-label="Explore and download this season">
      <a class="button" href={`/tools/season-compare/?a=${leagueSlug}-${season}`}>Compare this season</a>
      <a class="button button--secondary" href={`/tools/table-calculator/?season=${leagueSlug}-${season}`}>Recalculate table</a>
      {!isUnverified && <a class="button button--secondary" href={`/data/${leagueSlug}/${season}.csv`} download>Download table CSV</a>}
      <button type="button" class="button button--secondary favourite-button" data-favourite-league={leagueSlug} aria-pressed="false"><span aria-hidden="true">★</span><span data-favourite-label>Save league</span></button>
    </div>

    <section class="section" id="table">
      <h2 class="section-title">Final Table</h2>
      <StandingsTable standings={data.standings} leagueSlug={leagueSlug} linkClubs={!isUnverified} />
    </section>

    <ScorersTable scorers={data.scorers} linkEntities={!isUnverified} />
    <AssistersTable assisters={data.assisters} linkEntities={!isUnverified} />
    <CleanSheetsTable cleanSheets={data.cleanSheets} linkEntities={!isUnverified} />
    <Awards awards={data.awards} linkEntities={!isUnverified} />

    <section class="section" id="review">
      <h2 class="section-title">Season Review</h2>
      <div class="narrative">
        {narrativeParagraphs.map((p) => <p>{p}</p>)}
      </div>
    </section>

    <RelegationPromotion relegated={data.relegated} promoted={data.promoted} />

    {data.notableMoments.length > 0 && (
      <section class="section">
        <h2 class="section-title">Notable Moments</h2>
        <ul class="moments-list">
          {data.notableMoments.map((moment) => (
            <li>{moment}</li>
          ))}
        </ul>
      </section>
    )}

    {data.sources && data.sources.length > 0 && (
      <section class="section source-notes" aria-labelledby="source-notes-title">
        <h2 class="section-title" id="source-notes-title">Sources</h2>
        <p>Final-table and headline facts were checked against the following published sources:</p>
        <ul>
          {data.sources.map((source) => (
            <li><a href={source.url} rel="nofollow noopener" target="_blank">{source.name}</a></li>
          ))}
        </ul>
      </section>
    )}

    <nav class="season-nav" aria-label="Season navigation">
      {prev ? (
        <a href={`/${leagueSlug}/${prev}/`}>&larr; {prev}</a>
      ) : (
        <span></span>
      )}
      <a href={`/${leagueSlug}/`}>All {data.league} seasons</a>
      {next ? (
        <a href={`/${leagueSlug}/${next}/`}>{next} &rarr;</a>
      ) : (
        <span></span>
      )}
    </nav>
  </div>
</Base>
