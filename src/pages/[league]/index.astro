---
import Base from "../../layouts/Base.astro";
import SeasonCard from "../../components/SeasonCard.astro";
import { leagues } from "../../data/leagues/index";
import { getSeasonData } from "../../utils/data";

export function getStaticPaths() {
  return leagues.map((l) => ({
    params: { league: l.slug },
    props: { league: l },
  }));
}

const { league } = Astro.props;
const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lastseason.co.uk/" },
    { "@type": "ListItem", "position": 2, "name": league.name },
  ],
});
---

<Base
  title={`${league.name} — All Seasons, Tables & Stats`}
  description={`Every archived season for the ${league.name}. Final tables, top scorers, relegation, promotion and full season reviews.`}
  canonical={`/${league.slug}/`}
  accentColor={league.accentColor}
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <div class="container">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <span class="current">{league.name}</span>
    </nav>

    <section class="page-hero">
      <h1>{league.name}</h1>
      <p class="subtitle">{league.country} &mdash; {league.seasons.length} seasons archived</p>
    </section>

    <section class="section">
      <h2 class="section-title">All Seasons</h2>
      <div class="card-grid">
        {league.seasons.map((season: string) => {
          const data = getSeasonData(league.slug, season);
          return data ? (
            <SeasonCard
              leagueSlug={league.slug}
              season={data.season}
              champion={data.champion}
              topScorer={data.topScorer}
              topScorerGoals={data.topScorerGoals}
              totalGoals={data.totalGoals}
              accentColor={league.accentColor}
            />
          ) : (
            <div class="card card-accent" style={`border-top-color: ${league.accentColor}`}>
              <span class="card-tag">{season}</span>
              <p class="meta">Data coming soon</p>
            </div>
          );
        })}
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">Other Leagues</h2>
      <div class="card-grid">
        {leagues
          .filter((l) => l.slug !== league.slug)
          .map((l) => (
            <a href={`/${l.slug}/`} class="card card-accent" style={`border-top-color: ${l.accentColor}`}>
              <span class="card-tag">{l.country}</span>
              <h3>{l.name}</h3>
              <p class="meta">{l.seasons.length} seasons archived</p>
            </a>
          ))}
      </div>
    </section>
  </div>
</Base>
