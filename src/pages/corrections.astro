---
import Base from "../layouts/Base.astro";
---

<Base
  title="Corrections & Data Feedback"
  description="Report a football data error or suggest a primary source for the Last Season archive."
  canonical="/corrections/"
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Breadcrumb"><a href="/">Home</a><span class="sep">/</span><span class="current">Corrections</span></nav>
    <section class="page-hero">
      <h1>Corrections & data feedback</h1>
      <p class="subtitle">Football archives improve when errors are easy to report.</p>
    </section>
    <article class="prose section">
      <p>If you spot an incorrect table entry, scorer total, club name or historical detail, email <a href="mailto:corrections@lastseason.co.uk?subject=Last%20Season%20data%20correction">corrections@lastseason.co.uk</a>.</p>
      <h2>Please include</h2>
      <ul>
        <li>The Last Season page URL.</li>
        <li>The exact field or sentence that should change.</li>
        <li>The corrected value.</li>
        <li>A league, club, governing-body or other primary source where possible.</li>
      </ul>
      <p class="callout">Material corrections should be made in the shared data record, not patched only in the visible page, so every derived tool and profile stays consistent.</p>
    </article>
  </div>
</Base>
