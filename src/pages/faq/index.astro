---
import Base from "../../layouts/Base.astro";

const faqPages = [
  { href: "/faq/premier-league/", title: "Premier League FAQ", desc: "How many teams, who has won the most titles, how relegation works, the Big Six, and everything else fans ask about the Premier League." },
  { href: "/faq/transfers-and-money/", title: "Transfers & Money FAQ", desc: "The most expensive transfers ever, how fees work, Financial Fair Play, release clauses, free agents and footballer salaries explained." },
  { href: "/faq/champions-league/", title: "Champions League FAQ", desc: "How the Champions League works, who has won the most titles, qualification rules, prize money and all-time records." },
  { href: "/faq/world-football/", title: "World Football FAQ", desc: "The English football pyramid, promotion and relegation, the FA Cup, League Cup, World Cup, Ballon d'Or and international football." },
  { href: "/faq/rules-and-format/", title: "Football Rules FAQ", desc: "Offside, VAR, substitutions, extra time, penalty shootouts, yellow and red cards  -  every rule explained in plain English." },
];

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lastseason.co.uk/" },
    { "@type": "ListItem", "position": 2, "name": "FAQ" }
  ]
});
---

<Base
  title="Football FAQ  -  Answers to the Most Searched Football Questions"
  description="Answers to the most commonly searched football questions. Premier League rules, transfers, Champions League, world football, and the laws of the game  -  all explained."
  canonical="/faq/"
  robots="noindex, follow"
>
  <script is:inline type="application/ld+json" set:html={breadcrumbSchema} />

  <div class="container">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <span class="current">FAQ</span>
    </nav>

    <section class="page-hero">
      <h1>Football FAQ</h1>
      <p class="subtitle">Answers to the most searched football questions  -  from Premier League basics to transfer rules, Champions League history and the laws of the game.</p>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-value">5</span>
          <span class="hero-stat-label">Topics Covered</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">55+</span>
          <span class="hero-stat-label">Questions Answered</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">Plain</span>
          <span class="hero-stat-label">English Answers</span>
        </div>
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">Browse by Topic</h2>
      <div class="card-grid">
        {faqPages.map((page) => (
          <a href={page.href} class="card">
            <h3>{page.title}</h3>
            <p class="meta">{page.desc}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">About Our FAQ</h2>
      <div class="narrative">
        <p>These pages answer the questions that millions of football fans search for every month. Whether you're new to the sport or settling a debate with a mate, we've got you covered with clear, accurate answers backed by data.</p>
        <p>Rules and competitions change, so check the governing body's current regulations before relying on an answer. For source scope and corrections, see our <a href="/methodology/">methodology</a>. For deeper dives, visit <a href="/records/">Records &amp; Stats</a> or a <a href="/premier-league/">league archive</a>.</p>
      </div>
    </section>
  </div>
</Base>
