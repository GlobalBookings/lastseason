---
import Base from "../layouts/Base.astro";
import SeasonCard from "../components/SeasonCard.astro";
import { leagues } from "../data/leagues/index";
import { getSeasonData } from "../utils/data";
---

<Base
  title="Every Season. Every Stat."
  description="Last season's football stats archived. Final tables, top scorers, season reviews for the Premier League, La Liga, Bundesliga, Serie A and more."
  canonical="/"
>
  <div class="container">
    <section class="page-hero">
      <h1>Every season. Every stat.</h1>
      <p class="subtitle">Last season's football, archived.</p>
    </section>

    {leagues.map((league) => {
      const latestSeason = league.seasons[0];
      const data = getSeasonData(league.slug, latestSeason);
      return (
        <section class="section">
          <h2 class="section-title">
            <a href={`/${league.slug}/`}>{league.name}</a>
          </h2>
          {data ? (
            <div class="card-grid">
              <SeasonCard
                leagueSlug={league.slug}
                season={data.season}
                champion={data.champion}
                topScorer={data.topScorer}
                topScorerGoals={data.topScorerGoals}
                totalGoals={data.totalGoals}
                accentColor={league.accentColor}
              />
              {league.seasons.slice(1, 3).map((s) => {
                const sd = getSeasonData(league.slug, s);
                return sd ? (
                  <SeasonCard
                    leagueSlug={league.slug}
                    season={sd.season}
                    champion={sd.champion}
                    topScorer={sd.topScorer}
                    topScorerGoals={sd.topScorerGoals}
                    accentColor={league.accentColor}
                  />
                ) : null;
              })}
            </div>
          ) : (
            <p class="meta">Season data coming soon.</p>
          )}
        </section>
      );
    })}
  </div>
</Base>
