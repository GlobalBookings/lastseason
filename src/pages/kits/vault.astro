---
import Base from "../../layouts/Base.astro";import KitIllustration from "../../components/KitIllustration.astro";import { allClubKitArchives } from "../../data/kits/index";
const clubs=allClubKitArchives.map(c=>({club:c.club,slug:c.clubSlug,league:c.league,leagueSlug:c.leagueSlug,count:c.kits.length,kit:c.kits.find(k=>k.type==="home")||c.kits[0]})).filter(c=>c.kit);
const leagues=[...new Set(clubs.map(c=>c.league))].sort();
const payload=JSON.stringify(clubs.map(({club,slug,league,count})=>({club,slug,league,count}))).replace(/</g,"\\u003c");
---
<Base title="My Football Shirt Kit Vault" description="Browse football club kit timelines and build a private owned-and-wanted shirt vault in your browser. Generated colour studies, not authenticated reproductions." canonical="/kits/vault/">
  <div class="container vault-page"><header class="page-hero"><span class="section-kicker">Your private collection</span><h1>Build your kit vault.</h1><p class="subtitle">Browse the archive by club, mark the shirts you own or want, and return to your collection on this device. The artwork is illustrative—not an authenticated shirt reproduction.</p><div class="vault-summary"><strong id="owned-count">0 owned</strong><strong id="wanted-count">0 wanted</strong><span>Saved only in this browser</span></div></header>
    <section class="vault-controls"><label>Search clubs<input id="vault-search" type="search" placeholder="Arsenal, Milan, Dortmund…"/></label><label>League<select id="vault-league"><option value="">All leagues</option>{leagues.map(l=><option value={l}>{l}</option>)}</select></label></section>
    <section class="vault-grid" id="vault-grid">{clubs.map(c=><article class="vault-card" data-search={`${c.club} ${c.league}`.toLowerCase()} data-league={c.league} data-slug={c.slug}><a href={`/kits/${c.slug}/`}><KitIllustration primary={c.kit.primaryColor} secondary={c.kit.secondaryColor} tertiary={c.kit.tertiaryColor} size="sm"/><span>{c.league} · {c.count} kits</span><strong>{c.club}</strong></a><div><button data-vault="owned">I own shirts</button><button data-vault="wanted">Want list</button></div></article>)}</section><p id="vault-status" class="data-notice">Showing {clubs.length} club archives.</p>
    <section class="tool-cta"><h2>Buying a shirt?</h2><p>Use the condition, authenticity and sizing checks before spending money. Retail links stay editorially separate from the collection tool.</p><a class="button" href="/football-shirts/">Read the football shirt guide</a></section>
  </div>
  <script is:inline type="application/json" id="vault-data" set:html={payload}></script><script is:inline>
    let state={owned:[],wanted:[]};try{state=JSON.parse(localStorage.getItem("lastseason-kit-vault")||"null")||state}catch{}const cards=[...document.querySelectorAll(".vault-card")],search=document.getElementById("vault-search"),league=document.getElementById("vault-league");function render(){document.getElementById("owned-count").textContent=`${state.owned.length} owned`;document.getElementById("wanted-count").textContent=`${state.wanted.length} wanted`;cards.forEach(card=>card.querySelectorAll("[data-vault]").forEach(b=>b.setAttribute("aria-pressed",String(state[b.dataset.vault].includes(card.dataset.slug)))))}function filter(){let n=0;cards.forEach(c=>{const show=c.dataset.search.includes(search.value.toLowerCase())&&(!league.value||c.dataset.league===league.value);c.hidden=!show;if(show)n++});document.getElementById("vault-status").textContent=`Showing ${n} club archive${n===1?"":"s"}.`}document.querySelectorAll("[data-vault]").forEach(b=>b.addEventListener("click",()=>{const key=b.dataset.vault,slug=b.closest("[data-slug]").dataset.slug;state[key]=state[key].includes(slug)?state[key].filter(x=>x!==slug):[...state[key],slug];localStorage.setItem("lastseason-kit-vault",JSON.stringify(state));render()}));search?.addEventListener("input",filter);league?.addEventListener("change",filter);render();
  </script>
</Base>
<style>
.vault-page{padding-bottom:5rem}.vault-summary{display:flex;gap:.6rem;flex-wrap:wrap;margin-top:1rem}.vault-summary>*{padding:.5rem .75rem;border-radius:999px;background:#edf6f0;color:#245d3c}.vault-controls{display:grid;grid-template-columns:1fr 1fr;gap:.8rem;margin:1.5rem 0}.vault-controls label{display:grid;gap:.35rem;font-size:.75rem;font-weight:800}.vault-controls input,.vault-controls select{min-height:46px;border:1px solid var(--border);border-radius:10px;padding:.7rem;background:#fff}.vault-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:.7rem}.vault-card{display:grid;border:1px solid var(--border);border-radius:16px;background:#fff;overflow:hidden}.vault-card>a{display:grid;min-height:210px;padding:1rem;color:var(--text)}.vault-card>a span{margin-top:auto;color:var(--text-muted);font-size:.7rem}.vault-card>a strong{font-size:1.1rem}.vault-card>div{display:grid;grid-template-columns:1fr 1fr;border-top:1px solid var(--border)}.vault-card button{border:0;background:#f5f6f3;padding:.7rem;font-weight:800;cursor:pointer}.vault-card button[aria-pressed=true]{background:#17251f;color:#d5ff54}.vault-card button+button{border-left:1px solid var(--border)}@media(max-width:650px){.vault-controls{grid-template-columns:1fr}}
</style>
