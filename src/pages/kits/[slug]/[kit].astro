---
import Base from "../../../layouts/Base.astro";
import KitIllustration from "../../../components/KitIllustration.astro";
import { allClubKitArchives } from "../../../data/kits/index";
import { leagues } from "../../../data/leagues/index";

export function getStaticPaths() {
  const paths: any[] = [];
  for (const club of allClubKitArchives) {
    for (const kit of club.kits) {
      paths.push({
        params: { slug: club.clubSlug, kit: `${kit.season}-${kit.type}` },
        props: { club, kit },
      });
    }
  }
  return paths;
}

const { club, kit } = Astro.props;
const league = leagues.find(l => l.slug === club.leagueSlug);
const typeLabel: Record<string, string> = { home: "Home Kit", away: "Away Kit", third: "Third Kit", goalkeeper: "Goalkeeper Kit" };
const label = typeLabel[kit.type] || kit.type;

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lastseason.co.uk/" },
    { "@type": "ListItem", "position": 2, "name": "Kits", "item": "https://lastseason.co.uk/kits/" },
    { "@type": "ListItem", "position": 3, "name": club.club, "item": `https://lastseason.co.uk/kits/${club.clubSlug}/` },
    { "@type": "ListItem", "position": 4, "name": `${kit.season} ${label}` },
  ],
});

const otherKitsSameSeason = club.kits.filter(k => k.season === kit.season && k.type !== kit.type);
const adjacentSeasons = [...new Set(club.kits.map(k => k.season))].sort((a, b) => b.localeCompare(a));
const currentIdx = adjacentSeasons.indexOf(kit.season);
const prevSeason = currentIdx < adjacentSeasons.length - 1 ? adjacentSeasons[currentIdx + 1] : null;
const nextSeason = currentIdx > 0 ? adjacentSeasons[currentIdx - 1] : null;

const cfsUrl = `https://www.classicfootballshirts.co.uk/search?q=${encodeURIComponent(`${club.club} ${kit.season}`)}`;
const vfsUrl = `https://www.vintagefootballshirts.com/search?q=${encodeURIComponent(`${club.club} ${kit.season}`)}`;
const ebayUrl = `https://www.ebay.co.uk/sch/i.html?_nkw=${encodeURIComponent(`${club.club} ${kit.season} ${kit.type} shirt football`)}&_sacat=0&LH_TitleDesc=0&rt=nc`;
const ebayRetroUrl = `https://www.ebay.co.uk/sch/i.html?_nkw=${encodeURIComponent(`${club.club} ${kit.season} ${kit.type} shirt retro original`)}&_sacat=0&LH_TitleDesc=0`;
const typeShort: Record<string, string> = { home: "Home", away: "Away", third: "Third", goalkeeper: "GK" };
---

<Base
  title={`${club.club} ${kit.season} ${label} — ${kit.manufacturer}`}
  description={`${club.club} ${kit.season} ${label.toLowerCase()} made by ${kit.manufacturer}${kit.sponsor ? `, sponsored by ${kit.sponsor}` : ""}. Find where to buy this shirt on eBay, Classic Football Shirts and other retailers.`}
  canonical={`/kits/${club.clubSlug}/${kit.season}-${kit.type}/`}
  accentColor={league?.accentColor}
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <div class="container">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <a href="/kits/">Kits</a>
      <span class="sep">/</span>
      <a href={`/kits/${club.clubSlug}/`}>{club.club}</a>
      <span class="sep">/</span>
      <span class="current">{kit.season} {label}</span>
    </nav>

    <section class="page-hero">
      <h1>{club.club}<br />{kit.season} {label}</h1>
      <p class="subtitle">
        Made by <strong>{kit.manufacturer}</strong>
        {kit.sponsor && <span> &mdash; Sponsored by <strong>{kit.sponsor}</strong></span>}
      </p>
    </section>

    <div class="kit-detail-layout">
      <div class="kit-visual-panel">
        <div class="kit-visual-card">
          <KitIllustration
            primary={kit.primaryColor}
            secondary={kit.secondaryColor}
            tertiary={kit.tertiaryColor}
            type={kit.type}
            size="lg"
            manufacturer={kit.manufacturer}
          />
          <div class="kit-visual-label">
            <span class="kit-visual-season">{kit.season}</span>
            <span class="kit-visual-type">{label}</span>
          </div>
        </div>

        <div class="kit-colour-bar">
          <div class="kit-colour-chip" style={`background:${kit.primaryColor}`}>
            <span>Primary</span>
          </div>
          <div class="kit-colour-chip" style={`background:${kit.secondaryColor}`}>
            <span>Secondary</span>
          </div>
          {kit.tertiaryColor && (
            <div class="kit-colour-chip" style={`background:${kit.tertiaryColor}`}>
              <span>Accent</span>
            </div>
          )}
        </div>

        {otherKitsSameSeason.length > 0 && (
          <div class="kit-other-season">
            <span class="kit-other-label">Also from {kit.season}</span>
            <div class="kit-other-row">
              {otherKitsSameSeason.map((k) => (
                <a href={`/kits/${club.clubSlug}/${k.season}-${k.type}/`} class="kit-other-item">
                  <KitIllustration
                    primary={k.primaryColor}
                    secondary={k.secondaryColor}
                    tertiary={k.tertiaryColor}
                    type={k.type}
                    size="sm"
                  />
                  <span class="kit-other-type">{typeShort[k.type]}</span>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

      <div class="kit-info-panel">
        <div class="section">
          <h2 class="section-title">Kit Details</h2>
          <div class="kit-specs">
            <div class="kit-spec-row">
              <span class="kit-spec-label">Club</span>
              <span class="kit-spec-value"><a href={`/clubs/${club.clubSlug}/`}>{club.club}</a></span>
            </div>
            <div class="kit-spec-row">
              <span class="kit-spec-label">Season</span>
              <span class="kit-spec-value">{kit.season}</span>
            </div>
            <div class="kit-spec-row">
              <span class="kit-spec-label">Type</span>
              <span class="kit-spec-value">{label}</span>
            </div>
            <div class="kit-spec-row">
              <span class="kit-spec-label">Manufacturer</span>
              <span class="kit-spec-value">{kit.manufacturer}</span>
            </div>
            {kit.sponsor && (
              <div class="kit-spec-row">
                <span class="kit-spec-label">Sponsor</span>
                <span class="kit-spec-value">{kit.sponsor}</span>
              </div>
            )}
            <div class="kit-spec-row">
              <span class="kit-spec-label">League</span>
              <span class="kit-spec-value"><a href={`/${club.leagueSlug}/`}>{club.league}</a></span>
            </div>
          </div>
        </div>

        <div class="section">
          <h2 class="section-title">Where to Buy</h2>
          <div class="kit-buy-stack">
            <a href={cfsUrl} rel="nofollow sponsored" target="_blank" class="kit-buy-btn kit-buy-featured">
              <div>
                <span class="kit-buy-name">Classic Football Shirts</span>
                <span class="kit-buy-desc">Authenticated vintage kits</span>
              </div>
              <span class="kit-buy-arrow">&rarr;</span>
            </a>
            <a href={ebayUrl} rel="nofollow sponsored" target="_blank" class="kit-buy-btn">
              <div>
                <span class="kit-buy-name">eBay</span>
                <span class="kit-buy-desc">New & used shirts</span>
              </div>
              <span class="kit-buy-arrow">&rarr;</span>
            </a>
            <a href={ebayRetroUrl} rel="nofollow sponsored" target="_blank" class="kit-buy-btn">
              <div>
                <span class="kit-buy-name">eBay &mdash; Retro Originals</span>
                <span class="kit-buy-desc">Authentic vintage shirts</span>
              </div>
              <span class="kit-buy-arrow">&rarr;</span>
            </a>
            <a href={vfsUrl} rel="nofollow sponsored" target="_blank" class="kit-buy-btn">
              <div>
                <span class="kit-buy-name">Vintage Football Shirts</span>
                <span class="kit-buy-desc">Retro & classic kits</span>
              </div>
              <span class="kit-buy-arrow">&rarr;</span>
            </a>
          </div>
          <p class="kit-buy-disclaimer">
            Illustration is a stylised representation of kit colours, not the actual design. Links open external sites. We may earn commission from qualifying purchases.
          </p>
        </div>
      </div>
    </div>

    <nav class="season-nav" aria-label="Kit season navigation">
      {prevSeason ? (
        <a href={`/kits/${club.clubSlug}/${prevSeason}-${kit.type}/`}>&larr; {prevSeason}</a>
      ) : <span></span>}
      <a href={`/kits/${club.clubSlug}/`}>All {club.club} kits</a>
      {nextSeason ? (
        <a href={`/kits/${club.clubSlug}/${nextSeason}-${kit.type}/`}>{nextSeason} &rarr;</a>
      ) : <span></span>}
    </nav>
  </div>
</Base>

<style>
  .kit-detail-layout {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 2.5rem;
    margin-bottom: 2rem;
  }
  .kit-visual-panel {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .kit-visual-card {
    background: var(--bg-alt);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 2rem 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .kit-visual-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }
  .kit-visual-season {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }
  .kit-visual-type {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
  }
  .kit-colour-bar {
    display: flex;
    gap: 0.5rem;
  }
  .kit-colour-chip {
    flex: 1;
    height: 36px;
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid rgba(0,0,0,0.08);
  }
  .kit-colour-chip span {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #fff;
    text-shadow: 0 1px 3px rgba(0,0,0,0.4);
    mix-blend-mode: normal;
  }
  .kit-other-season {
    background: var(--bg-alt);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 1rem;
  }
  .kit-other-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    display: block;
    margin-bottom: 0.65rem;
  }
  .kit-other-row { display: flex; gap: 0.75rem; }
  .kit-other-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    text-decoration: none;
    padding: 0.5rem;
    border-radius: var(--radius);
    transition: all 0.15s;
  }
  .kit-other-item:hover { background: rgba(0,0,0,0.03); text-decoration: none; }
  .kit-other-type {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-secondary);
  }
  .kit-info-panel { display: flex; flex-direction: column; gap: 0; }
  .kit-specs {
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .kit-spec-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--border-light);
    font-size: 0.88rem;
  }
  .kit-spec-row:last-child { border-bottom: none; }
  .kit-spec-row:nth-child(even) { background: var(--bg-alt); }
  .kit-spec-label { color: var(--text-muted); font-weight: 500; }
  .kit-spec-value { font-weight: 600; color: var(--text); }
  .kit-spec-value a { color: var(--text); }
  .kit-spec-value a:hover { color: var(--link); }
  .kit-buy-stack { display: flex; flex-direction: column; gap: 0.5rem; }
  .kit-buy-btn {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.85rem 1.1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all 0.2s;
    color: var(--text);
  }
  .kit-buy-btn:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
    text-decoration: none;
    transform: translateY(-1px);
  }
  .kit-buy-featured {
    border-color: var(--accent);
    background: rgba(61, 25, 91, 0.03);
  }
  .kit-buy-name { font-weight: 700; font-size: 0.9rem; display: block; }
  .kit-buy-desc { font-size: 0.72rem; color: var(--text-muted); display: block; margin-top: 0.1rem; }
  .kit-buy-arrow { font-size: 1rem; color: var(--link); font-weight: 700; flex-shrink: 0; }
  .kit-buy-disclaimer {
    font-size: 0.68rem;
    color: var(--text-muted);
    margin-top: 0.85rem;
    line-height: 1.5;
    font-style: italic;
  }
  @media (max-width: 768px) {
    .kit-detail-layout {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .kit-visual-card { padding: 1.5rem 1rem 1rem; }
  }
</style>
