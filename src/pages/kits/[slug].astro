---
import Base from "../../layouts/Base.astro";
import KitIllustration from "../../components/KitIllustration.astro";
import { allClubKitArchives } from "../../data/kits/index";
import { leagues } from "../../data/leagues/index";

export function getStaticPaths() {
  return allClubKitArchives.map((club) => ({
    params: { slug: club.clubSlug },
    props: { club },
  }));
}

const { club } = Astro.props;
const league = leagues.find(l => l.slug === club.leagueSlug);

const kitsBySeason = new Map<string, typeof club.kits>();
for (const kit of club.kits) {
  if (!kitsBySeason.has(kit.season)) kitsBySeason.set(kit.season, []);
  kitsBySeason.get(kit.season)!.push(kit);
}
const seasons = [...kitsBySeason.keys()].sort((a, b) => b.localeCompare(a));
const manufacturers = [...new Set(club.kits.map(k => k.manufacturer))];

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lastseason.co.uk/" },
    { "@type": "ListItem", "position": 2, "name": "Kits", "item": "https://lastseason.co.uk/kits/" },
    { "@type": "ListItem", "position": 3, "name": club.club },
  ],
});

const typeLabel: Record<string, string> = { home: "Home", away: "Away", third: "Third", goalkeeper: "GK" };
---

<Base
  title={`${club.club} Kit History — Every Home & Away Kit`}
  description={`Complete ${club.club} kit archive. Every home and away shirt from ${seasons[seasons.length - 1]} to ${seasons[0]}. Browse by season and find where to buy retro kits.`}
  canonical={`/kits/${club.clubSlug}/`}
  accentColor={league?.accentColor}
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <div class="container">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <a href="/kits/">Kits</a>
      <span class="sep">/</span>
      <span class="current">{club.club}</span>
    </nav>

    <section class="page-hero">
      <h1>{club.club} Kit History</h1>
      <p class="subtitle">
        <a href={`/${club.leagueSlug}/`}>{club.league}</a>
        {club.founded && <span> &mdash; Founded {club.founded}</span>}
      </p>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-value">{club.kits.length}</span>
          <span class="hero-stat-label">Kits Archived</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">{seasons.length}</span>
          <span class="hero-stat-label">Seasons</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">{manufacturers.length}</span>
          <span class="hero-stat-label">Manufacturers</span>
        </div>
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">All Kits by Season</h2>
      {seasons.map((season) => {
        const kits = kitsBySeason.get(season)!;
        return (
          <div class="kit-season-row" id={season}>
            <h3 class="kit-season-label">{season}</h3>
            <div class="kit-season-grid">
              {kits.map((kit) => (
                <a href={`/kits/${club.clubSlug}/${season}-${kit.type}/`} class="kit-grid-card">
                  <KitIllustration
                    primary={kit.primaryColor}
                    secondary={kit.secondaryColor}
                    tertiary={kit.tertiaryColor}
                    type={kit.type}
                    size="sm"
                    manufacturer={kit.manufacturer}
                  />
                  <div class="kit-grid-info">
                    <span class={`kit-type-pill kit-type-${kit.type}`}>{typeLabel[kit.type]}</span>
                    <span class="kit-grid-brand">{kit.manufacturer}</span>
                    {kit.sponsor && <span class="kit-grid-sponsor">{kit.sponsor}</span>}
                  </div>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </section>

    <section class="section">
      <h2 class="section-title">Manufacturer Timeline</h2>
      <div class="kit-timeline">
        {(() => {
          const eras: { manufacturer: string; from: string; to: string }[] = [];
          let current = { manufacturer: club.kits[club.kits.length - 1]?.manufacturer, from: club.kits[club.kits.length - 1]?.season, to: "" };
          for (let i = club.kits.length - 1; i >= 0; i--) {
            const kit = club.kits[i];
            if (kit.type !== "home") continue;
            if (kit.manufacturer !== current.manufacturer) {
              current.to = club.kits[i + 1]?.season || kit.season;
              eras.push({ ...current });
              current = { manufacturer: kit.manufacturer, from: kit.season, to: "" };
            }
          }
          current.to = club.kits[0]?.season || "";
          eras.push({ ...current });
          return eras.map((era) => (
            <div class="timeline-block">
              <span class="timeline-years">{era.from} &mdash; {era.to}</span>
              <span class="timeline-brand">{era.manufacturer}</span>
            </div>
          ));
        })()}
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">Club Stats</h2>
      <p>View <a href={`/clubs/${club.clubSlug}/`}>{club.club}'s season history and league positions</a>.</p>
    </section>
  </div>
</Base>

<style>
  .kit-season-row {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-light);
  }
  .kit-season-row:last-child { border-bottom: none; }
  .kit-season-label {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.85rem;
  }
  .kit-season-grid {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .kit-grid-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1.1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--text);
    transition: all 0.2s;
    min-width: 240px;
    flex: 1 1 240px;
    max-width: 360px;
  }
  .kit-grid-card:hover {
    border-color: var(--border);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
  }
  .kit-grid-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .kit-type-pill {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    width: fit-content;
  }
  .kit-type-home { color: #059669; background: rgba(5,150,105,0.08); }
  .kit-type-away { color: #2563eb; background: rgba(37,99,235,0.08); }
  .kit-type-third { color: #9333ea; background: rgba(147,51,234,0.08); }
  .kit-type-goalkeeper { color: #d97706; background: rgba(217,119,6,0.08); }
  .kit-grid-brand {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text);
  }
  .kit-grid-sponsor {
    font-size: 0.75rem;
    color: var(--text-muted);
  }
  .kit-timeline { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .timeline-block {
    background: var(--bg-alt);
    border: 1px solid var(--border-light);
    border-radius: var(--radius);
    padding: 0.65rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .timeline-years { font-size: 0.7rem; color: var(--text-muted); font-weight: 500; }
  .timeline-brand { font-size: 0.9rem; font-weight: 700; color: var(--text); }

  @media (max-width: 480px) {
    .kit-grid-card { min-width: 100%; max-width: 100%; }
  }
</style>
