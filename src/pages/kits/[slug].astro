---
import Base from "../../layouts/Base.astro";
import { allClubKitArchives } from "../../data/kits/index";
import { leagues } from "../../data/leagues/index";

export function getStaticPaths() {
  return allClubKitArchives.map((club) => ({
    params: { slug: club.clubSlug },
    props: { club },
  }));
}

const { club } = Astro.props;
const league = leagues.find(l => l.slug === club.leagueSlug);

const kitsBySeason = new Map<string, typeof club.kits>();
for (const kit of club.kits) {
  if (!kitsBySeason.has(kit.season)) kitsBySeason.set(kit.season, []);
  kitsBySeason.get(kit.season)!.push(kit);
}
const seasons = [...kitsBySeason.keys()].sort((a, b) => b.localeCompare(a));
const manufacturers = [...new Set(club.kits.map(k => k.manufacturer))];

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lastseason.co.uk/" },
    { "@type": "ListItem", "position": 2, "name": "Kits", "item": "https://lastseason.co.uk/kits/" },
    { "@type": "ListItem", "position": 3, "name": club.club },
  ],
});

const typeLabel: Record<string, string> = { home: "Home", away: "Away", third: "Third", goalkeeper: "GK" };
---

<Base
  title={`${club.club} Kit History — Every Home & Away Kit`}
  description={`Complete ${club.club} kit archive. Every home and away shirt from ${seasons[seasons.length - 1]} to ${seasons[0]}. Browse by season and find where to buy retro kits.`}
  canonical={`/kits/${club.clubSlug}/`}
  accentColor={league?.accentColor}
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <div class="container">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <a href="/kits/">Kits</a>
      <span class="sep">/</span>
      <span class="current">{club.club}</span>
    </nav>

    <section class="page-hero">
      <h1>{club.club} Kit History</h1>
      <p class="subtitle">
        <a href={`/${club.leagueSlug}/`}>{club.league}</a>
        {club.founded && <span> &mdash; Founded {club.founded}</span>}
      </p>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-value">{club.kits.length}</span>
          <span class="hero-stat-label">Kits Archived</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">{seasons.length}</span>
          <span class="hero-stat-label">Seasons</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">{manufacturers.length}</span>
          <span class="hero-stat-label">Manufacturers</span>
        </div>
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">Full Kit History</h2>
      <div class="table-wrap" role="region" aria-label="Kit history table" tabindex="0">
        <table class="stats-table" aria-label="Kit history">
          <thead>
            <tr>
              <th scope="col">Season</th>
              <th scope="col">Type</th>
              <th scope="col">Manufacturer</th>
              <th scope="col">Sponsor</th>
              <th scope="col">Colours</th>
              <th scope="col">Buy</th>
            </tr>
          </thead>
          <tbody>
            {club.kits.map((kit) => (
              <tr>
                <td><a href={`/kits/${club.clubSlug}/${kit.season}-${kit.type}/`}>{kit.season}</a></td>
                <td><span class={`kit-type-badge kit-type-${kit.type}`}>{typeLabel[kit.type]}</span></td>
                <td>{kit.manufacturer}</td>
                <td>{kit.sponsor || "—"}</td>
                <td>
                  <span class="colour-dots">
                    <span class="colour-dot" style={`background:${kit.primaryColor}`}></span>
                    <span class="colour-dot" style={`background:${kit.secondaryColor}`}></span>
                    {kit.tertiaryColor && <span class="colour-dot" style={`background:${kit.tertiaryColor}`}></span>}
                  </span>
                </td>
                <td>
                  <a href={`/kits/${club.clubSlug}/${kit.season}-${kit.type}/`} class="kit-view-link">View &rarr;</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">Manufacturer Timeline</h2>
      <div class="kit-timeline">
        {(() => {
          const eras: { manufacturer: string; from: string; to: string }[] = [];
          let current = { manufacturer: club.kits[club.kits.length - 1]?.manufacturer, from: club.kits[club.kits.length - 1]?.season, to: "" };
          for (let i = club.kits.length - 1; i >= 0; i--) {
            const kit = club.kits[i];
            if (kit.type !== "home") continue;
            if (kit.manufacturer !== current.manufacturer) {
              current.to = club.kits[i + 1]?.season || kit.season;
              eras.push({ ...current });
              current = { manufacturer: kit.manufacturer, from: kit.season, to: "" };
            }
          }
          current.to = club.kits[0]?.season || "";
          eras.push({ ...current });
          return eras.map((era) => (
            <div class="timeline-block">
              <span class="timeline-years">{era.from} — {era.to}</span>
              <span class="timeline-brand">{era.manufacturer}</span>
            </div>
          ));
        })()}
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">Club Stats</h2>
      <p>View <a href={`/clubs/${club.clubSlug}/`}>{club.club}'s season history and league positions</a>.</p>
    </section>
  </div>
</Base>

<style>
  .kit-type-badge {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    background: var(--bg-alt);
    border: 1px solid var(--border-light);
  }
  .kit-type-home { color: var(--cl-green); border-color: rgba(5, 150, 105, 0.2); background: rgba(5, 150, 105, 0.06); }
  .kit-type-away { color: var(--el-blue); border-color: rgba(37, 99, 235, 0.2); background: rgba(37, 99, 235, 0.06); }
  .kit-type-third { color: #9333ea; border-color: rgba(147, 51, 234, 0.2); background: rgba(147, 51, 234, 0.06); }
  .colour-dots { display: flex; gap: 0.3rem; align-items: center; }
  .colour-dot {
    width: 16px; height: 16px;
    border-radius: 50%;
    border: 2px solid var(--border);
    flex-shrink: 0;
  }
  .kit-view-link {
    font-size: 0.8rem;
    font-weight: 600;
    white-space: nowrap;
  }
  .kit-timeline {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .timeline-block {
    background: var(--bg-alt);
    border: 1px solid var(--border-light);
    border-radius: var(--radius);
    padding: 0.65rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .timeline-years {
    font-size: 0.7rem;
    color: var(--text-muted);
    font-weight: 500;
  }
  .timeline-brand {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text);
  }
</style>
