---
import Base from "../../layouts/Base.astro";
import { allClubKitArchives } from "../../data/kits/index";
import { leagues } from "../../data/leagues/index";

export function getStaticPaths() {
  return allClubKitArchives.map((club) => ({
    params: { slug: club.clubSlug },
    props: { club },
  }));
}

const { club } = Astro.props;
const league = leagues.find(l => l.slug === club.leagueSlug);

const kitsBySeason = new Map<string, typeof club.kits>();
for (const kit of club.kits) {
  if (!kitsBySeason.has(kit.season)) kitsBySeason.set(kit.season, []);
  kitsBySeason.get(kit.season)!.push(kit);
}
const seasons = [...kitsBySeason.keys()].sort((a, b) => b.localeCompare(a));

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lastseason.co.uk/" },
    { "@type": "ListItem", "position": 2, "name": "Kits", "item": "https://lastseason.co.uk/kits/" },
    { "@type": "ListItem", "position": 3, "name": club.club },
  ],
});

const typeLabel: Record<string, string> = { home: "Home", away: "Away", third: "Third", goalkeeper: "GK" };
---

<Base
  title={`${club.club} Kit History — Every Home & Away Kit`}
  description={`Complete ${club.club} kit archive. Every home and away shirt from ${seasons[seasons.length - 1]} to ${seasons[0]}. Browse by season and find where to buy retro kits.`}
  canonical={`/kits/${club.clubSlug}/`}
  accentColor={league?.accentColor}
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <div class="container">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <a href="/kits/">Kits</a>
      <span class="sep">/</span>
      <span class="current">{club.club}</span>
    </nav>

    <section class="page-hero">
      <h1>{club.club} Kit History</h1>
      <p class="subtitle">
        <a href={`/${club.leagueSlug}/`}>{club.league}</a>
        {club.founded && <span> &mdash; Founded {club.founded}</span>}
      </p>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-value">{club.kits.length}</span>
          <span class="hero-stat-label">Kits Archived</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">{seasons.length}</span>
          <span class="hero-stat-label">Seasons</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">{[...new Set(club.kits.map(k => k.manufacturer))].length}</span>
          <span class="hero-stat-label">Manufacturers</span>
        </div>
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">All Kits by Season</h2>

      {seasons.map((season) => {
        const kits = kitsBySeason.get(season)!;
        return (
          <div class="kit-season-row" id={season}>
            <h3 class="kit-season-heading">{season}</h3>
            <div class="kit-cards-row">
              {kits.map((kit) => (
                <a href={`/kits/${club.clubSlug}/${season}-${kit.type}/`} class="kit-card">
                  <div class="kit-shirt-preview" aria-hidden="true">
                    <svg viewBox="0 0 100 120" class="kit-shirt-svg">
                      <path d="M25,0 L0,20 L15,25 L15,120 L85,120 L85,25 L100,20 L75,0 Z"
                        fill={kit.primaryColor} stroke={kit.secondaryColor} stroke-width="2"/>
                      <path d="M35,0 L50,15 L65,0" fill="none" stroke={kit.secondaryColor} stroke-width="2"/>
                    </svg>
                  </div>
                  <span class="kit-card-type">{typeLabel[kit.type] || kit.type}</span>
                  <span class="kit-card-brand">{kit.manufacturer}</span>
                  {kit.sponsor && <span class="kit-card-sponsor">{kit.sponsor}</span>}
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </section>

    <section class="section">
      <h2 class="section-title">Club Stats</h2>
      <p>View <a href={`/clubs/${club.clubSlug}/`}>{club.club}'s season history and league positions</a>.</p>
    </section>
  </div>
</Base>

<style>
  .kit-season-row {
    margin-bottom: 1.75rem;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid var(--border-light);
  }
  .kit-season-row:last-child { border-bottom: none; }
  .kit-season-heading {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--text-secondary);
  }
  .kit-cards-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .kit-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 120px;
    padding: 1rem 0.75rem;
    background: var(--bg-alt);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--text);
    transition: all 0.2s;
    text-align: center;
  }
  .kit-card:hover {
    border-color: var(--border);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
  }
  .kit-shirt-preview {
    width: 60px;
    height: 72px;
    margin-bottom: 0.5rem;
  }
  .kit-shirt-svg { width: 100%; height: 100%; }
  .kit-card-type {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .kit-card-brand {
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }
  .kit-card-sponsor {
    font-size: 0.62rem;
    color: var(--text-muted);
    opacity: 0.7;
    margin-top: 0.1rem;
  }
  @media (max-width: 480px) {
    .kit-card { width: calc(50% - 0.375rem); }
  }
</style>
