---
import Base from "../../layouts/Base.astro";
import KitIllustration from "../../components/KitIllustration.astro";
import { allClubKitArchives, getKitArchivesByLeague } from "../../data/kits/index";
import { leagues } from "../../data/leagues/index";

const totalKits = allClubKitArchives.reduce((sum, c) => sum + c.kits.length, 0);
const totalClubs = allClubKitArchives.length;
---

<Base
  title="Football Kit Archive  -  Every Club, Every Season"
  description="Browse the complete football kit archive. Home, away and third kits for clubs across the Premier League, La Liga, Bundesliga, Serie A and more. Find where to buy vintage and retro shirts."
  canonical="/kits/"
>
  <section class="home-hero kits-hero" style="background-image: url('/img/hero-stadium.jpg');">
    <div class="container">
      <h1>Football Kit<br />Archive</h1>
      <p class="subtitle">Every club. Every season. Home and away kits from the 1980s to today, with links to buy vintage and retro shirts.</p>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-value">{totalClubs}</span>
          <span class="hero-stat-label">Clubs</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">{totalKits.toLocaleString()}</span>
          <span class="hero-stat-label">Kits Archived</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">{leagues.length}</span>
          <span class="hero-stat-label">Leagues</span>
        </div>
      </div>
    </div>
  </section>

  <div class="container home-leagues">
    {leagues.map((league) => {
      const clubs = getKitArchivesByLeague(league.slug);
      if (!clubs || clubs.length === 0) return null;
      return (
        <section class="league-section">
          <div class="league-section-header">
            <h2><a href={`/${league.slug}/`}>{league.name}</a></h2>
          </div>
          <div class="kit-hub-grid">
            {clubs.map((club) => {
              const kitCount = club.kits.length;
              const latestHome = club.kits.find(k => k.type === "home");
              const latestAway = club.kits.find(k => k.type === "away");
              const yearsRange = club.kits.length > 0
                ? `${club.kits[club.kits.length - 1].season}  -  ${club.kits[0].season}`
                : "";
              return (
                <a href={`/kits/${club.clubSlug}/`} class="kit-hub-card">
                  <div class="kit-hub-previews">
                    {latestHome && (
                      <KitIllustration
                        primary={latestHome.primaryColor}
                        secondary={latestHome.secondaryColor}
                        tertiary={latestHome.tertiaryColor}
                        size="sm"
                      />
                    )}
                    {latestAway && (
                      <KitIllustration
                        primary={latestAway.primaryColor}
                        secondary={latestAway.secondaryColor}
                        tertiary={latestAway.tertiaryColor}
                        size="sm"
                      />
                    )}
                  </div>
                  <div class="kit-hub-info">
                    <h3>{club.club}</h3>
                    <p class="meta"><strong>{kitCount} kits</strong> archived</p>
                    <p class="meta">{yearsRange}</p>
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      );
    })}
  </div>
</Base>

<style>
  .kit-hub-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 0.875rem;
  }
  .kit-hub-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--text);
    transition: all 0.2s;
  }
  .kit-hub-card:hover {
    box-shadow: var(--shadow-md);
    border-color: rgba(0,0,0,0.12);
    transform: translateY(-2px);
    text-decoration: none;
  }
  .kit-hub-previews {
    display: flex;
    gap: 0.25rem;
    flex-shrink: 0;
  }
  .kit-hub-info h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
  }
  .kit-hub-info .meta {
    color: var(--text-secondary);
    font-size: 0.82rem;
    margin-bottom: 0.15rem;
  }
  .kit-hub-info .meta strong { color: var(--text); }
  @media (max-width: 480px) {
    .kit-hub-grid { grid-template-columns: 1fr; }
  }
</style>
