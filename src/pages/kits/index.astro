---
import Base from "../../layouts/Base.astro";
import { allClubKitArchives, getKitArchivesByLeague } from "../../data/kits/index";
import { leagues } from "../../data/leagues/index";

const totalKits = allClubKitArchives.reduce((sum, c) => sum + c.kits.length, 0);
const totalClubs = allClubKitArchives.length;
---

<Base
  title="Football Kit Archive — Every Club, Every Season"
  description="Browse the complete football kit archive. Home, away and third kits for clubs across the Premier League, La Liga, Bundesliga, Serie A and more. Find where to buy vintage and retro shirts."
  canonical="/kits/"
>
  <section class="home-hero kits-hero" style="background-image: url('/img/hero-stadium.jpg');">
    <div class="container">
      <h1>Football Kit<br />Archive</h1>
      <p class="subtitle">Every club. Every season. Home and away kits from the 1980s to today, with links to buy vintage and retro shirts.</p>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-value">{totalClubs}</span>
          <span class="hero-stat-label">Clubs</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">{totalKits.toLocaleString()}</span>
          <span class="hero-stat-label">Kits Archived</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">{leagues.length}</span>
          <span class="hero-stat-label">Leagues</span>
        </div>
      </div>
    </div>
  </section>

  <div class="container home-leagues">
    {leagues.map((league) => {
      const clubs = getKitArchivesByLeague(league.slug);
      if (!clubs || clubs.length === 0) return null;
      return (
        <section class="league-section">
          <div class="league-section-header">
            <h2><a href={`/${league.slug}/`}>{league.name}</a></h2>
          </div>
          <div class="card-grid">
            {clubs.map((club) => {
              const kitCount = club.kits.length;
              const decades = new Set(club.kits.map(k => k.season.slice(0, 3) + "0s"));
              const yearsRange = club.kits.length > 0
                ? `${club.kits[club.kits.length - 1].season} — ${club.kits[0].season}`
                : "";
              return (
                <a href={`/kits/${club.clubSlug}/`} class="card card-accent" style={`border-top-color: ${league.accentColor}`}>
                  <div class="kit-color-preview">
                    <span class="kit-swatch" style={`background: ${club.kits[0]?.primaryColor || '#ccc'}`}></span>
                    <span class="kit-swatch" style={`background: ${club.kits[0]?.secondaryColor || '#ccc'}`}></span>
                  </div>
                  <h3>{club.club}</h3>
                  <p class="meta"><strong>{kitCount} kits</strong> archived</p>
                  <p class="meta">{yearsRange}</p>
                </a>
              );
            })}
          </div>
        </section>
      );
    })}
  </div>
</Base>
