---
import Base from "../../layouts/Base.astro";
import { plGoldenBoots } from "../../data/records/premier-league";

const mostWins = new Map<string, number>();
for (const entry of plGoldenBoots) {
  const players = entry.player.split(" / ");
  for (const p of players) {
    mostWins.set(p, (mostWins.get(p) || 0) + 1);
  }
}
const topBootWinner = Array.from(mostWins.entries()).sort((a, b) => b[1] - a[1])[0];
const highestGoals = Math.max(...plGoldenBoots.map(e => e.goals));
const highestEntry = plGoldenBoots.find(e => e.goals === highestGoals)!;

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lastseason.co.uk/" },
    { "@type": "ListItem", "position": 2, "name": "Records", "item": "https://lastseason.co.uk/records/" },
    { "@type": "ListItem", "position": 3, "name": "Golden Boot Winners" }
  ]
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Who has won the most Premier League Golden Boots?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${topBootWinner[0]} has won the most Premier League Golden Boots with ${topBootWinner[1]} awards.`
      }
    },
    {
      "@type": "Question",
      "name": "What is the Premier League Golden Boot scoring record?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `The Premier League Golden Boot scoring record is ${highestGoals} goals, set by ${highestEntry.player} of ${highestEntry.club} in ${highestEntry.season}.`
      }
    }
  ]
});

const seasonToSlug = (s: string) => s.toLowerCase();
---

<Base
  title="Premier League Golden Boot Winners — Every Top Scorer by Season"
  description="Every Premier League Golden Boot winner from 1992-93 to 2024-25. See which player finished as the top scorer in every Premier League season, with goals and clubs."
  canonical="/records/golden-boot/"
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />
  <script type="application/ld+json" set:html={faqSchema} />

  <div class="container">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <a href="/records/">Records</a>
      <span class="sep">/</span>
      <span class="current">Golden Boot Winners</span>
    </nav>

    <section class="page-hero">
      <h1>Premier League Golden Boot Winners</h1>
      <p class="subtitle">Every top scorer in Premier League history, season by season since 1992.</p>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-value">{plGoldenBoots.length}</span>
          <span class="hero-stat-label">Seasons</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">{topBootWinner[0]}</span>
          <span class="hero-stat-label">Most Awards ({topBootWinner[1]})</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">{highestGoals}</span>
          <span class="hero-stat-label">Record Goals ({highestEntry.season})</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">{(plGoldenBoots.reduce((s, e) => s + e.goals, 0) / plGoldenBoots.length).toFixed(1)}</span>
          <span class="hero-stat-label">Average Winning Goals</span>
        </div>
      </div>
    </section>

    <section class="section" id="golden-boot">
      <h2 class="section-title">Golden Boot Winners by Season</h2>
      <div class="table-wrap">
        <table class="stats-table">
          <thead>
            <tr>
              <th scope="col">Season</th>
              <th scope="col">Player</th>
              <th scope="col">Club</th>
              <th scope="col">Goals</th>
            </tr>
          </thead>
          <tbody>
            {plGoldenBoots.map((row) => (
              <tr>
                <td><a href={`/premier-league/${seasonToSlug(row.season)}/`}>{row.season}</a></td>
                <td><a href={`/players/${row.slug}/`}>{row.player}</a></td>
                <td>{row.club}</td>
                <td><strong>{row.goals}</strong></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </div>
</Base>
