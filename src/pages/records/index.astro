---
import Base from "../../layouts/Base.astro";

const subPages = [
  { href: "/records/all-time-top-scorers/", title: "All-Time Top Scorers", desc: "The 25 highest Premier League goalscorers of all time, with goals, appearances and clubs." },
  { href: "/records/winners/", title: "Winners List", desc: "Every Premier League champion from 1992-93 to 2024-25, with managers and points tallies." },
  { href: "/records/golden-boot/", title: "Golden Boot Winners", desc: "Every Premier League top scorer by season  -  from Teddy Sheringham to Mohamed Salah." },
  { href: "/records/relegation-history/", title: "Relegation History", desc: "Premier League relegation results published by season." },
  { href: "/records/premier-league-records/", title: "Records & Milestones", desc: "Selected Premier League points, goals, wins and unbeaten-run records." },
  { href: "/records/winners/", title: "Title Counts", desc: "Premier League champions and title counts across the published archive." },
];

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lastseason.co.uk/" },
    { "@type": "ListItem", "position": 2, "name": "Records" }
  ]
});
---

<Base
  title="Premier League Records & All-Time Stats"
  description="Premier League records, all-time stats and historical data. Top scorers, title winners, Golden Boot history, relegation records and milestone achievements since 1992."
  canonical="/records/"
  robots="noindex, follow"
>
  <script is:inline type="application/ld+json" set:html={breadcrumbSchema} />

  <div class="container">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <span class="current">Records</span>
    </nav>

    <section class="page-hero">
      <h1>Premier League Records &amp; All-Time Stats</h1>
      <p class="subtitle">A legacy record section currently being reconciled against primary sources.</p>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-value">33</span>
          <span class="hero-stat-label">Seasons</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">7</span>
          <span class="hero-stat-label">Different Champions</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">260</span>
          <span class="hero-stat-label">Record Goals (Shearer)</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">100</span>
          <span class="hero-stat-label">Record Points (Man City)</span>
        </div>
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">Browse Records</h2>
      <div class="card-grid">
        {subPages.map((page) => (
          <a href={page.href} class="card">
            <h3>{page.title}</h3>
            <p class="meta">{page.desc}</p>
          </a>
        ))}
      </div>
    </section>
  </div>
</Base>
