---
import Base from "../../layouts/Base.astro";
import { plRecords } from "../../data/records/premier-league";

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lastseason.co.uk/" },
    { "@type": "ListItem", "position": 2, "name": "Records", "item": "https://lastseason.co.uk/records/" },
    { "@type": "ListItem", "position": 3, "name": "Records & Milestones" },
  ],
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is the most points in a Premier League season?",
      "acceptedAnswer": { "@type": "Answer", "text": "Manchester City hold the record with 100 points in the 2017-18 season under Pep Guardiola." }},
    { "@type": "Question", "name": "Who scored the most goals in a single Premier League season?",
      "acceptedAnswer": { "@type": "Answer", "text": "Erling Haaland scored 36 goals for Manchester City in the 2022-23 season, breaking the previous record." }},
    { "@type": "Question", "name": "Has any team gone unbeaten in the Premier League?",
      "acceptedAnswer": { "@type": "Answer", "text": "Arsenal went the entire 2003-04 season unbeaten (26 wins, 12 draws), earning the nickname 'The Invincibles'." }},
    { "@type": "Question", "name": "What is the biggest win in Premier League history?",
      "acceptedAnswer": { "@type": "Answer", "text": "The record is 9-0, achieved by Manchester United vs Ipswich Town in 1995 and Liverpool vs AFC Bournemouth in 2022." }},
  ],
});
---

<Base
  title="Premier League Records & Milestones  -  All-Time Stats"
  description="Every Premier League record: most points, most goals, biggest wins, fastest goals, longest unbeaten runs and more. Complete stats and milestones from 1992 to present."
  canonical="/records/premier-league-records/"
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />
  <script type="application/ld+json" set:html={faqSchema} />

  <div class="container">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <a href="/records/">Records</a>
      <span class="sep">/</span>
      <span class="current">Records & Milestones</span>
    </nav>

    <section class="page-hero">
      <h1>Premier League Records & Milestones</h1>
      <p class="subtitle">Every major record in Premier League history, from the most points in a season to the fastest goal ever scored.</p>
    </section>

    <section class="section">
      <h2 class="section-title">All-Time Records</h2>
      <div class="table-wrap" role="region" aria-label="Premier League records table" tabindex="0">
        <table class="stats-table" aria-label="Premier League records">
          <thead>
            <tr>
              <th scope="col">Record</th>
              <th scope="col">Value</th>
              <th scope="col">Holder</th>
              <th scope="col">Season</th>
            </tr>
          </thead>
          <tbody>
            {plRecords.map((r) => (
              <tr>
                <td><strong>{r.record}</strong></td>
                <td><strong>{r.value}</strong></td>
                <td>{r.holder}</td>
                <td>{r.season}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">The Invincibles</h2>
      <div class="narrative">
        <p>Arsenal's 2003-04 season remains the only unbeaten campaign in Premier League history. Arsene Wenger's side won 26 and drew 12 of their 38 matches, claiming the title with 90 points. The team, known as "The Invincibles," extended their unbeaten run to 49 consecutive league matches before losing to Manchester United in October 2004.</p>
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">Manchester City's Centurions</h2>
      <div class="narrative">
        <p>In 2017-18, Pep Guardiola's Manchester City became the first team to reach 100 points in a Premier League season. They also set records for most wins (32), most goals (106), and most consecutive wins (18). City finished 19 points ahead of second-placed Manchester United in the most dominant title win the league has ever seen.</p>
      </div>
    </section>
  </div>
</Base>
