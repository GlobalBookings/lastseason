---
import Base from "../../layouts/Base.astro";
import { plWinners, plTitleCounts } from "../../data/records/premier-league";

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lastseason.co.uk/" },
    { "@type": "ListItem", "position": 2, "name": "Records", "item": "https://lastseason.co.uk/records/" },
    { "@type": "ListItem", "position": 3, "name": "Winners" }
  ]
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Who has won the most Premier League titles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Manchester United have won the most Premier League titles with 13 championships, all under Sir Alex Ferguson between 1992-93 and 2012-13."
      }
    },
    {
      "@type": "Question",
      "name": "How many times have Manchester United won the Premier League?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Manchester United have won the Premier League 13 times: 1992-93, 1993-94, 1995-96, 1996-97, 1998-99, 1999-00, 2000-01, 2002-03, 2006-07, 2007-08, 2008-09, 2010-11 and 2012-13."
      }
    },
    {
      "@type": "Question",
      "name": "When did Leicester City win the Premier League?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Leicester City won the Premier League in 2015-16 under manager Claudio Ranieri with 81 points, one of the greatest upsets in sporting history."
      }
    }
  ]
});

const seasonToSlug = (s: string) => s.toLowerCase();
---

<Base
  title="Every Premier League Winner  -  Complete List 1992 to 2025"
  description="The complete list of every Premier League winner from 1992-93 to 2024-25. Title counts by club, winning managers, points totals and runners-up for all 33 seasons."
  canonical="/records/winners/"
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />
  <script type="application/ld+json" set:html={faqSchema} />

  <div class="container">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <a href="/records/">Records</a>
      <span class="sep">/</span>
      <span class="current">Winners</span>
    </nav>

    <section class="page-hero">
      <h1>Every Premier League Winner</h1>
      <p class="subtitle">Complete list of Premier League champions from 1992 to 2025, with title counts, managers and points.</p>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-value">{plWinners.length}</span>
          <span class="hero-stat-label">Seasons</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">{plTitleCounts.length}</span>
          <span class="hero-stat-label">Different Winners</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">{plTitleCounts[0].titles}</span>
          <span class="hero-stat-label">Most Titles (Man Utd)</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">100</span>
          <span class="hero-stat-label">Record Points (Man City)</span>
        </div>
      </div>
    </section>

    <section class="section" id="title-counts">
      <h2 class="section-title">Title Count by Club</h2>
      <div class="table-wrap">
        <table class="stats-table">
          <thead>
            <tr>
              <th scope="col">Club</th>
              <th scope="col">Titles</th>
              <th scope="col">Winning Seasons</th>
            </tr>
          </thead>
          <tbody>
            {plTitleCounts.map((row) => (
              <tr>
                <td><strong>{row.club}</strong></td>
                <td>{row.titles}</td>
                <td>{row.years}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="section" id="winners">
      <h2 class="section-title">All Winners by Season</h2>
      <div class="table-wrap">
        <table class="stats-table">
          <thead>
            <tr>
              <th scope="col">Season</th>
              <th scope="col">Winner</th>
              <th scope="col">Manager</th>
              <th scope="col">Points</th>
              <th scope="col">Runner-Up</th>
            </tr>
          </thead>
          <tbody>
            {plWinners.map((row) => (
              <tr>
                <td><a href={`/premier-league/${seasonToSlug(row.season)}/`}>{row.season}</a></td>
                <td><strong>{row.winner}</strong></td>
                <td>{row.manager}</td>
                <td>{row.points}</td>
                <td>{row.runnerUp}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </div>
</Base>
