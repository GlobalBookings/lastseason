---
import type { Standing } from "../types";

interface Props {
  standings: Standing[];
  leagueSlug: string;
}

const { standings, leagueSlug } = Astro.props;
const hasPromotion = standings.some(s => s.zone === "promotion");
---

<div class="table-wrap" role="region" aria-label="League standings table" tabindex="0">
  <table class="stats-table" aria-label="Final league table">
    <thead>
      <tr>
        <th class="num" scope="col" abbr="Position">#</th>
        <th scope="col">Club</th>
        <th class="num" scope="col" abbr="Played">P</th>
        <th class="num" scope="col" abbr="Won">W</th>
        <th class="num" scope="col" abbr="Drawn">D</th>
        <th class="num" scope="col" abbr="Lost">L</th>
        <th class="num" scope="col" abbr="Goals For">GF</th>
        <th class="num" scope="col" abbr="Goals Against">GA</th>
        <th class="num" scope="col" abbr="Goal Difference">GD</th>
        <th class="num" scope="col" abbr="Points">Pts</th>
      </tr>
    </thead>
    <tbody>
      {standings.map((row) => (
        <tr class={row.zone ? `zone-${row.zone}` : ""}>
          <td class="num">{row.pos}</td>
          <td><a href={`/clubs/${row.clubSlug}/`}>{row.club}</a></td>
          <td class="num">{row.p}</td>
          <td class="num">{row.w}</td>
          <td class="num">{row.d}</td>
          <td class="num">{row.l}</td>
          <td class="num">{row.gf}</td>
          <td class="num">{row.ga}</td>
          <td class="num">{row.gd > 0 ? `+${row.gd}` : row.gd}</td>
          <td class="num"><strong>{row.pts}</strong></td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
<div class="table-legend" aria-label="Table legend">
  <span><span class="dot dot-cl"></span> Champions League</span>
  <span><span class="dot dot-el"></span> Europa League</span>
  <span><span class="dot dot-ecl"></span> Conference League</span>
  <span><span class="dot dot-rel"></span> Relegation</span>
  {hasPromotion && <span><span class="dot dot-promo"></span> Promotion</span>}
</div>
