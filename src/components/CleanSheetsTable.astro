---
import type { CleanSheet } from "../types";

interface Props {
  cleanSheets: CleanSheet[];
  linkEntities?: boolean;
}

const { cleanSheets, linkEntities = true } = Astro.props;
---

{cleanSheets.length > 0 && <section class="section" id="clean-sheets">
  <h2 class="section-title">Clean Sheet Leaders</h2>
  <div class="table-wrap" role="region" aria-label="Clean sheet leaders table" tabindex="0">
    <table class="stats-table" aria-label="Clean sheet leaders">
      <thead>
        <tr>
          <th class="num" scope="col">#</th>
          <th scope="col">Goalkeeper</th>
          <th scope="col">Club</th>
          <th class="num" scope="col">Clean Sheets</th>
        </tr>
      </thead>
      <tbody>
        {cleanSheets.map((cs, i) => (
          <tr>
            <td class="num">{i + 1}</td>
            <td>{linkEntities ? <a href={`/players/${cs.playerSlug}/`}>{cs.name}</a> : cs.name}</td>
            <td>{linkEntities ? <a href={`/clubs/${cs.clubSlug}/`}>{cs.club}</a> : cs.club}</td>
            <td class="num"><strong>{cs.cleanSheets}</strong></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>}
