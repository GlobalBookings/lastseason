---
interface Props {
  leagueSlug: string;
  season: string;
  champion: string;
  topScorer: string;
  topScorerGoals: number;
  totalGoals?: number;
  accentColor?: string;
}

const { leagueSlug, season, champion, topScorer, topScorerGoals, totalGoals, accentColor } = Astro.props;
---

<a href={`/${leagueSlug}/${season}/`} class="card card-accent season-card" style={accentColor ? `border-top-color: ${accentColor}` : ""}>
  <span class="card-tag">{season}</span>
  <p class="meta">Champion: <strong>{champion}</strong></p>
  <p class="meta">Top scorer: <strong>{topScorer}</strong> ({topScorerGoals} goals)</p>
  {totalGoals && <p class="meta goals-total">{totalGoals.toLocaleString()} total goals</p>}
</a>

<style>
  .season-card {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .season-card:hover { text-decoration: none; }
  .goals-total {
    font-variant-numeric: tabular-nums;
    font-size: 0.78rem !important;
    margin-top: 0.35rem;
    opacity: 0.7;
  }
</style>
