---
interface Props {
  leagueSlug: string;
  season: string;
  champion: string;
  topScorer: string;
  topScorerGoals: number;
  totalGoals?: number;
  accentColor?: string;
}

const { leagueSlug, season, champion, topScorer, topScorerGoals, totalGoals, accentColor } = Astro.props;
---

<a href={`/${leagueSlug}/${season}/`} class="card card-accent" style={accentColor ? `border-top-color: ${accentColor}` : ""}>
  <h3>{season}</h3>
  <p class="meta">Champion: <strong>{champion}</strong></p>
  <p class="meta">Top scorer: {topScorer} ({topScorerGoals} goals)</p>
  {totalGoals && <p class="meta">{totalGoals} total goals scored</p>}
</a>

<style>
  a.card {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  a.card:hover {
    text-decoration: none;
  }
</style>
