---
import type { Assister } from "../types";

interface Props {
  assisters: Assister[];
  linkEntities?: boolean;
}

const { assisters, linkEntities = true } = Astro.props;
---

{assisters.length > 0 && <section class="section" id="assists">
  <h2 class="section-title">Top Assisters</h2>
  <div class="table-wrap" role="region" aria-label="Top assisters table" tabindex="0">
    <table class="stats-table" aria-label="Top assisters">
      <thead>
        <tr>
          <th class="num" scope="col">#</th>
          <th scope="col">Player</th>
          <th scope="col">Club</th>
          <th class="num" scope="col">Assists</th>
        </tr>
      </thead>
      <tbody>
        {assisters.map((a, i) => (
          <tr>
            <td class="num">{i + 1}</td>
            <td>{linkEntities ? <a href={`/players/${a.playerSlug}/`}>{a.name}</a> : a.name}</td>
            <td>{linkEntities ? <a href={`/clubs/${a.clubSlug}/`}>{a.club}</a> : a.club}</td>
            <td class="num"><strong>{a.assists}</strong></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>}
