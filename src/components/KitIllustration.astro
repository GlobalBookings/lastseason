---
interface Props {
  primary: string;
  secondary: string;
  tertiary?: string;
  type?: "home" | "away" | "third" | "goalkeeper";
  size?: "sm" | "md" | "lg";
  manufacturer?: string;
}

const { primary, secondary, tertiary, type = "home", size = "md", manufacturer } = Astro.props;

const sizes = { sm: { w: 80, h: 96 }, md: { w: 140, h: 168 }, lg: { w: 200, h: 240 } };
const { w, h } = sizes[size];

const contrast = secondary;
const accent = tertiary || secondary;
---

<div class={`kit-illustration kit-illustration-${size}`} aria-hidden="true">
  <svg viewBox="0 0 200 240" width={w} height={h} xmlns="http://www.w3.org/2000/svg">
    <!-- Shirt body -->
    <path d="M60,0 L40,0 L0,35 L0,55 L25,50 L25,230 C25,235 30,240 35,240 L165,240 C170,240 175,235 175,230 L175,50 L200,55 L200,35 L160,0 L140,0 L120,20 C110,28 90,28 80,20 Z"
      fill={primary} />

    <!-- Collar -->
    <path d="M60,0 L80,20 C90,28 110,28 120,20 L140,0"
      fill="none" stroke={contrast} stroke-width="4" stroke-linecap="round" />

    <!-- Collar inner -->
    <path d="M65,2 L80,17 C90,25 110,25 120,17 L135,2"
      fill="none" stroke={contrast} stroke-width="1.5" opacity="0.3" />

    <!-- Sleeve seams -->
    <line x1="25" y1="50" x2="60" y2="0" stroke={contrast} stroke-width="1" opacity="0.15" />
    <line x1="175" y1="50" x2="140" y2="0" stroke={contrast} stroke-width="1" opacity="0.15" />

    <!-- Sleeve cuffs -->
    <rect x="0" y="47" width="26" height="6" rx="1" fill={contrast} opacity="0.7" />
    <rect x="174" y="47" width="26" height="6" rx="1" fill={contrast} opacity="0.7" />

    <!-- Bottom hem -->
    <rect x="25" y="232" width="150" height="8" rx="4" fill={contrast} opacity="0.15" />

    <!-- Side panels (subtle) -->
    <rect x="25" y="50" width="4" height="182" fill={contrast} opacity="0.08" />
    <rect x="171" y="50" width="4" height="182" fill={contrast} opacity="0.08" />

    <!-- Shirt shadow/fold lines -->
    <line x1="70" y1="60" x2="70" y2="230" stroke={contrast} stroke-width="0.5" opacity="0.06" />
    <line x1="130" y1="60" x2="130" y2="230" stroke={contrast} stroke-width="0.5" opacity="0.06" />
    <line x1="100" y1="40" x2="100" y2="230" stroke={contrast} stroke-width="0.5" opacity="0.04" />

    <!-- Manufacturer area (small bar) -->
    <rect x="85" y="55" width="30" height="4" rx="2" fill={contrast} opacity="0.2" />

    <!-- Sponsor text area (larger block) -->
    <rect x="60" y="100" width="80" height="18" rx="3" fill={contrast} opacity="0.12" />

    <!-- Badge area (left chest) -->
    <circle cx="65" cy="72" r="10" fill={contrast} opacity="0.1" />
    <circle cx="65" cy="72" r="7" fill={contrast} opacity="0.06" />

    <!-- Manufacturer logo area (right chest) -->
    <rect x="125" y="64" width="16" height="16" rx="2" fill={contrast} opacity="0.1" />
  </svg>
</div>

<style>
  .kit-illustration {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-shrink: 0;
  }
  .kit-illustration svg {
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.08));
    transition: transform 0.2s ease;
  }
  .kit-illustration:hover svg {
    transform: scale(1.03);
  }
</style>
