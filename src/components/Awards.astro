---
import type { Award } from "../types";
import { hasPublishedPlayerPage } from "../utils/data";

interface Props {
  awards: Award[];
  linkEntities?: boolean;
}

const { awards, linkEntities = true } = Astro.props;
---

{awards.length > 0 && <div class="section">
  <h2 class="section-title">Season Awards</h2>
  <div class="awards-grid">
    {awards.map((award) => (
      <div class="award-card">
        <div class="award-title">{award.title}</div>
        <div class="award-winner">
          {award.playerSlug && linkEntities && hasPublishedPlayerPage(award.playerSlug) ? (
            <a href={`/players/${award.playerSlug}/`}>{award.winner}</a>
          ) : (
            award.winner
          )}
        </div>
      </div>
    ))}
  </div>
</div>}
