---
import type { Scorer } from "../types";

interface Props {
  scorers: Scorer[];
  title?: string;
}

const { scorers, title = "Top Scorers" } = Astro.props;
---

<section class="section" id="scorers">
  <h2 class="section-title">{title}</h2>
  <div class="table-wrap" role="region" aria-label="Top scorers table" tabindex="0">
    <table class="stats-table" aria-label={title}>
      <thead>
        <tr>
          <th class="num" scope="col">#</th>
          <th scope="col">Player</th>
          <th scope="col">Club</th>
          <th class="num" scope="col">Goals</th>
          <th class="num" scope="col">Assists</th>
        </tr>
      </thead>
      <tbody>
        {scorers.map((s, i) => (
          <tr>
            <td class="num">{i + 1}</td>
            <td><a href={`/players/${s.playerSlug}/`}>{s.name}</a></td>
            <td><a href={`/clubs/${s.clubSlug}/`}>{s.club}</a></td>
            <td class="num"><strong>{s.goals}</strong></td>
            <td class="num">{s.assists}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>
