---
import type { Scorer } from "../types";

interface Props {
  scorers: Scorer[];
  title?: string;
  linkEntities?: boolean;
}

const { scorers, title = "Top Scorers", linkEntities = true } = Astro.props;
const showAssists = scorers.some((scorer) => scorer.assists !== undefined);
---

{scorers.length > 0 && <section class="section" id="scorers">
  <h2 class="section-title">{title}</h2>
  <div class="table-wrap" role="region" aria-label="Top scorers table" tabindex="0">
    <table class="stats-table" aria-label={title}>
      <thead>
        <tr>
          <th class="num" scope="col">#</th>
          <th scope="col">Player</th>
          <th scope="col">Club</th>
          <th class="num" scope="col">Goals</th>
          {showAssists && <th class="num" scope="col">Assists</th>}
        </tr>
      </thead>
      <tbody>
        {scorers.map((s, i) => (
          <tr>
            <td class="num">{i + 1}</td>
            <td>{linkEntities ? <a href={`/players/${s.playerSlug}/`}>{s.name}</a> : s.name}</td>
            <td>{linkEntities ? <a href={`/clubs/${s.clubSlug}/`}>{s.club}</a> : s.club}</td>
            <td class="num"><strong>{s.goals}</strong></td>
            {showAssists && <td class="num">{s.assists ?? "—"}</td>}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>}
